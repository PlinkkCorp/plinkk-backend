{
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.10",
  "scripts": {
    "prisma:migratedev": "bunx prisma migrate dev --config=packages/prisma/prisma.config.ts --schema=packages/prisma/prisma/schema.prisma",
    "prisma:dev": "bunx prisma dev --config=packages/prisma/prisma.config.ts --schema=packages/prisma/prisma/schema.prisma",
    "prisma:studio": "bunx prisma studio --config=packages/prisma/prisma.config.ts --schema=packages/prisma/prisma/schema.prisma",
    "prisma:init": "bunx prisma migrate deploy --config=packages/prisma/prisma.config.ts --schema=packages/prisma/prisma/schema.prisma",
    "postinstall": "bunx prisma generate --config=packages/prisma/prisma.config.ts --schema=packages/prisma/prisma/schema.prisma",
    "set-admin": "bun scripts/set-admin.cjs",
    "migrate:plinkks": "bun scripts/migrate-plinkks.cjs",
    "delete_inactive": "bun scripts/delete_inactive_user.js",
    "seed-permissions": "bun scripts/seed-permissions.js",
    "seed-email-templates": "bun scripts/seed-email-templates.js",
    "prisma:generate": "bunx prisma generate --config=packages/prisma/prisma.config.ts --schema=packages/prisma/prisma/schema.prisma",
    "build": "cd packages/prisma && bun run build && cd ../../packages/shared && bun run build && cd ../../apps/dashboard && bun run build && cd ../../apps/public && bun run build",
    "build:dashboard": "cd apps/dashboard && bun run build",
    "build:public": "cd apps/public && bun run build",
    "dev:dashboard": "cd apps/dashboard && bun run dev",
    "dev:public": "cd apps/public && bun run dev",
    "launch-all": "concurrently \"cd apps/dashboard && bun run dev\" \"cd apps/public && bun run dev\""
  },
  "devDependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "concurrently": "^9.2.1",
    "pg": "^8.20.0",
    "prisma": "^7.5.0"
  },
  "dependencies": {
    "@fastify/secure-session": "^8.3.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1"
  },
  "prisma": {
    "schema": "packages/prisma/prisma/schema.prisma"
  },
  "private": true
}
