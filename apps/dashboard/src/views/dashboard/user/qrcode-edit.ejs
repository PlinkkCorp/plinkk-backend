<%- include('partials/head.ejs', {
  title: 'Édition QR Code',
  description: 'Créez et modifiez vos codes QR pour votre Plinkk.',
  robots: 'noindex,nofollow'
}) %>
<%- include('partials/header-dash.ejs') %>

<div class="max-w-[1600px] mx-auto grid grid-cols-12 gap-6 px-4 py-8">
  <%- include('partials/asside_dash.ejs', { active: 'qrcodes' }) %>

  <main class="col-span-12 lg:col-span-10 space-y-6">
    <section class="bg-slate-900 border border-slate-800 rounded-3xl p-6">
      <h1 class="text-2xl font-bold text-white">Édition QR Code</h1>
      <p class="text-sm text-slate-400 mt-1">
        <span class="font-medium text-slate-300">Plinkk :</span>
        <%= plinkk.name %> (<span class="text-violet-400"><%= plinkk.slug %></span>)
      </p>
    </section>

    <section class="grid grid-cols-1 xl:grid-cols-12 gap-6">
      <div class="xl:col-span-5 bg-slate-900 border border-slate-800 rounded-3xl p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-white">Mes QR codes</h2>
          <button id="btnNewQr"
            class="px-3 py-2 text-sm font-medium rounded-xl bg-violet-600 hover:bg-violet-500 text-white transition-colors">
            Nouveau
          </button>
        </div>
        <div id="qrCodesList" class="space-y-3"></div>
      </div>

      <div class="xl:col-span-7 bg-slate-900 border border-slate-800 rounded-3xl p-6">
        <form id="qrCodeForm" class="space-y-5">
          <input type="hidden" id="qrCodeId" value="">

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="md:col-span-2">
              <label for="qrCodeName" class="block text-sm font-medium text-white mb-2">Nom du QR Code</label>
              <input type="text" id="qrCodeName" placeholder="Ex: Promotion Été 2026"
                class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-violet-500 transition-colors">
            </div>

            <div>
              <label for="qrCodeTargetType" class="block text-sm font-medium text-white mb-2">Cible</label>
              <select id="qrCodeTargetType"
                class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white focus:outline-none focus:border-violet-500 transition-colors">
                <option value="PLINKK_PAGE">Ma page Plinkk</option>
                <option value="PROFILE">Mon profil</option>
                <option value="CUSTOM_URL">URL personnalisée</option>
              </select>
            </div>

            <div>
              <label for="qrCodeMargin" class="block text-sm font-medium text-white mb-2">Marge</label>
              <div class="flex items-center gap-3">
                <input type="range" id="qrCodeMargin" min="0" max="8" value="2"
                  class="flex-1 h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-violet-600">
                <span id="qrCodeMarginValue" class="text-xs text-slate-400 w-6">2</span>
              </div>
            </div>

            <div id="customUrlGroup" class="md:col-span-2 hidden">
              <label for="qrCodeCustomUrl" class="block text-sm font-medium text-white mb-2">URL personnalisée</label>
              <input type="url" id="qrCodeCustomUrl" placeholder="https://example.com"
                class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-violet-500 transition-colors">
            </div>

            <div>
              <label for="qrCodeForegroundColor" class="block text-sm font-medium text-white mb-2">Couleur modules</label>
              <div class="flex items-center gap-3">
                <input type="color" id="qrCodeForegroundColor" value="#111827" class="w-10 h-10 rounded-lg border border-slate-700">
                <span id="qrCodeForegroundColorValue" class="text-xs text-slate-400 font-mono">#111827</span>
              </div>
            </div>

            <div>
              <label for="qrCodeBackgroundColor" class="block text-sm font-medium text-white mb-2">Couleur fond</label>
              <div class="flex items-center gap-3">
                <input type="color" id="qrCodeBackgroundColor" value="#ffffff" class="w-10 h-10 rounded-lg border border-slate-700">
                <span id="qrCodeBackgroundColorValue" class="text-xs text-slate-400 font-mono">#ffffff</span>
              </div>
            </div>

            <div class="md:col-span-2">
              <label class="inline-flex items-center gap-2 text-sm text-white cursor-pointer">
                <input type="checkbox" id="qrCodeRounded" class="accent-violet-600">
                Modules arrondis
              </label>
            </div>
          </div>

          <div class="border-t border-slate-800 pt-5">
            <p class="text-sm font-semibold text-white mb-3">Prévisualisation en direct</p>
            <div class="bg-slate-800 rounded-xl p-4 flex items-center justify-center min-h-[260px]">
              <div id="qrCodePreview" class="w-full max-w-[260px] flex items-center justify-center"></div>
            </div>
          </div>

          <div class="flex gap-3 pt-2">
            <button type="submit" id="qrCodeSubmitBtn"
              class="px-4 py-3 bg-violet-600 hover:bg-violet-500 text-white rounded-xl font-medium transition-colors">
              Créer le QR Code
            </button>
            <button type="button" id="btnResetForm"
              class="px-4 py-3 bg-slate-800 border border-slate-700 text-white rounded-xl font-medium hover:bg-slate-700 transition-colors">
              Réinitialiser
            </button>
          </div>
        </form>
      </div>
    </section>
  </main>
</div>

<script src="https://unpkg.com/qrcode@1.5.4/build/qrcode.min.js"></script>
<script>
(() => {
  const params = new URLSearchParams(window.location.search);
  const plinkkId = params.get('plinkkId');
  const qrIdToEdit = params.get('qrId');
  let currentQrCodes = [];
  let currentEditingQr = null;

  const fieldName = document.getElementById('qrCodeName');
  const fieldTargetType = document.getElementById('qrCodeTargetType');
  const fieldCustomUrl = document.getElementById('qrCodeCustomUrl');
  const fieldForeground = document.getElementById('qrCodeForegroundColor');
  const fieldBackground = document.getElementById('qrCodeBackgroundColor');
  const fieldRounded = document.getElementById('qrCodeRounded');
  const fieldMargin = document.getElementById('qrCodeMargin');

  const customUrlGroup = document.getElementById('customUrlGroup');
  const marginValue = document.getElementById('qrCodeMarginValue');
  const foregroundValue = document.getElementById('qrCodeForegroundColorValue');
  const backgroundValue = document.getElementById('qrCodeBackgroundColorValue');
  const previewEl = document.getElementById('qrCodePreview');
  const listEl = document.getElementById('qrCodesList');
  const formEl = document.getElementById('qrCodeForm');
  const submitBtn = document.getElementById('qrCodeSubmitBtn');
  const qrCodeIdEl = document.getElementById('qrCodeId');

  function escapeHtml(value) {
    return String(value || '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function getPreviewText() {
    if (currentEditingQr?.shortCode) {
      return `${window.location.origin}/q/${currentEditingQr.shortCode}`;
    }
    if (fieldTargetType.value === 'CUSTOM_URL' && fieldCustomUrl.value.trim()) {
      return fieldCustomUrl.value.trim();
    }
    return `${window.location.origin}/q/preview`;
  }

  async function renderPreview() {
    const text = getPreviewText();
    const margin = parseInt(fieldMargin.value || '2', 10);
    const options = {
      type: 'svg',
      errorCorrectionLevel: 'M',
      margin,
      width: 260,
      color: {
        dark: fieldForeground.value,
        light: fieldBackground.value,
      },
    };

    try {
      const svg = await QRCode.toString(text, options);
      previewEl.innerHTML = svg;
      const svgNode = previewEl.querySelector('svg');
      if (svgNode) {
        svgNode.classList.add('w-full', 'h-full', 'max-w-[260px]');
        if (fieldRounded.checked) {
          svgNode.style.borderRadius = '16px';
        } else {
          svgNode.style.borderRadius = '0';
        }
      }
    } catch {
      previewEl.innerHTML = '<p class="text-sm text-rose-400">Impossible de générer la prévisualisation.</p>';
    }
  }

  function syncFormIndicators() {
    marginValue.textContent = fieldMargin.value;
    foregroundValue.textContent = fieldForeground.value;
    backgroundValue.textContent = fieldBackground.value;
    customUrlGroup.classList.toggle('hidden', fieldTargetType.value !== 'CUSTOM_URL');
  }

  function resetForm() {
    currentEditingQr = null;
    qrCodeIdEl.value = '';
    fieldName.value = '';
    fieldTargetType.value = 'PLINKK_PAGE';
    fieldCustomUrl.value = '';
    fieldForeground.value = '#111827';
    fieldBackground.value = '#ffffff';
    fieldRounded.checked = false;
    fieldMargin.value = '2';
    submitBtn.textContent = 'Créer le QR Code';
    syncFormIndicators();
    renderPreview();
  }

  function fillFormForEdit(item) {
    currentEditingQr = item;
    qrCodeIdEl.value = item.id;
    fieldName.value = item.name || '';
    fieldTargetType.value = item.targetType || 'PLINKK_PAGE';
    fieldCustomUrl.value = item.targetType === 'CUSTOM_URL' ? (item.targetUrl || '') : '';
    fieldForeground.value = item.foregroundHex || '#111827';
    fieldBackground.value = item.backgroundHex || '#ffffff';
    fieldRounded.checked = Boolean(item.rounded);
    fieldMargin.value = String(item.margin ?? 2);
    submitBtn.textContent = 'Enregistrer les modifications';
    syncFormIndicators();
    renderPreview();
  }

  function renderList() {
    if (!currentQrCodes.length) {
      listEl.innerHTML = `
        <div class="text-center py-8 text-slate-400 bg-slate-800/40 rounded-xl border border-slate-800">
          Aucun QR code pour ce Plinkk.
        </div>
      `;
      return;
    }

    listEl.innerHTML = currentQrCodes.map((item) => `
      <button type="button" data-id="${item.id}"
        class="w-full text-left bg-slate-800 border border-slate-700 rounded-xl p-3 hover:border-violet-500/40 transition-colors">
        <p class="text-sm font-semibold text-white truncate">${escapeHtml(item.name || 'Sans nom')}</p>
        <p class="text-xs text-slate-400 mt-1">${escapeHtml(item.targetType)}</p>
        <p class="text-xs text-slate-500 mt-1 truncate">${escapeHtml(item.shareUrl || '')}</p>
      </button>
    `).join('');

    listEl.querySelectorAll('button[data-id]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const found = currentQrCodes.find((entry) => entry.id === btn.dataset.id);
        if (found) fillFormForEdit(found);
      });
    });
  }

  async function loadQRCodes() {
    if (!plinkkId) return;
    const response = await fetch(`/api/me/plinkks/${plinkkId}/qrcodes`);
    if (!response.ok) throw new Error('Erreur de chargement des QR codes');
    const data = await response.json();
    currentQrCodes = data.items || [];
    renderList();

    if (qrIdToEdit) {
      const selected = currentQrCodes.find((entry) => entry.id === qrIdToEdit);
      if (selected) {
        fillFormForEdit(selected);
        return;
      }
    }

    if (currentQrCodes[0]) {
      fillFormForEdit(currentQrCodes[0]);
    } else {
      resetForm();
    }
  }

  async function onSubmit(event) {
    event.preventDefault();
    if (!plinkkId) return;

    const qrId = qrCodeIdEl.value;
    const method = qrId ? 'PATCH' : 'POST';
    const url = qrId
      ? `/api/me/plinkks/${plinkkId}/qrcodes/${qrId}`
      : `/api/me/plinkks/${plinkkId}/qrcodes`;

    const payload = {
      name: fieldName.value,
      targetType: fieldTargetType.value,
      customUrl: fieldTargetType.value === 'CUSTOM_URL' ? fieldCustomUrl.value : undefined,
      foregroundHex: fieldForeground.value,
      backgroundHex: fieldBackground.value,
      eyeHex: fieldForeground.value,
      rounded: fieldRounded.checked,
      margin: parseInt(fieldMargin.value || '2', 10),
    };

    const response = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (!response.ok) {
      const data = await response.json().catch(() => ({}));
      throw new Error(data.error || 'Erreur lors de la sauvegarde');
    }

    await loadQRCodes();
  }

  document.getElementById('btnNewQr').addEventListener('click', resetForm);
  document.getElementById('btnResetForm').addEventListener('click', resetForm);
  formEl.addEventListener('submit', async (event) => {
    try {
      await onSubmit(event);
    } catch (error) {
      alert(`Erreur: ${error.message}`);
    }
  });

  [fieldTargetType, fieldCustomUrl, fieldForeground, fieldBackground, fieldRounded, fieldMargin].forEach((el) => {
    el.addEventListener('input', () => {
      syncFormIndicators();
      renderPreview();
    });
    el.addEventListener('change', () => {
      syncFormIndicators();
      renderPreview();
    });
  });

  syncFormIndicators();
  renderPreview();
  loadQRCodes().catch((error) => {
    listEl.innerHTML = `<div class="text-sm text-rose-400">${escapeHtml(error.message)}</div>`;
  });
})();
</script>
