{
  "name": "@plinkk/prisma",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bunx tsc && bun copy-generated.js",
    "generate": "bunx prisma generate --config=prisma.config.ts --schema=prisma/schema.prisma",
    "migrate:dev": "bunx prisma migrate dev --config=prisma.config.ts --schema=prisma/schema.prisma",
    "migrate": "bunx prisma migrate --config=prisma.config.ts --schema=prisma/schema.prisma",
    "deploy": "bunx prisma migrate deploy --config=prisma.config.ts --schema=prisma/schema.prisma",
    "dev": "bunx prisma dev --config=prisma.config.ts --schema=prisma/schema.prisma",
    "studio": "bunx prisma studio --config=prisma.config.ts --schema=prisma/schema.prisma",
    "seed": "bun prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@prisma/client-runtime-utils": "^7.3.0",
    "@types/pg": "8.18.0",
    "dotenv": "^17.2.3",
    "pg": "^8.18.0",
    "pg-connection-string": "^2.7.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@prisma/config": "^7.3.0",
    "@types/node": "^20.11.0",
    "prisma": "^7.3.0",
    "typescript": "^5.3.3"
  }
}