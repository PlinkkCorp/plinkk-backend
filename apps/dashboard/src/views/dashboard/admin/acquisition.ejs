<%- include('partials/head.ejs', { title: 'Acquisition - Administration', description: 'Suivi du funnel inscription et quota emails.', robots: 'noindex,nofollow' }) %>
<%- include('partials/header-dash.ejs', { user: user }) %>

<div class="max-w-[1600px] mx-auto grid grid-cols-12 gap-6 px-4 py-8">
  <%- include('partials/admin-nav.ejs', { user: user, active: 'acquisition' }) %>

  <main class="col-span-12 lg:col-span-10 space-y-8 relative">

    <!-- Hero header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-gradient-to-r from-violet-900 to-slate-900 p-8 rounded-3xl border border-slate-800 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-violet-600/20 rounded-full blur-3xl -mr-16 -mt-16 pointer-events-none"></div>
      <div class="relative z-10">
        <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">Acquisition</h1>
        <p class="text-slate-300 text-lg">Funnel d'inscription, quota emails et conversions.</p>
      </div>
      <div class="relative z-10 flex items-center gap-3">
        <!-- Toggle inscriptions -->
        <div class="bg-slate-900/60 border border-slate-700 rounded-2xl px-4 py-3 flex items-center gap-3">
          <div>
            <p class="text-sm font-medium text-white">Inscriptions email</p>
            <p class="text-xs text-slate-400" id="regStatusLabel">Chargement…</p>
          </div>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" id="regToggle" class="sr-only peer" onchange="toggleRegistration(this.checked)">
            <div class="w-11 h-6 bg-slate-800 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-violet-600"></div>
          </label>
        </div>
      </div>
    </div>

    <!-- Quota email -->
    <section class="bg-slate-900 border border-slate-800 rounded-3xl p-6">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-lg font-bold text-white flex items-center gap-2">
          <svg class="w-5 h-5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Quota Email mensuel
        </h2>
        <span id="quotaMonth" class="text-sm text-slate-500"></span>
      </div>

      <!-- Jauge principale -->
      <div class="mb-4">
        <div class="flex justify-between items-end mb-2">
          <span id="quotaTotal" class="text-3xl font-bold text-white">—</span>
          <span class="text-slate-500 text-sm">/ 3 000 emails</span>
        </div>
        <div class="w-full h-4 bg-slate-800 rounded-full overflow-hidden">
          <div id="quotaBar" class="h-full rounded-full transition-all duration-700" style="width:0%;background:#8b5cf6"></div>
        </div>
        <div class="flex justify-between mt-2 text-xs text-slate-500">
          <span>0</span>
          <span id="quotaAlert70" class="flex items-center gap-1">⚠ 70% (2 100)</span>
          <span id="quotaAlert90" class="flex items-center gap-1">🔴 90% (2 700)</span>
          <span>3 000</span>
        </div>
      </div>

      <!-- Alerte -->
      <div id="quotaAlertBanner" class="hidden rounded-xl px-4 py-3 mb-4 text-sm font-medium flex items-center gap-2"></div>

      <!-- Détail par type -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="bg-slate-800 rounded-xl p-3">
          <p class="text-xs text-slate-500 mb-1">OTP / Inscription</p>
          <p id="q-otp" class="text-lg font-bold text-white">—</p>
        </div>
        <div class="bg-slate-800 rounded-xl p-3">
          <p class="text-xs text-slate-500 mb-1">Campagnes</p>
          <p id="q-campaign" class="text-lg font-bold text-white">—</p>
        </div>
        <div class="bg-slate-800 rounded-xl p-3">
          <p class="text-xs text-slate-500 mb-1">Bienvenue</p>
          <p id="q-welcome" class="text-lg font-bold text-white">—</p>
        </div>
        <div class="bg-slate-800 rounded-xl p-3">
          <p class="text-xs text-slate-500 mb-1">Autres</p>
          <p id="q-other" class="text-lg font-bold text-white">—</p>
        </div>
      </div>

      <!-- Historique 6 mois -->
      <div class="mt-6">
        <p class="text-sm font-medium text-slate-400 mb-3">Historique 6 mois</p>
        <div id="historyBars" class="flex items-end gap-2 h-20"></div>
        <div id="historyLabels" class="flex gap-2 mt-1"></div>
      </div>
    </section>

    <!-- Funnel de conversion -->
    <section class="bg-slate-900 border border-slate-800 rounded-3xl p-6">
      <div class="flex flex-wrap items-center justify-between gap-4 mb-5">
        <h2 class="text-lg font-bold text-white flex items-center gap-2">
          <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          Funnel de conversion
        </h2>
        <div class="flex items-center gap-2">
          <input type="date" id="funnelFrom" class="bg-slate-800 border border-slate-700 text-white text-sm rounded-lg px-3 py-1.5 focus:border-violet-500 focus:outline-none" />
          <span class="text-slate-500 text-sm">→</span>
          <input type="date" id="funnelTo" class="bg-slate-800 border border-slate-700 text-white text-sm rounded-lg px-3 py-1.5 focus:border-violet-500 focus:outline-none" />
          <button onclick="loadFunnel()" class="bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg px-4 py-1.5 transition-colors">Filtrer</button>
        </div>
      </div>

      <div id="funnelGrid" class="space-y-2">
        <!-- Rempli dynamiquement -->
      </div>

      <div class="mt-5 grid grid-cols-3 gap-3" id="funnelRates">
        <!-- Rempli dynamiquement -->
      </div>
    </section>

  </main>
</div>

<script>
  // ─── Init dates ──────────────────────────────────────────────────────────────
  (function () {
    const now = new Date();
    const to = now.toISOString().split('T')[0];
    const from = new Date(now - 29 * 86400_000).toISOString().split('T')[0];
    document.getElementById('funnelFrom').value = from;
    document.getElementById('funnelTo').value = to;
  })();

  // ─── Load quota ──────────────────────────────────────────────────────────────
  async function loadQuota() {
    try {
      const res = await fetch('/api/admin/acquisition/quota');
      const { current, history } = await res.json();

      // Month label
      const [y, m] = current.month.split('-');
      const months = ['Jan','Fév','Mars','Avr','Mai','Juin','Juil','Août','Sep','Oct','Nov','Déc'];
      document.getElementById('quotaMonth').textContent = `${months[parseInt(m)-1]} ${y}`;

      // Total + bar
      document.getElementById('quotaTotal').textContent = current.total.toLocaleString('fr-FR');
      const pct = Math.min(100, current.percentUsed);
      const bar = document.getElementById('quotaBar');
      bar.style.width = pct + '%';
      bar.style.background = current.alert === 'critical' ? '#ef4444' : current.alert === 'warning' ? '#f59e0b' : '#8b5cf6';
      setTimeout(() => bar.style.width = pct + '%', 50);

      // Détail
      document.getElementById('q-otp').textContent = current.otp.toLocaleString('fr-FR');
      document.getElementById('q-campaign').textContent = current.campaign.toLocaleString('fr-FR');
      document.getElementById('q-welcome').textContent = current.welcome.toLocaleString('fr-FR');
      document.getElementById('q-other').textContent = current.other.toLocaleString('fr-FR');

      // Seuils
      document.getElementById('quotaAlert70').style.color = current.total >= 2100 ? '#f59e0b' : '#64748b';
      document.getElementById('quotaAlert90').style.color = current.total >= 2700 ? '#ef4444' : '#64748b';

      // Bannière alerte
      const banner = document.getElementById('quotaAlertBanner');
      if (current.alert === 'critical') {
        banner.className = 'rounded-xl px-4 py-3 mb-4 text-sm font-medium flex items-center gap-2 bg-red-500/10 border border-red-500/30 text-red-400';
        banner.innerHTML = '🔴 <span><strong>Alerte critique :</strong> Tu approches de la limite mensuelle (90%). Les nouvelles inscriptions pourraient échouer.</span>';
        banner.classList.remove('hidden');
      } else if (current.alert === 'warning') {
        banner.className = 'rounded-xl px-4 py-3 mb-4 text-sm font-medium flex items-center gap-2 bg-amber-500/10 border border-amber-500/30 text-amber-400';
        banner.innerHTML = '⚠️ <span><strong>Attention :</strong> Tu as consommé 70% du quota email du mois.</span>';
        banner.classList.remove('hidden');
      } else {
        banner.classList.add('hidden');
      }

      // Historique bars
      const histContainer = document.getElementById('historyBars');
      const histLabels = document.getElementById('historyLabels');
      const maxTotal = Math.max(...history.map(h => h.total), 1);
      histContainer.innerHTML = '';
      histLabels.innerHTML = '';
      history.forEach(h => {
        const pct2 = (h.total / maxTotal) * 100;
        const [hy, hm] = h.month.split('-');
        const monthNames = ['Jan','Fév','Mars','Avr','Mai','Juin','Juil','Août','Sep','Oct','Nov','Déc'];
        const label = monthNames[parseInt(hm)-1];
        const color = h.alert === 'critical' ? '#ef4444' : h.alert === 'warning' ? '#f59e0b' : '#8b5cf6';
        const isCurrent = h.month === current.month;

        const bar = document.createElement('div');
        bar.className = 'flex-1 rounded-t-md transition-all duration-500 cursor-pointer relative group';
        bar.style.cssText = `height:${Math.max(4, pct2)}%;background:${isCurrent ? color : color + '66'};min-height:4px`;
        bar.title = `${h.total} emails`;

        const tooltip = document.createElement('div');
        tooltip.className = 'absolute -top-8 left-1/2 -translate-x-1/2 bg-slate-700 text-white text-xs rounded px-2 py-1 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none';
        tooltip.textContent = h.total.toLocaleString('fr-FR');
        bar.appendChild(tooltip);
        histContainer.appendChild(bar);

        const lbl = document.createElement('div');
        lbl.className = `flex-1 text-center text-xs ${isCurrent ? 'text-white font-semibold' : 'text-slate-600'}`;
        lbl.textContent = label;
        histLabels.appendChild(lbl);
      });

    } catch (e) { console.error('quota load error', e); }
  }

  // ─── Load funnel ─────────────────────────────────────────────────────────────
  async function loadFunnel() {
    const from = document.getElementById('funnelFrom').value;
    const to = document.getElementById('funnelTo').value;
    try {
      const res = await fetch(`/api/admin/acquisition/funnel?from=${from}&to=${to}`);
      const data = await res.json();

      const steps = [
        { label: 'Email soumis', value: data.emailSubmits, icon: '📧' },
        { label: 'Email vérifié', value: data.emailVerified, icon: '✅' },
        { label: 'Étape onboarding 1', value: data.step1, icon: '📝' },
        { label: 'Étape onboarding 2', value: data.step2, icon: '🎨' },
        { label: 'Plinkk créé', value: data.plinkkCreated, icon: '🚀' },
      ];

      const max = Math.max(data.emailSubmits, 1);
      const grid = document.getElementById('funnelGrid');
      grid.innerHTML = steps.map((s, i) => {
        const pct = Math.round((s.value / max) * 100);
        const drop = i > 0 ? Math.round((1 - s.value / Math.max(steps[i-1].value, 1)) * 100) : 0;
        return `
          <div class="flex items-center gap-3">
            <span class="w-6 text-base text-center shrink-0">${s.icon}</span>
            <div class="flex-1">
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm font-medium text-white">${s.label}</span>
                <div class="flex items-center gap-3">
                  ${i > 0 ? `<span class="text-xs text-rose-400">-${drop}%</span>` : ''}
                  <span class="text-sm font-semibold text-white w-16 text-right">${s.value.toLocaleString('fr-FR')}</span>
                  <span class="text-xs text-slate-500 w-10 text-right">${pct}%</span>
                </div>
              </div>
              <div class="w-full h-2 bg-slate-800 rounded-full overflow-hidden">
                <div class="h-full rounded-full bg-violet-500 transition-all duration-700" style="width:${pct}%"></div>
              </div>
            </div>
          </div>
        `;
      }).join('');

      // Taux clés
      const ratesEl = document.getElementById('funnelRates');
      ratesEl.innerHTML = [
        { label: 'Taux vérification', value: data.rates.verifyRate + '%', color: 'text-blue-400' },
        { label: 'Taux completion', value: data.rates.completionRate + '%', color: 'text-emerald-400' },
        { label: 'Taux global', value: data.rates.overallRate + '%', color: 'text-violet-400' },
      ].map(r => `
        <div class="bg-slate-800 rounded-xl p-4 text-center">
          <p class="text-2xl font-bold ${r.color} mb-1">${r.value}</p>
          <p class="text-xs text-slate-500">${r.label}</p>
        </div>
      `).join('');

    } catch (e) { console.error('funnel load error', e); }
  }

  // ─── Toggle registrations ─────────────────────────────────────────────────
  async function loadSettings() {
    try {
      const res = await fetch('/api/admin/acquisition/settings');
      const data = await res.json();
      const toggle = document.getElementById('regToggle');
      const label = document.getElementById('regStatusLabel');
      toggle.checked = data.emailRegistrationEnabled;
      label.textContent = data.emailRegistrationEnabled ? 'Activées' : 'Désactivées';
    } catch {}
  }

  async function toggleRegistration(enabled) {
    const label = document.getElementById('regStatusLabel');
    label.textContent = 'Mise à jour…';
    try {
      const res = await fetch('/api/admin/acquisition/settings', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ emailRegistrationEnabled: enabled }),
      });
      const data = await res.json();
      label.textContent = data.emailRegistrationEnabled ? 'Activées' : 'Désactivées';
    } catch {
      label.textContent = 'Erreur';
    }
  }

  // ─── Init ─────────────────────────────────────────────────────────────────
  loadQuota();
  loadFunnel();
  loadSettings();
</script>

<%- include('partials/footer.ejs') %>
