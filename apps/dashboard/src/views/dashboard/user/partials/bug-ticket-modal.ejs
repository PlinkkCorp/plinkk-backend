<!-- Bug Ticket Modal -->
<div id="bugTicketModal" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4">
  <div class="bg-slate-900 border border-slate-800 rounded-2xl max-w-2xl w-full max-h-[80vh] overflow-y-auto">
    <div class="sticky top-0 bg-slate-900 border-b border-slate-800 px-6 py-4 flex items-center justify-between">
      <h2 class="text-xl font-bold text-white" id="bugTicketTitle">Ticket #</h2>
      <button type="button" class="text-slate-400 hover:text-white" onclick="document.getElementById('bugTicketModal').classList.add('hidden')">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>

    <div class="p-6 space-y-4">
      <div id="bugTicketContent" class="prose prose-invert max-w-none">
        <!-- Contenu du ticket inséré ici -->
      </div>

      <div id="bugTicketReplies" class="space-y-4 mt-6 border-t border-slate-800 pt-6">
        <!-- Les réponses seront injectées ici -->
      </div>

      <div class="border-t border-slate-800 pt-6 mt-6">
        <h3 class="text-sm font-semibold text-slate-300 mb-3">Ajouter une réaction</h3>
        <div class="space-y-2">
          <input type="text" id="bugReactionInput" placeholder="😀 Emoji ou commentaire" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-sm text-white placeholder-slate-400 focus:outline-none focus:border-violet-500" />
          <button type="button" id="bugSubmitReactionBtn" class="w-full px-4 py-2 bg-violet-600 hover:bg-violet-700 text-white text-sm font-semibold rounded-lg transition-colors">
            Envoyer
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  window.showBugTicket = function(itemId, itemTitle, itemText) {
    const modal = document.getElementById('bugTicketModal');
    document.getElementById('bugTicketTitle').textContent = itemTitle;
    
    // Utiliser textContent pour éviter les injections HTML
    const contentDiv = document.getElementById('bugTicketContent');
    contentDiv.innerHTML = '';
    const p = document.createElement('p');
    p.textContent = itemText;
    contentDiv.appendChild(p);
    
    modal.classList.remove('hidden');

    // Marquer comme lu
    fetch(`/api/me/inbox/${itemId}/read`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ itemType: 'announcement' })
    });
  };

  document.getElementById('bugSubmitReactionBtn')?.addEventListener('click', async function() {
    const input = document.getElementById('bugReactionInput');
    const value = input.value.trim();
    if (!value) return;

    const reply = document.createElement('div');
    reply.className = 'bg-slate-800 border border-slate-700 rounded-lg p-4 text-sm text-slate-200';
    reply.innerHTML = `<strong>Vous:</strong> ${value}`;

    document.getElementById('bugTicketReplies').appendChild(reply);
    input.value = '';
    input.focus();

    // TODO: Envoyer au serveur (créer un modèle de réponse ou utiliser les logs)
  });
</script>
