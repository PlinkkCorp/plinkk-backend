<%- include('partials/head.ejs', {
  title: 'Édition QR Code',
  description: 'Créez et modifiez vos codes QR pour votre Plinkk.',
  robots: 'noindex,nofollow'
}) %>
<%- include('partials/header-dash.ejs') %>

<div class="max-w-[1600px] mx-auto grid grid-cols-12 gap-6 px-4 py-4 min-h-[calc(100vh-72px)]">
  <%- include('partials/asside_dash.ejs', { active: 'qrcodes' }) %>

  <main class="col-span-12 lg:col-span-10 space-y-4 h-full flex flex-col">
    <section class="bg-slate-900 border border-slate-800 rounded-3xl p-6">
      <h1 class="text-2xl font-bold text-white">Édition QR Code</h1>
      <p class="text-sm text-slate-400 mt-1">
        <span class="font-medium text-slate-300">Plinkk :</span>
        <%= plinkk.name %> (<span class="text-violet-400"><%= plinkk.slug %></span>)
      </p>
    </section>

    <section class="grid grid-cols-1 xl:grid-cols-12 gap-6 items-start flex-1 xl:min-h-0">
      <div class="xl:col-span-4 bg-slate-900 border border-slate-800 rounded-3xl p-5 xl:h-full xl:flex xl:flex-col">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-white">Mes QR codes</h2>
          <button id="btnNewQr"
            class="px-3 py-2 text-sm font-medium rounded-xl bg-violet-600 hover:bg-violet-500 text-white transition-colors">
            Nouveau
          </button>
        </div>
        <div id="qrCodesList" class="space-y-3 xl:overflow-y-auto xl:pr-1"></div>
      </div>

      <div class="xl:col-span-5 bg-slate-900 border border-slate-800 rounded-3xl p-6 xl:h-full xl:overflow-y-auto">
        <form id="qrCodeForm" class="space-y-5">
          <input type="hidden" id="qrCodeId" value="">

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="md:col-span-2">
              <label for="qrCodeName" class="block text-sm font-medium text-white mb-2">Nom du QR Code</label>
              <input type="text" id="qrCodeName" placeholder="Ex: Promotion Été 2026"
                class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-violet-500 transition-colors">
            </div>

            <div>
              <label for="qrCodeTargetType" class="block text-sm font-medium text-white mb-2">Cible</label>
              <select id="qrCodeTargetType"
                class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white focus:outline-none focus:border-violet-500 transition-colors">
                <option value="PLINKK_PAGE">Ma page Plinkk</option>
                <option value="PROFILE">Mon profil</option>
                <option value="CUSTOM_URL">URL personnalisée</option>
              </select>
            </div>

            <div>
              <label for="qrCodeMargin" class="block text-sm font-medium text-white mb-2">Marge</label>
              <div class="flex items-center gap-3">
                <input type="range" id="qrCodeMargin" min="0" max="8" value="2"
                  class="flex-1 h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-violet-600">
                <span id="qrCodeMarginValue" class="text-xs text-slate-400 w-6">2</span>
              </div>
            </div>

            <div id="customUrlGroup" class="md:col-span-2 hidden">
              <label for="qrCodeCustomUrl" class="block text-sm font-medium text-white mb-2">URL personnalisée</label>
              <input type="url" id="qrCodeCustomUrl" placeholder="https://example.com"
                class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-violet-500 transition-colors">
            </div>

            <div>
              <label for="qrCodeForegroundColor" class="block text-sm font-medium text-white mb-2">Couleur modules</label>
              <div class="flex items-center gap-3">
                <input type="color" id="qrCodeForegroundColor" value="#111827" class="w-10 h-10 rounded-lg border border-slate-700">
                <span id="qrCodeForegroundColorValue" class="text-xs text-slate-400 font-mono">#111827</span>
              </div>
            </div>

            <div>
              <label for="qrCodeEyeColor" class="block text-sm font-medium text-white mb-2">Couleur des yeux</label>
              <div class="flex items-center gap-3">
                <input type="color" id="qrCodeEyeColor" value="#111827" class="w-10 h-10 rounded-lg border border-slate-700">
                <span id="qrCodeEyeColorValue" class="text-xs text-slate-400 font-mono">#111827</span>
              </div>
            </div>

            <div>
              <label for="qrCodeBackgroundColor" class="block text-sm font-medium text-white mb-2">Couleur fond</label>
              <div class="flex items-center gap-3">
                <input type="color" id="qrCodeBackgroundColor" value="#ffffff" class="w-10 h-10 rounded-lg border border-slate-700">
                <span id="qrCodeBackgroundColorValue" class="text-xs text-slate-400 font-mono">#ffffff</span>
              </div>
            </div>

            <div>
              <label for="qrCodeErrorCorrection" class="block text-sm font-medium text-white mb-2">Niveau de correction</label>
              <select id="qrCodeErrorCorrection"
                class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white focus:outline-none focus:border-violet-500 transition-colors text-sm">
                <option value="L">L - 7% (Low)</option>
                <option value="M" selected>M - 15% (Medium)</option>
                <option value="Q">Q - 25% (Quartile)</option>
                <option value="H">H - 30% (High)</option>
              </select>
            </div>

            <div>
              <label for="qrCodePreset" class="block text-sm font-medium text-white mb-2">Preset couleur</label>
              <select id="qrCodePreset"
                class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white focus:outline-none focus:border-violet-500 transition-colors text-sm">
                <option value="custom">Personnalisé</option>
                <option value="plinkk">Plinkk</option>
                <option value="midnight">Midnight</option>
                <option value="forest">Forest</option>
                <option value="sunset">Sunset</option>
                <option value="mono">Noir & Blanc</option>
              </select>
            </div>

            <div class="md:col-span-2 border border-slate-800 rounded-xl p-4 space-y-4">
              <label class="inline-flex items-center gap-2 text-sm text-white cursor-pointer">
                <input type="checkbox" id="qrCodeIncludeImage" class="accent-violet-600">
                Ajouter un logo/image au centre
              </label>

              <div id="qrCodeImageFields" class="hidden space-y-4">
                <input type="hidden" id="qrCodeImageUrl" value="">
                <input type="file" id="qrCodeImageFileInput" accept="image/*,.svg" class="hidden">
                <div>
                  <p class="block text-sm font-medium text-white mb-2">Image/logo</p>
                  <div class="flex flex-wrap gap-2">
                    <button type="button" id="btnUploadQrLogo" class="px-3 py-2 text-sm rounded-lg bg-slate-800 border border-slate-700 text-white hover:bg-slate-700 transition-colors">Upload image</button>
                    <button type="button" id="btnLibraryQrLogo" class="px-3 py-2 text-sm rounded-lg bg-slate-800 border border-slate-700 text-white hover:bg-slate-700 transition-colors">Bibliothèque</button>
                    <button type="button" id="btnClearQrLogo" class="px-3 py-2 text-sm rounded-lg bg-slate-900 border border-slate-700 text-slate-300 hover:text-white transition-colors">Supprimer</button>
                  </div>
                  <p id="qrCodeImageSource" class="text-xs text-slate-400 mt-2 break-all">Aucune image sélectionnée</p>
                </div>
                <div id="qrCodeLogoColorGroup" class="hidden">
                  <label for="qrCodeLogoColor" class="block text-sm font-medium text-white mb-2">Couleur logo SVG</label>
                  <div class="flex items-center gap-3">
                    <input type="color" id="qrCodeLogoColor" value="#7c3aed" class="w-10 h-10 rounded-lg border border-slate-700">
                    <span id="qrCodeLogoColorValue" class="text-xs text-slate-400 font-mono">#7c3aed</span>
                  </div>
                </div>
                <div>
                  <label for="qrCodeImageSize" class="block text-sm font-medium text-white mb-2">Taille logo</label>
                  <div class="flex items-center gap-3">
                    <input type="range" id="qrCodeImageSize" min="10" max="40" value="25"
                      class="flex-1 h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-violet-600">
                    <span id="qrCodeImageSizeValue" class="text-xs text-slate-400 w-10">25%</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="md:col-span-2">
              <label class="inline-flex items-center gap-2 text-sm text-white cursor-pointer">
                <input type="checkbox" id="qrCodeRounded" class="accent-violet-600">
                Modules arrondis
              </label>
            </div>
          </div>

          <div class="flex gap-3 pt-2">
            <button type="submit" id="qrCodeSubmitBtn"
              class="px-4 py-3 bg-violet-600 hover:bg-violet-500 text-white rounded-xl font-medium transition-colors">
              Créer le QR Code
            </button>
            <button type="button" id="btnResetForm"
              class="px-4 py-3 bg-slate-800 border border-slate-700 text-white rounded-xl font-medium hover:bg-slate-700 transition-colors">
              Réinitialiser
            </button>
          </div>
          <p id="qrSaveStatus" class="text-xs text-slate-400">Autosave activé pour les modifications.</p>
        </form>
      </div>

      <div class="xl:col-span-3 xl:sticky xl:top-20 xl:max-h-[calc(100vh-96px)] xl:overflow-y-auto space-y-4">
        <div class="bg-slate-900 border border-slate-800 rounded-3xl p-5">
          <p class="text-sm font-semibold text-white mb-3">Prévisualisation en direct</p>
          <div class="bg-slate-800 rounded-xl p-4 flex items-center justify-center min-h-[280px]">
            <div id="qrCodePreview" class="w-full max-w-[280px] flex items-center justify-center"></div>
          </div>
          <div class="mt-4 pt-4 border-t border-slate-800">
            <p class="text-xs text-slate-400 mb-1">Lien du QR code</p>
            <a id="qrCodePreviewLink" href="#" target="_blank" rel="noopener noreferrer" class="text-xs text-violet-400 hover:text-violet-300 break-all">-</a>
          </div>
          <div class="mt-4 pt-4 border-t border-slate-800">
            <button type="button" id="btnDownloadQrCode"
              class="w-full px-4 py-2 bg-slate-800 hover:bg-slate-700 text-white rounded-xl text-sm font-medium transition-colors flex items-center justify-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Télécharger en SVG
            </button>
          </div>
        </div>
        <div class="bg-slate-900 border border-slate-800 rounded-3xl p-5">
          <p class="text-sm font-semibold text-white mb-2">Conseil</p>
          <p class="text-xs text-slate-400">Utilisez un contraste fort (foncé sur clair) pour améliorer la lecture du QR code.</p>
        </div>
      </div>
    </section>
  </main>
</div>

<div id="qrLibraryModal" class="hidden fixed inset-0 z-[120] bg-black/70 p-4">
  <div class="max-w-3xl mx-auto bg-slate-900 border border-slate-700 rounded-2xl overflow-hidden">
    <div class="px-4 py-3 border-b border-slate-800 flex items-center justify-between">
      <p class="text-sm font-semibold text-white">Bibliothèque d'images</p>
      <button type="button" id="btnCloseQrLibrary" class="text-slate-300 hover:text-white text-sm">Fermer</button>
    </div>
    <div id="qrLibraryGrid" class="p-4 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 max-h-[60vh] overflow-auto"></div>
  </div>
</div>

<script>
window.addEventListener('load', () => {
  const params = new URLSearchParams(window.location.search);
  const plinkkId = params.get('plinkkId');
  const qrIdToEdit = params.get('qrId');
  let currentQrCodes = [];
  let currentEditingQr = null;
  let previewController = null;
  let autoSaveTimer = null;
  let isAutoSaving = false;
  let suspendAutoSave = false;

  const fieldName = document.getElementById('qrCodeName');
  const fieldTargetType = document.getElementById('qrCodeTargetType');
  const fieldCustomUrl = document.getElementById('qrCodeCustomUrl');
  const fieldForeground = document.getElementById('qrCodeForegroundColor');
  const fieldEye = document.getElementById('qrCodeEyeColor');
  const fieldBackground = document.getElementById('qrCodeBackgroundColor');
  const fieldRounded = document.getElementById('qrCodeRounded');
  const fieldMargin = document.getElementById('qrCodeMargin');
  const fieldErrorCorrection = document.getElementById('qrCodeErrorCorrection');
  const fieldPreset = document.getElementById('qrCodePreset');
  const fieldIncludeImage = document.getElementById('qrCodeIncludeImage');
  const fieldImageUrl = document.getElementById('qrCodeImageUrl');
  const fieldImageSize = document.getElementById('qrCodeImageSize');
  const fieldLogoColor = document.getElementById('qrCodeLogoColor');

  const customUrlGroup = document.getElementById('customUrlGroup');
  const imageFieldsGroup = document.getElementById('qrCodeImageFields');
  const logoColorGroup = document.getElementById('qrCodeLogoColorGroup');
  const marginValue = document.getElementById('qrCodeMarginValue');
  const imageSizeValue = document.getElementById('qrCodeImageSizeValue');
  const logoColorValue = document.getElementById('qrCodeLogoColorValue');
  const foregroundValue = document.getElementById('qrCodeForegroundColorValue');
  const eyeValue = document.getElementById('qrCodeEyeColorValue');
  const backgroundValue = document.getElementById('qrCodeBackgroundColorValue');
  const imageSourceValue = document.getElementById('qrCodeImageSource');
  const previewEl = document.getElementById('qrCodePreview');
  const previewLinkEl = document.getElementById('qrCodePreviewLink');
  const listEl = document.getElementById('qrCodesList');
  const formEl = document.getElementById('qrCodeForm');
  const submitBtn = document.getElementById('qrCodeSubmitBtn');
  const saveStatusEl = document.getElementById('qrSaveStatus');
  const qrCodeIdEl = document.getElementById('qrCodeId');
  const downloadBtn = document.getElementById('btnDownloadQrCode');
  const uploadLogoBtn = document.getElementById('btnUploadQrLogo');
  const libraryLogoBtn = document.getElementById('btnLibraryQrLogo');
  const clearLogoBtn = document.getElementById('btnClearQrLogo');
  const imageFileInput = document.getElementById('qrCodeImageFileInput');
  const qrLibraryModal = document.getElementById('qrLibraryModal');
  const qrLibraryGrid = document.getElementById('qrLibraryGrid');
  const closeQrLibraryBtn = document.getElementById('btnCloseQrLibrary');
  const PLINKK_LOGO_URL = 'https://cdn.plinkk.fr/logo.svg';

  function isSvgUrl(url) {
    if (!url) return false;
    return /^data:image\/svg\+xml/i.test(url) || /\.svg([?#].*)?$/i.test(url);
  }

  function updateImageSourceLabel() {
    if (!fieldImageUrl.value) {
      imageSourceValue.textContent = 'Aucune image sélectionnée';
      return;
    }
    imageSourceValue.textContent = fieldImageUrl.value;
  }

  async function uploadLogoFile(file) {
    const formData = new FormData();
    formData.append('file', file);
    const response = await fetch('/api/me/upload?field=iconUrl', {
      method: 'POST',
      body: formData,
    });
    if (!response.ok) {
      const data = await response.json().catch(() => ({}));
      throw new Error(data.error || 'upload_failed');
    }
    const data = await response.json();
    if (!data?.url) throw new Error('upload_failed');
    return data.url;
  }

  async function openLibraryModal() {
    qrLibraryModal.classList.remove('hidden');
    qrLibraryGrid.innerHTML = '<div class="col-span-full text-sm text-slate-400">Chargement...</div>';
    const response = await fetch('/api/me/uploads');
    if (!response.ok) {
      qrLibraryGrid.innerHTML = '<div class="col-span-full text-sm text-rose-400">Impossible de charger la bibliothèque.</div>';
      return;
    }
    const data = await response.json();
    const uploads = data.uploads || [];
    if (!uploads.length) {
      qrLibraryGrid.innerHTML = '<div class="col-span-full text-sm text-slate-400">Aucune image dans la bibliothèque.</div>';
      return;
    }
    qrLibraryGrid.innerHTML = uploads.map((item) => `
      <button type="button" data-url="${escapeHtml(item.url)}" class="p-2 rounded-xl border border-slate-700 bg-slate-950 hover:border-violet-500/40 transition-colors text-left">
        <img src="${escapeHtml(item.url)}" alt="upload" class="w-full h-20 object-contain rounded-lg bg-slate-800" />
        <p class="text-[11px] text-slate-400 mt-2 truncate">${escapeHtml(item.name || 'Image')}</p>
      </button>
    `).join('');
    qrLibraryGrid.querySelectorAll('button[data-url]').forEach((btn) => {
      btn.addEventListener('click', () => {
        fieldIncludeImage.checked = true;
        fieldImageUrl.value = btn.dataset.url || '';
        syncFormIndicators();
        updateImageSourceLabel();
        renderPreview();
        scheduleAutoSave();
        qrLibraryModal.classList.add('hidden');
      });
    });
  }

  const presets = {
    custom: null,
    plinkk: { foreground: '#111827', eye: '#7c3aed', background: '#ffffff' },
    midnight: { foreground: '#e2e8f0', eye: '#38bdf8', background: '#0f172a' },
    forest: { foreground: '#14532d', eye: '#166534', background: '#f0fdf4' },
    sunset: { foreground: '#9a3412', eye: '#ea580c', background: '#fff7ed' },
    mono: { foreground: '#000000', eye: '#000000', background: '#ffffff' },
  };

  function applyPreset(presetKey) {
    const preset = presets[presetKey];
    if (!preset) return;
    fieldForeground.value = preset.foreground;
    fieldEye.value = preset.eye;
    fieldBackground.value = preset.background;

    if (presetKey !== 'custom') {
      fieldIncludeImage.checked = true;
      fieldImageUrl.value = PLINKK_LOGO_URL;
    }
  }

  function updatePreviewLink(targetUrl) {
    const link = currentEditingQr?.shareUrl || targetUrl || '#';
    previewLinkEl.href = link;
    previewLinkEl.textContent = link;
  }

  function setSaveStatus(message, isError = false) {
    if (!saveStatusEl) return;
    saveStatusEl.textContent = message;
    saveStatusEl.classList.toggle('text-rose-400', Boolean(isError));
    saveStatusEl.classList.toggle('text-emerald-400', !isError && /enregistré/i.test(message));
    saveStatusEl.classList.toggle('text-slate-400', !isError && !/enregistré/i.test(message));
  }

  function escapeHtml(value) {
    return String(value || '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  async function renderPreview() {
    if (!plinkkId) {
      previewEl.innerHTML = '<p class="text-sm text-rose-400">Plinkk introuvable.</p>';
      return;
    }

    try {
      if (previewController) {
        previewController.abort();
      }
      previewController = new AbortController();

      const response = await fetch(`/api/me/plinkks/${plinkkId}/qrcodes/preview.svg`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          qrId: qrCodeIdEl.value || undefined,
          targetType: fieldTargetType.value,
          customUrl: fieldTargetType.value === 'CUSTOM_URL' ? fieldCustomUrl.value : undefined,
          foregroundHex: fieldForeground.value,
          eyeHex: fieldEye.value,
          backgroundHex: fieldBackground.value,
          rounded: fieldRounded.checked,
          margin: parseInt(fieldMargin.value || '2', 10),
          size: 384,
          errorCorrectionLevel: fieldErrorCorrection.value,
          includeImage: fieldIncludeImage.checked,
          imageUrl: fieldIncludeImage.checked ? fieldImageUrl.value : undefined,
          imageSize: parseInt(fieldImageSize.value || '25', 10),
          logoColor: fieldLogoColor.value,
        }),
        signal: previewController.signal,
      });

      if (!response.ok) {
        const data = await response.json().catch(() => ({}));
        throw new Error(data.error || 'Impossible de générer la prévisualisation.');
      }

        const svg = await response.text();
        const targetUrl = response.headers.get('x-qr-target-url') || '';
        updatePreviewLink(targetUrl);
      previewEl.innerHTML = svg;
      const svgNode = previewEl.querySelector('svg');
      if (svgNode) {
        svgNode.style.width = '100%';
        svgNode.style.height = '100%';
        svgNode.style.maxWidth = '280px';
      }

      const previewNode = previewEl.firstElementChild;
      if (previewNode) {
        previewNode.classList.add('w-full', 'h-full');
      }

      if (fieldRounded.checked) {
        previewEl.style.borderRadius = '16px';
      } else {
        previewEl.style.borderRadius = '0';
      }
    } catch (error) {
      if (error?.name === 'AbortError') return;
      console.error('Erreur QR Code:', error);
      previewEl.innerHTML = '<p class="text-sm text-rose-400">Erreur: ' + escapeHtml(error?.message || 'Impossible de générer') + '</p>';
    }
  }

  function syncFormIndicators() {
    marginValue.textContent = fieldMargin.value;
    imageSizeValue.textContent = `${fieldImageSize.value}%`;
    logoColorValue.textContent = fieldLogoColor.value;
    foregroundValue.textContent = fieldForeground.value;
    eyeValue.textContent = fieldEye.value;
    backgroundValue.textContent = fieldBackground.value;
    customUrlGroup.classList.toggle('hidden', fieldTargetType.value !== 'CUSTOM_URL');
    imageFieldsGroup.classList.toggle('hidden', !fieldIncludeImage.checked);
    logoColorGroup.classList.toggle('hidden', !fieldIncludeImage.checked || !isSvgUrl(fieldImageUrl.value));
  }

  function resetForm() {
    currentEditingQr = null;
    qrCodeIdEl.value = '';
    fieldName.value = '';
    fieldTargetType.value = 'PLINKK_PAGE';
    fieldCustomUrl.value = '';
    fieldForeground.value = '#111827';
    fieldEye.value = '#111827';
    fieldBackground.value = '#ffffff';
    fieldRounded.checked = false;
    fieldMargin.value = '2';
    fieldErrorCorrection.value = 'M';
    fieldPreset.value = 'plinkk';
    fieldIncludeImage.checked = true;
    fieldImageUrl.value = PLINKK_LOGO_URL;
    fieldImageSize.value = '25';
    fieldLogoColor.value = '#7c3aed';
    applyPreset('plinkk');
    submitBtn.textContent = 'Créer le QR Code';
    syncFormIndicators();
    updateImageSourceLabel();
    updatePreviewLink('');
    renderPreview();
  }

  function fillFormForEdit(item) {
    currentEditingQr = item;
    qrCodeIdEl.value = item.id;
    fieldName.value = item.name || '';
    fieldTargetType.value = item.targetType || 'PLINKK_PAGE';
    fieldCustomUrl.value = item.targetType === 'CUSTOM_URL' ? (item.targetUrl || '') : '';
    fieldForeground.value = item.foregroundHex || '#111827';
    fieldEye.value = item.eyeHex || '#111827';
    fieldBackground.value = item.backgroundHex || '#ffffff';
    fieldRounded.checked = Boolean(item.rounded);
    fieldMargin.value = String(item.margin ?? 2);
    fieldErrorCorrection.value = item.errorCorrectionLevel || 'M';
    fieldPreset.value = item.preset || 'custom';
    fieldIncludeImage.checked = Boolean(item.includeImage);
    fieldImageUrl.value = item.imageUrl || '';
    fieldImageSize.value = String(item.imageSize ?? 25);
    fieldLogoColor.value = item.logoColor || '#7c3aed';
    submitBtn.textContent = 'Enregistrer les modifications';
    syncFormIndicators();
    updateImageSourceLabel();
    updatePreviewLink(item.shareUrl || '');
    renderPreview();
  }

  function renderList() {
    if (!currentQrCodes.length) {
      listEl.innerHTML = `
        <div class="text-center py-8 text-slate-400 bg-slate-800/40 rounded-xl border border-slate-800">
          Aucun QR code pour ce Plinkk.
        </div>
      `;
      return;
    }

    listEl.innerHTML = currentQrCodes.map((item) => `
      <button type="button" data-id="${item.id}"
        class="w-full text-left bg-slate-800 border border-slate-700 rounded-xl p-3 hover:border-violet-500/40 transition-colors">
        <p class="text-sm font-semibold text-white truncate">${escapeHtml(item.name || 'Sans nom')}</p>
        <p class="text-xs text-slate-400 mt-1">${escapeHtml(item.targetType)}</p>
        <p class="text-xs text-slate-500 mt-1 truncate">${escapeHtml(item.shareUrl || '')}</p>
      </button>
    `).join('');

    listEl.querySelectorAll('button[data-id]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const found = currentQrCodes.find((entry) => entry.id === btn.dataset.id);
        if (found) fillFormForEdit(found);
      });
    });
  }

  async function loadQRCodes() {
    if (!plinkkId) return;
    const response = await fetch(`/api/me/plinkks/${plinkkId}/qrcodes`);
    if (!response.ok) throw new Error('Erreur de chargement des QR codes');
    const data = await response.json();
    currentQrCodes = data.items || [];
    renderList();

    if (qrIdToEdit) {
      const selected = currentQrCodes.find((entry) => entry.id === qrIdToEdit);
      if (selected) {
        fillFormForEdit(selected);
        return;
      }
    }

    if (currentQrCodes[0]) {
      fillFormForEdit(currentQrCodes[0]);
    } else {
      resetForm();
    }
  }

  function buildPayload() {
    return {
      name: fieldName.value,
      targetType: fieldTargetType.value,
      customUrl: fieldTargetType.value === 'CUSTOM_URL' ? fieldCustomUrl.value : undefined,
      foregroundHex: fieldForeground.value,
      eyeHex: fieldEye.value,
      backgroundHex: fieldBackground.value,
      rounded: fieldRounded.checked,
      margin: parseInt(fieldMargin.value || '2', 10),
      errorCorrectionLevel: fieldErrorCorrection.value,
      preset: fieldPreset.value,
      includeImage: fieldIncludeImage.checked,
      imageUrl: fieldIncludeImage.checked ? fieldImageUrl.value : undefined,
      imageSize: parseInt(fieldImageSize.value || '25', 10),
      logoColor: fieldLogoColor.value,
    };
  }

  async function saveQr(forceCreate = false) {
    if (!plinkkId) return;
    const qrId = qrCodeIdEl.value;
    if (!qrId && !forceCreate) {
      setSaveStatus('Nouveau QR : cliquez sur Créer pour initialiser.');
      return;
    }

    const method = qrId ? 'PATCH' : 'POST';
    const url = qrId
      ? `/api/me/plinkks/${plinkkId}/qrcodes/${qrId}`
      : `/api/me/plinkks/${plinkkId}/qrcodes`;

    isAutoSaving = true;
    setSaveStatus('Enregistrement...');

    try {
      const response = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(buildPayload()),
      });

      if (!response.ok) {
        const data = await response.json().catch(() => ({}));
        throw new Error(data.error || 'Erreur lors de la sauvegarde');
      }

      await loadQRCodes();
      setSaveStatus('✅ Modifications enregistrées');
    } finally {
      isAutoSaving = false;
    }
  }

  function scheduleAutoSave() {
    if (suspendAutoSave || isAutoSaving) return;
    if (!qrCodeIdEl.value) {
      setSaveStatus('Nouveau QR : cliquez sur Créer pour initialiser.');
      return;
    }
    setSaveStatus('Modifications en attente...');
    if (autoSaveTimer) clearTimeout(autoSaveTimer);
    autoSaveTimer = setTimeout(async () => {
      try {
        await saveQr(false);
      } catch (error) {
        setSaveStatus(`Erreur autosave: ${error.message}`, true);
      }
    }, 700);
  }

  async function onSubmit(event) {
    event.preventDefault();
    if (!plinkkId) return;
    await saveQr(true);
  }

  function downloadQrCodeSvg() {
    const qrId = qrCodeIdEl.value;
    if (!qrId) {
      alert('Veuillez d\'abord créer le QR Code.');
      return;
    }
    const fileName = (fieldName.value || 'QR Code').replace(/[^a-z0-9_-]/gi, '_');
    const url = `/api/me/plinkks/${plinkkId}/qrcodes/${qrId}/image.svg`;
    const link = document.createElement('a');
    link.href = url;
    link.download = `${fileName}.svg`;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  }

  document.getElementById('btnNewQr').addEventListener('click', resetForm);
  document.getElementById('btnResetForm').addEventListener('click', resetForm);
  uploadLogoBtn.addEventListener('click', () => imageFileInput.click());
  imageFileInput.addEventListener('change', async () => {
    const file = imageFileInput.files?.[0];
    if (!file) return;
    try {
      const uploadedUrl = await uploadLogoFile(file);
      fieldIncludeImage.checked = true;
      fieldImageUrl.value = uploadedUrl;
      syncFormIndicators();
      updateImageSourceLabel();
      renderPreview();
      scheduleAutoSave();
    } catch (error) {
      alert(`Erreur upload: ${error.message}`);
    } finally {
      imageFileInput.value = '';
    }
  });
  libraryLogoBtn.addEventListener('click', () => {
    openLibraryModal().catch((e) => {
      console.error(e);
      qrLibraryGrid.innerHTML = '<div class="col-span-full text-sm text-rose-400">Erreur chargement bibliothèque.</div>';
    });
  });
  clearLogoBtn.addEventListener('click', () => {
    fieldImageUrl.value = '';
    fieldIncludeImage.checked = false;
    syncFormIndicators();
    updateImageSourceLabel();
    renderPreview();
    scheduleAutoSave();
  });
  closeQrLibraryBtn.addEventListener('click', () => qrLibraryModal.classList.add('hidden'));
  qrLibraryModal.addEventListener('click', (event) => {
    if (event.target === qrLibraryModal) qrLibraryModal.classList.add('hidden');
  });
  fieldPreset.addEventListener('change', () => {
    applyPreset(fieldPreset.value);
    syncFormIndicators();
    updateImageSourceLabel();
    renderPreview();
    scheduleAutoSave();
  });
  formEl.addEventListener('submit', async (event) => {
    try {
      await onSubmit(event);
    } catch (error) {
      alert(`Erreur: ${error.message}`);
    }
  });

  downloadBtn.addEventListener('click', downloadQrCodeSvg);

  [fieldTargetType, fieldCustomUrl, fieldForeground, fieldEye, fieldBackground, fieldRounded, fieldMargin, fieldErrorCorrection, fieldIncludeImage, fieldImageUrl, fieldImageSize, fieldLogoColor].forEach((el) => {
    if (el) {
      el.addEventListener('input', () => {
        syncFormIndicators();
        renderPreview();
        scheduleAutoSave();
      });
      el.addEventListener('change', () => {
        syncFormIndicators();
        renderPreview();
        scheduleAutoSave();
      });
    }
  });

  syncFormIndicators();
  updateImageSourceLabel();
  renderPreview();
  loadQRCodes().catch((error) => {
    listEl.innerHTML = `<div class="text-sm text-rose-400">${escapeHtml(error.message)}</div>`;
  });
});
</script>
