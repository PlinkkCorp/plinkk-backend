<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/button.css">
    <link rel="icon" type="image/svg+xml" href="https://cdn.plinkk.fr/logo.svg" />
    <link rel="apple-touch-icon" href="https://cdn.plinkk.fr/logo.svg" />
    
    <% 
      const pageTitle = (page && page.title) ? page.title : username;
      const pageDesc = (page && page.description) ? page.description : `Découvre le profil de ${username} sur Plinkk !`;
      const pageUrl = (typeof publicPath !== 'undefined' && publicPath) ? publicPath : ((page && page.slug) ? page.slug : username);
      const ogImage = `/og/${encodeURIComponent(pageTitle)}`;
    %>
    
    <title><%= pageTitle %> — Plinkk</title>
    
    <!-- Métadonnées de base -->
    <meta name="title" content="<%= pageTitle %>">
    <meta name="description" content="<%= pageDesc %>">
    <meta name="keywords" content="Plinkk, <%= username %>, profil, liens, bio, réseaux sociaux, portfolio, page personnalisée">
    <meta name="author" content="<%= username %>">
    <meta name="robots" content="index, follow, max-image-preview:large">
    <meta name="theme-color" content="#8B5CF6">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="profile">
    <meta property="og:site_name" content="Plinkk">
    <meta property="og:locale" content="fr_FR">
    <meta property="og:url" content="<%= pageUrl %>">
    <meta property="og:title" content="<%= pageTitle %> sur Plinkk">
    <meta property="og:description" content="<%= pageDesc %>">
    <meta property="og:image" content="<%= ogImage %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="<%= pageTitle %> - Page Plinkk">
    <% if (page && page.username) { %>
    <meta property="profile:username" content="<%= page.username %>">
    <% } %>
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@Plinkk">
    <meta name="twitter:url" content="<%= pageUrl %>">
    <meta name="twitter:title" content="<%= pageTitle %> sur Plinkk">
    <meta name="twitter:description" content="<%= pageDesc %>">
    <meta name="twitter:image" content="/api/plinkks/og/<%= encodeURIComponent(pageTitle) %>">
    <meta name="twitter:image:alt" content="<%= pageTitle %> - Profil Plinkk">
    
    <!-- Métadonnées structurées JSON-LD -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfilePage",
      "mainEntity": {
        "@type": "Person",
        "name": "<%= pageTitle.replace(/"/g, '\\"') %>",
        "description": "<%= pageDesc.replace(/"/g, '\\"') %>",
        "url": "<%= pageUrl %>",
        "image": "<%= ogImage %>"
      },
      "isPartOf": {
        "@type": "WebSite",
        "name": "Plinkk",
        "url": "https://plinkk.fr"
      }
    }
    </script>
    <meta http-equiv="Permissions-Policy"
        content="autoplay=*, clipboard-write=*, encrypted-media=*, picture-in-picture=*, web-share=*, fullscreen=*, unload=*">
    <meta http-equiv="Content-Security-Policy"
        content="default-src 'self' 'unsafe-inline' 'unsafe-eval' https: data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://plinkk.fr https://analytics.plinkk.fr s3.marvideo.fr https://www.youtube.com https://s.ytimg.com; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https: blob:; font-src 'self' https: data:; connect-src 'self' https:; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://open.spotify.com https:;">

    <% const viewSettings=(typeof settings !=='undefined' && settings) ? settings : (page && page.settings ?
        page.settings : {}); %>
        <% if (viewSettings && viewSettings.fontFamily) { %>
            <link rel="preconnect" href="https://fonts.googleapis.com">
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
            <link
                href="https://fonts.googleapis.com/css2?family=<%= viewSettings.fontFamily.replace(/ /g, '+') %>:wght@400;500;600;700&display=swap"
                rel="stylesheet">
            <style>
                body,
                #profile-article {
                    font-family: '<%= viewSettings.fontFamily %>', sans-serif !important;
                }
            </style>
            <% } %>
</head>

<%- include('./loader.ejs') %>

    <body>
        <div class="background"></div>
        <article id="profile-article">
            <!-- Skeleton Loading -->
            <div id="skeleton-loading" class="animate-pulse space-y-6">
                <div class="flex flex-col items-center space-y-4">
                    <div class="w-40 h-40 bg-white/10 rounded-full"></div>
                    <div class="w-32 h-6 bg-white/10 rounded-lg"></div>
                    <div class="w-48 h-4 bg-white/10 rounded-md"></div>
                </div>
                <div class="flex justify-center space-x-3">
                    <div class="w-8 h-8 bg-white/10 rounded-lg"></div>
                    <div class="w-8 h-8 bg-white/10 rounded-lg"></div>
                    <div class="w-8 h-8 bg-white/10 rounded-lg"></div>
                </div>
                <div class="space-y-3 pt-4">
                    <div class="w-full h-14 bg-white/10 rounded-2xl"></div>
                    <div class="w-full h-14 bg-white/10 rounded-2xl"></div>
                    <div class="w-full h-14 bg-white/10 rounded-2xl"></div>
                </div>
            </div>
        </article>
    </body>
    <script type="application/json" id="plinkk-ctx-username"><%- JSON.stringify(username || "") %></script>
    <script type="application/json"
        id="plinkk-ctx-identifier"><%- JSON.stringify((page && page.slug) ? page.slug : "") %></script>
    <script>
        (function () {
            try {
                const u = document.getElementById('plinkk-ctx-username')?.textContent || '';
                const s = document.getElementById('plinkk-ctx-identifier')?.textContent || '';
                window.__PLINKK_USERNAME__ = JSON.parse(u || '""');
                window.__PLINKK_IDENTIFIER__ = JSON.parse(s || '""');
            } catch (_) { }
        })();
        window.__PLINKK_EXPORT_MODE__ = <%= !!(locals.isExport) %>;
        window.__PLINKK_IS_PREVIEW__ = (new URLSearchParams(location.search).get('preview') === '1');
        if (!window.__PLINKK_IDENTIFIER__) {
            try {
                const parts = location.pathname.split('/').filter(Boolean);
                if (parts[1] === '0') window.__PLINKK_IDENTIFIER__ = '';
            } catch (_) { }
        }
    </script>
    <script type="application/json" id="plinkk-page-id"><%- JSON.stringify(page?.id || "") %></script>
    <script>
        // Client-side tracking avec localStorage
        (function() {
            try {
                const pageId = JSON.parse(document.getElementById('plinkk-page-id')?.textContent || '""');
                if (!pageId) return;

                const isPreview = window.__PLINKK_IS_PREVIEW__;
                const ttl = isPreview ? 1000 : 10000; // 1s en preview, 10s sinon
                
                // 1. Tracking des vues de page
                const viewKey = `plinkk_view_${pageId}`;
                const lastView = localStorage.getItem(viewKey);
                const now = Date.now();
                
                if (!lastView || now - parseInt(lastView, 10) > ttl) {
                    fetch(`/api/track-view/${pageId}`, { 
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    })
                    .then(() => localStorage.setItem(viewKey, String(now)))
                    .catch(() => {}); // Silencieux en cas d'erreur
                }

                // 2. Interception des clics sur les liens
                document.addEventListener('click', function(e) {
                    const link = e.target.closest('a[href^="/click/"]');
                    if (!link) return;

                    const href = link.getAttribute('href');
                    const match = href?.match(/^\/click\/([^/?&#]+)/);
                    if (!match) return;

                    const linkId = match[1];
                    const clickKey = `plinkk_click_${linkId}`;
                    const lastClick = localStorage.getItem(clickKey);
                    const now = Date.now();
                    
                    // Si le cache est valide, rediriger directement sans tracker
                    if (lastClick && now - parseInt(lastClick, 10) <= ttl) {
                        // Pas de preventDefault, laisser le navigateur suivre le lien normalement
                        return;
                    }

                    // Sinon, faire le tracking puis rediriger
                    e.preventDefault();
                    fetch(`/api/track-click/${linkId}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    })
                    .then(res => res.json())
                    .then(data => {
                        localStorage.setItem(clickKey, String(now));
                        if (data.url) {
                            window.location.href = data.url;
                        }
                    })
                    .catch(() => {
                        // En cas d'erreur, suivre le lien normalement
                        window.location.href = href;
                    });
                });
            } catch (err) {
                console.warn('Tracking initialization failed:', err);
            }
        })();
    </script>
    <script type="module"
        src="/<%= (typeof publicPath !== 'undefined' && publicPath) ? publicPath : ((page && page.slug) ? page.slug : username) %>.js?v=fix-icons"></script>
    <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.9.1/dist/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/simplex-noise/2.4.0/simplex-noise.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/dat-gui/0.7.7/dat.gui.min.js"></script>

</html>