<%- include('partials/head.ejs', { title: 'Tableau de bord - Administration' ,
    description: "Gestion des signalements de bugs" , robots: 'noindex,nofollow' }) %>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <%- include('partials/header-dash.ejs', { user: user }) %>

        <% const total=bugReports ? bugReports.length : 0; const countPending=bugReports ? bugReports.filter(r=>
            r.status === 'PENDING').length : 0;
            const countProgress = bugReports ? bugReports.filter(r => r.status === 'IN_PROGRESS').length : 0;
            const countResolved = bugReports ? bugReports.filter(r => r.status === 'RESOLVED').length : 0;
            %>

            <div class="max-w-[1600px] mx-auto grid grid-cols-12 gap-6 px-4 py-8 min-h-[calc(100vh-72px)]">
                <%- include('partials/admin-nav.ejs', { user: user, active: 'bug-reports' }) %>

                    <main class="col-span-12 lg:col-span-10 space-y-5">

                        <!-- ── Header ──────────────────────────────────────────── -->
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                            <div>
                                <h1 class="text-2xl font-bold text-white tracking-tight flex items-center gap-3">
                                    <span
                                        class="inline-flex items-center justify-center w-9 h-9 rounded-2xl bg-rose-500/10 border border-rose-500/20 text-rose-400">
                                        <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                            stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                        </svg>
                                    </span>
                                    Signalements de bugs
                                </h1>
                                <p class="text-sm text-slate-500 mt-1 ml-12">Gérez les tickets signalés par vos
                                    utilisateurs.</p>
                            </div>
                        </div>

                        <!-- ── Stats bar ────────────────────────────────────────── -->
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                            <button onclick="setFilter('all')" data-filter="all"
                                class="filter-btn active-filter group flex flex-col p-4 rounded-2xl border bg-slate-900 border-slate-800 hover:border-slate-700 transition-all text-left cursor-pointer">
                                <span class="text-2xl font-black text-white tabular-nums">
                                    <%= total %>
                                </span>
                                <span
                                    class="text-[11px] font-semibold text-slate-500 mt-0.5 uppercase tracking-wider">Total</span>
                            </button>
                            <button onclick="setFilter('PENDING')" data-filter="PENDING"
                                class="filter-btn group flex flex-col p-4 rounded-2xl border bg-slate-900 border-slate-800 hover:border-amber-500/40 transition-all text-left cursor-pointer">
                                <span class="text-2xl font-black text-amber-400 tabular-nums">
                                    <%= countPending %>
                                </span>
                                <span
                                    class="text-[11px] font-semibold text-slate-500 mt-0.5 uppercase tracking-wider">En
                                    attente</span>
                            </button>
                            <button onclick="setFilter('IN_PROGRESS')" data-filter="IN_PROGRESS"
                                class="filter-btn group flex flex-col p-4 rounded-2xl border bg-slate-900 border-slate-800 hover:border-blue-500/40 transition-all text-left cursor-pointer">
                                <span class="text-2xl font-black text-blue-400 tabular-nums">
                                    <%= countProgress %>
                                </span>
                                <span
                                    class="text-[11px] font-semibold text-slate-500 mt-0.5 uppercase tracking-wider">En
                                    cours</span>
                            </button>
                            <button onclick="setFilter('RESOLVED')" data-filter="RESOLVED"
                                class="filter-btn group flex flex-col p-4 rounded-2xl border bg-slate-900 border-slate-800 hover:border-emerald-500/40 transition-all text-left cursor-pointer">
                                <span class="text-2xl font-black text-emerald-400 tabular-nums">
                                    <%= countResolved %>
                                </span>
                                <span
                                    class="text-[11px] font-semibold text-slate-500 mt-0.5 uppercase tracking-wider">Résolus</span>
                            </button>
                        </div>

                        <!-- ── Ticket list ──────────────────────────────────────── -->
                        <div id="ticketList" class="space-y-2">
                            <% if (bugReports && bugReports.length> 0) { %>
                                <% bugReports.forEach(function(r, i) { const preview=r.message.slice(0, 140) +
                                    (r.message.length> 140 ? '…' : '');
                                    const hasReplies = r.thread && r.thread.length > 1;
                                    const adminReplied = r.thread && r.thread.some(function(m) { return m.from ===
                                    'admin'; });
                                    %>
                                    <div class="ticket-card group relative flex items-center gap-4 bg-slate-900 border border-slate-800 hover:border-slate-700 rounded-2xl px-5 py-4 transition-all hover:shadow-xl hover:shadow-slate-950/50 cursor-pointer"
                                        data-status="<%= r.status %>" onclick="openDetails(<%= i %>)">
                                        <!-- Status stripe -->
                                        <div
                                            class="absolute left-0 top-3 bottom-3 w-1 rounded-full
                        <% if (r.status==='PENDING') { %>bg-amber-500<% } else if (r.status==='IN_PROGRESS') { %>bg-blue-500<% } else if (r.status==='RESOLVED') { %>bg-emerald-500<% } else { %>bg-slate-600<% } %>">
                                        </div>

                                        <!-- Avatar -->
                                        <div class="shrink-0 ml-2">
                                            <% if (r.user && r.user.image) { %>
                                                <img src="<%= r.user.image %>"
                                                    class="w-9 h-9 rounded-full object-cover ring-1 ring-white/10">
                                                <% } else if (r.user) { %>
                                                    <div
                                                        class="w-9 h-9 rounded-full bg-violet-600/15 border border-violet-500/20 flex items-center justify-center text-[11px] font-bold text-violet-400 uppercase">
                                                        <%= r.user.userName?.substring(0, 2) %>
                                                    </div>
                                                    <% } else { %>
                                                        <div
                                                            class="w-9 h-9 rounded-full bg-slate-800 border border-white/5 flex items-center justify-center text-slate-600">
                                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24"
                                                                stroke="currentColor">
                                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                                    stroke-width="2"
                                                                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                                            </svg>
                                                        </div>
                                                        <% } %>
                                        </div>

                                        <!-- Content -->
                                        <div class="flex-1 min-w-0">
                                            <div class="flex items-center gap-2 mb-1 flex-wrap">
                                                <span class="text-[11px] font-bold text-slate-400 font-mono">#<%=
                                                        r.id.slice(-8) %></span>
                                                <% if (r.user) { %>
                                                    <span class="text-[11px] font-semibold text-slate-300">
                                                        <%= r.user.userName %>
                                                    </span>
                                                    <span class="text-[10px] text-slate-600">
                                                        <%= r.user.email %>
                                                    </span>
                                                    <% } else { %>
                                                        <span class="text-[11px] text-slate-500 italic">Anonyme</span>
                                                        <% } %>
                                                            <% if (adminReplied) { %>
                                                                <span
                                                                    class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-md text-[9px] font-bold bg-violet-500/10 text-violet-400 border border-violet-500/20">
                                                                    <svg class="w-2.5 h-2.5" fill="currentColor"
                                                                        viewBox="0 0 20 20">
                                                                        <path fill-rule="evenodd"
                                                                            d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z"
                                                                            clip-rule="evenodd" />
                                                                    </svg>
                                                                    Répondu
                                                                </span>
                                                                <% } %>
                                            </div>
                                            <p class="text-[13px] text-slate-300 truncate leading-snug">
                                                <%= preview %>
                                            </p>
                                            <div class="flex items-center gap-3 mt-1.5 flex-wrap">
                                                <span class="text-[10px] text-slate-600 font-mono">
                                                    <%= new Date(r.createdAt).toLocaleString('fr-FR') %>
                                                </span>
                                                <% if (hasReplies) { %>
                                                    <span class="text-[10px] text-slate-500 flex items-center gap-1">
                                                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24"
                                                            stroke="currentColor">
                                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                                stroke-width="2"
                                                                d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                                                        </svg>
                                                        <%= r.thread.length %> messages
                                                    </span>
                                                    <% } %>
                                                        <% if (r.url) { %>
                                                            <span
                                                                class="text-[10px] text-violet-500/70 font-mono truncate max-w-[200px]"
                                                                title="<%= r.url %>">
                                                                <%= r.url.replace(/^https?:\/\/[^\/]+/, '' ) || r.url %>
                                                            </span>
                                                            <% } %>
                                                                <% if (typeof r.browser==='object' &&
                                                                    r.browser?.platform) { %>
                                                                    <span class="text-[10px] text-slate-600 font-mono">
                                                                        <%= r.browser.platform %>
                                                                    </span>
                                                                    <% } %>
                                            </div>
                                        </div>

                                        <!-- Status + action -->
                                        <div class="shrink-0 flex flex-col items-end gap-2">
                                            <% if (r.status==='PENDING' ) { %>
                                                <span
                                                    class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-amber-500/10 text-amber-400 border border-amber-500/20">
                                                    <span
                                                        class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>En
                                                    attente
                                                </span>
                                                <% } else if (r.status==='IN_PROGRESS' ) { %>
                                                    <span
                                                        class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-blue-500/10 text-blue-400 border border-blue-500/20">
                                                        <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span>En
                                                        cours
                                                    </span>
                                                    <% } else if (r.status==='RESOLVED' ) { %>
                                                        <span
                                                            class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                                                            <span
                                                                class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>Résolu
                                                        </span>
                                                        <% } else { %>
                                                            <span
                                                                class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase bg-slate-800 text-slate-400 border border-slate-700">
                                                                <%= r.status %>
                                                            </span>
                                                            <% } %>
                                                                <svg class="w-4 h-4 text-slate-700 group-hover:text-slate-400 transition-colors"
                                                                    fill="none" viewBox="0 0 24 24"
                                                                    stroke="currentColor">
                                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                                        stroke-width="2" d="M9 5l7 7-7 7" />
                                                                </svg>
                                        </div>
                                    </div>
                                    <% }); %>
                                        <% } else { %>
                                            <div
                                                class="flex flex-col items-center justify-center py-20 gap-3 text-slate-600">
                                                <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24"
                                                    stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="1.5"
                                                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                </svg>
                                                <p class="text-sm font-medium text-slate-500">Aucun signalement de bug.
                                                </p>
                                            </div>
                                            <% } %>
                        </div>

                        <!-- Empty filter state -->
                        <div id="emptyFilter"
                            class="hidden flex-col items-center justify-center py-16 gap-3 text-slate-600">
                            <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                    d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                            </svg>
                            <p class="text-sm font-medium text-slate-500">Aucun ticket dans cette catégorie.</p>
                        </div>

                    </main>
            </div>

            <!-- Hidden inputs for file upload -->
            <input type="file" id="bugAttachmentInput" class="hidden" accept="image/*,application/pdf,text/*">

            <!-- ══════════════════════════════════════════════════════════
     TICKET MODAL
══════════════════════════════════════════════════════════ -->
            <div id="detailsModal"
                class="fixed inset-0 z-[100] hidden items-end sm:items-center justify-center sm:p-4 bg-slate-950/80 backdrop-blur-sm"
                aria-labelledby="modal-title" role="dialog" aria-modal="true">
                <div class="fixed inset-0" onclick="closeModal()"></div>

                <!-- Modal shell — wider, split layout -->
                <div
                    class="relative w-full max-w-5xl flex flex-col bg-[#080E1E] border border-white/8 rounded-t-[2rem] sm:rounded-[2rem] shadow-2xl shadow-slate-950 max-h-[92vh] overflow-hidden transition-all">

                    <!-- ── Top bar ── -->
                    <div
                        class="flex items-center gap-4 px-6 py-4 border-b border-white/6 shrink-0 bg-slate-950/60 backdrop-blur">
                        <!-- Status pill (clickable — opens quick-change menu) -->
                        <div id="modalStatusBadge" class="shrink-0"></div>

                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2">
                                <span class="text-[11px] font-mono text-slate-500" id="modalIdDisplay"></span>
                                <span id="modalUserChip" class="text-[11px] text-slate-400 truncate"></span>
                            </div>
                            <p class="text-[10px] text-slate-600 font-mono mt-0.5" id="modalDate"></p>
                        </div>

                        <!-- Quick resolve -->
                        <form id="resolveForm" method="POST" action="" class="shrink-0">
                            <input type="hidden" name="status" value="RESOLVED">
                            <button type="submit" id="resolveSubmitBtn"
                                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[11px] font-bold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 hover:bg-emerald-500 hover:text-white hover:border-emerald-500 transition-all">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                        d="M5 13l4 4L19 7" />
                                </svg>
                                Résoudre
                            </button>
                        </form>

                        <button onclick="closeModal()"
                            class="shrink-0 p-2 rounded-xl hover:bg-white/5 text-slate-600 hover:text-white transition-colors">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>

                    <!-- ── Body: split ── -->
                    <div class="flex flex-col md:flex-row flex-1 overflow-hidden min-h-0">

                        <!-- LEFT — Thread -->
                        <div
                            class="relative flex-1 min-w-0 flex flex-col overflow-hidden border-b md:border-b-0 md:border-r border-white/6">
                            <!-- Thread scroll area -->
                            <div id="modalThread" class="flex-1 overflow-y-auto p-5 space-y-4 min-h-0 bg-slate-950/20">
                                <!-- injected by JS -->
                            </div>

                            <!-- Chat Input Area -->
                            <div class="p-4 bg-slate-900/40 border-t border-white/6">
                                <div
                                    class="relative flex items-center gap-2 bg-black/40 border border-white/8 rounded-2xl p-2 focus-within:border-violet-500/50 transition-all">
                                    <!-- Add button -->
                                    <button onclick="document.getElementById('bugAttachmentInput').click()"
                                        class="shrink-0 w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 hover:bg-white/10 text-slate-400 hover:text-white transition-all"
                                        title="Joindre un fichier">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                            stroke-width="2.5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                                        </svg>
                                    </button>

                                    <textarea id="chatInput" placeholder="Rédigez votre réponse…"
                                        class="flex-1 bg-transparent border-none outline-none text-[13px] text-white placeholder:text-slate-600 py-2.5 resize-none max-h-32 overflow-y-auto leading-relaxed"
                                        rows="1"></textarea>

                                    <div class="flex items-center gap-1">
                                        <!-- Image Gallery button -->
                                        <button onclick="toggleGallery()"
                                            class="w-9 h-9 flex items-center justify-center rounded-xl hover:bg-white/5 text-slate-500 hover:text-white transition-all"
                                            title="Mes images">
                                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                            </svg>
                                        </button>
                                        <!-- Emoji button -->
                                        <button id="emojiBtn" onclick="toggleEmojiPicker()"
                                            class="w-9 h-9 flex items-center justify-center rounded-xl hover:bg-white/5 text-slate-500 hover:text-white transition-all"
                                            title="Émojis">
                                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                            </svg>
                                        </button>
                                        <!-- Send button -->
                                        <button onclick="sendChatResponse()"
                                            class="w-9 h-9 flex items-center justify-center rounded-xl bg-violet-600 hover:bg-violet-500 text-white shadow-lg shadow-violet-900/20 transition-all">
                                            <svg class="w-5 h-5 translate-x-0.5" fill="none" viewBox="0 0 24 24"
                                                stroke="currentColor" stroke-width="2.5">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                    d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Emoji Picker Popup -->
                            <div id="emojiPicker"
                                class="hidden absolute bottom-20 right-8 z-[110] bg-[#111827] border border-white/10 rounded-2xl shadow-2xl p-3 w-72 h-80 flex flex-col">
                                <div class="flex items-center justify-between mb-2 px-1">
                                    <span
                                        class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Émojis</span>
                                    <div class="flex gap-2">
                                        <button onclick="setEmojiCat('faces')" class="text-sm">😀</button>
                                        <button onclick="setEmojiCat('objects')" class="text-sm">💡</button>
                                        <button onclick="setEmojiCat('symbols')" class="text-sm">❤️</button>
                                    </div>
                                </div>
                                <div id="emojiGrid" class="flex-1 overflow-y-auto grid grid-cols-6 gap-2 p-1"></div>
                            </div>

                            <!-- Image Gallery Popup -->
                            <div id="imageGallery"
                                class="hidden absolute bottom-20 right-8 z-[110] bg-[#111827] border border-white/10 rounded-2xl shadow-2xl p-4 w-80 h-96 flex flex-col">
                                <div class="flex items-center justify-between mb-3 px-1">
                                    <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Vos
                                        images</span>
                                    <button onclick="toggleGallery()" class="text-slate-500 hover:text-white"><svg
                                            class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                d="M6 18L18 6M6 6l12 12" />
                                        </svg></button>
                                </div>
                                <div id="galleryGrid" class="flex-1 overflow-y-auto grid grid-cols-3 gap-2 p-1">
                                    <!-- Loaded via JS -->
                                </div>
                            </div>
                        </div>

                        <!-- RIGHT — Meta + Status + Stack -->
                        <div class="w-full md:w-80 shrink-0 flex flex-col overflow-y-auto bg-slate-900/30">

                            <!-- Meta -->
                            <div class="p-5 border-b border-white/6 space-y-4">
                                <p class="text-[10px] font-bold text-slate-600 uppercase tracking-widest">Informations
                                </p>

                                <!-- URL -->
                                <div class="space-y-1">
                                    <p class="text-[10px] text-slate-600 uppercase tracking-wider">Page</p>
                                    <p id="modalUrl"
                                        class="text-[11px] text-violet-400 font-mono break-all cursor-pointer hover:text-violet-300 hover:underline transition-colors leading-snug">
                                    </p>
                                </div>

                                <!-- Browser -->
                                <div id="modalBrowserContainer" class="hidden space-y-1">
                                    <p class="text-[10px] text-slate-600 uppercase tracking-wider">Environnement</p>
                                    <div id="modalBrowser"
                                        class="space-y-0.5 rounded-xl bg-black/20 p-3 border border-white/5"></div>
                                </div>

                                <!-- User link -->
                                <div id="modalUserLinkContainer" class="hidden">
                                    <a id="modalUserLink" href="#"
                                        class="inline-flex items-center gap-2 text-[11px] text-slate-400 hover:text-white transition-colors group/ul">
                                        <svg class="w-3.5 h-3.5 text-slate-600 group-hover/ul:text-violet-400 transition-colors"
                                            fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                        </svg>
                                        Voir le profil utilisateur
                                    </a>
                                </div>
                            </div>

                            <!-- Status -->
                            <div class="p-5 border-b border-white/6 space-y-4">
                                <p class="text-[10px] font-bold text-slate-600 uppercase tracking-widest">Statut du
                                    ticket</p>

                                <div class="flex flex-col gap-2">
                                    <label
                                        class="relative flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition-all hover:bg-white/5 has-[:checked]:bg-amber-500/10 has-[:checked]:border-amber-500/30 border-white/5">
                                        <input type="radio" name="ticketStatus" value="PENDING"
                                            onchange="updateTicketOption('status', this.value)" class="peer sr-only">
                                        <div
                                            class="w-4 h-4 rounded-full border border-slate-600 peer-checked:border-amber-400 flex items-center justify-center transition-colors">
                                            <div
                                                class="w-1.5 h-1.5 rounded-full bg-amber-400 opacity-0 peer-checked:opacity-100 transition-opacity">
                                            </div>
                                        </div>
                                        <span
                                            class="text-[12px] font-bold text-slate-400 peer-checked:text-amber-400 transition-colors">En
                                            attente</span>
                                    </label>

                                    <label
                                        class="relative flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition-all hover:bg-white/5 has-[:checked]:bg-blue-500/10 has-[:checked]:border-blue-500/30 border-white/5">
                                        <input type="radio" name="ticketStatus" value="IN_PROGRESS"
                                            onchange="updateTicketOption('status', this.value)" class="peer sr-only">
                                        <div
                                            class="w-4 h-4 rounded-full border border-slate-600 peer-checked:border-blue-400 flex items-center justify-center transition-colors">
                                            <div
                                                class="w-1.5 h-1.5 rounded-full bg-blue-400 opacity-0 peer-checked:opacity-100 transition-opacity">
                                            </div>
                                        </div>
                                        <span
                                            class="text-[12px] font-bold text-slate-400 peer-checked:text-blue-400 transition-colors">En
                                            cours</span>
                                    </label>

                                    <label
                                        class="relative flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition-all hover:bg-white/5 has-[:checked]:bg-emerald-500/10 has-[:checked]:border-emerald-500/30 border-white/5">
                                        <input type="radio" name="ticketStatus" value="RESOLVED"
                                            onchange="updateTicketOption('status', this.value)" class="peer sr-only">
                                        <div
                                            class="w-4 h-4 rounded-full border border-slate-600 peer-checked:border-emerald-400 flex items-center justify-center transition-colors">
                                            <div
                                                class="w-1.5 h-1.5 rounded-full bg-emerald-400 opacity-0 peer-checked:opacity-100 transition-opacity">
                                            </div>
                                        </div>
                                        <span
                                            class="text-[12px] font-bold text-slate-400 peer-checked:text-emerald-400 transition-colors">Résolu</span>
                                    </label>
                                </div>
                            </div>

                            <!-- Stack (collapsible) -->
                            <div id="modalStackContainer" class="hidden shrink-0 mt-auto">
                                <button onclick="toggleStack()"
                                    class="w-full flex items-center gap-2 px-5 py-3 text-[10px] font-bold text-rose-400 uppercase tracking-widest hover:bg-rose-500/5 transition-colors border-t border-white/6">
                                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                    </svg>
                                    <span>Contexte technique</span>
                                    <svg id="stackChevron" class="w-3.5 h-3.5 ml-auto transition-transform" fill="none"
                                        viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M19 9l-7 7-7-7" />
                                    </svg>
                                </button>
                                <div id="stackBody" class="hidden bg-rose-500/5 border-t border-rose-500/20">
                                    <pre id="modalStack"
                                        class="p-5 text-[10.5px] text-rose-300 font-mono overflow-x-auto leading-relaxed max-h-40"></pre>
                                </div>
                            </div>

                            <!-- Footer Resolve -->
                            <div class="p-5 pt-2">
                                <button onclick="quickResolve()" id="modalResolveBtn"
                                    class="w-full flex items-center justify-center gap-2 bg-emerald-600/20 hover:bg-emerald-600 text-emerald-400 hover:text-white border border-emerald-500/20 py-2.5 rounded-xl text-[12px] font-bold transition-all">
                                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                            d="M5 13l4 4L19 7" />
                                    </svg>
                                    Marquer comme résolu
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- 
  Delete legacy resolve form 
  <form id="resolveForm"...> 
  <textarea name="message"...> (replaced by new input style)
-->
            </div>
            </div>
            </div>

            <style>
                .filter-btn {
                    transition: border-color .15s, box-shadow .15s;
                }

                .filter-btn.active-filter {
                    border-color: rgb(139 92 246 / .4) !important;
                    box-shadow: 0 0 0 1px rgb(139 92 246 / .15);
                }

                .ticket-card[data-filtered="true"] {
                    display: none;
                }
            </style>

            <script nonce="<%= cspNonce %>">
                const rawData = '<%- Buffer.from(JSON.stringify(bugReports || [])).toString("base64") %>';
                const bugReportsData = JSON.parse(atob(rawData));

                // Inject admin info from server
                const currentAdminName = '<%= (typeof adminName !== "undefined" ? adminName : user.userName) %>';
                const currentAdminAvatar = '<%= (typeof adminAvatar !== "undefined" ? adminAvatar : user.image) %>';

                let openTicketIndex = -1;
                let selectedStatus = '';
                let currentSocket = null;

                /* ── Filter ───────────────────────────────────── */
                function setFilter(status) {
                    document.querySelectorAll('.filter-btn').forEach(btn => {
                        btn.classList.toggle('active-filter', btn.dataset.filter === status);
                    });
                    let visibleCount = 0;
                    document.querySelectorAll('.ticket-card').forEach(card => {
                        const show = status === 'all' || card.dataset.status === status;
                        card.style.display = show ? '' : 'none';
                        if (show) visibleCount++;
                    });
                    const empty = document.getElementById('emptyFilter');
                    empty.style.display = visibleCount === 0 ? 'flex' : 'none';
                }

                /* ── Thread renderer ──────────────────────────── */
                function renderThread(thread) {
                    const container = document.getElementById('modalThread');
                    while (container.firstChild) {
                        container.removeChild(container.firstChild)
                    }
                    if (!thread || thread.length === 0) {
                        container.innerHTML = '<p class="text-slate-600 text-sm italic text-center py-8">Aucun message.</p>';
                        return;
                    }
                    thread.forEach(msg => {
                        const isAdmin = msg.from === 'admin';
                        const row = document.createElement('div');
                        row.className = 'flex gap-3 ' + (isAdmin ? 'flex-row-reverse' : '');

                        // Avatar
                        const avatar = document.createElement('div');
                        avatar.className = 'shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-[9px] font-black uppercase overflow-hidden ' +
                            (isAdmin ? 'bg-violet-600/20 text-violet-400 border border-violet-500/30' : 'bg-slate-800 text-slate-400 border border-white/5');

                        const avatarImg = (isAdmin && !msg.image) ? currentAdminAvatar : msg.image;
                        if (avatarImg) {
                            avatar.innerHTML = `<img src="${avatarImg}" class="w-full h-full object-cover">`;
                        } else {
                            avatar.textContent = (isAdmin ? (msg.userName || 'ADM') : (msg.userName || 'USR')).substring(0, 2);
                        }

                        const col = document.createElement('div');
                        col.className = 'flex flex-col gap-1 max-w-[85%] ' + (isAdmin ? 'items-end' : 'items-start');

                        // Name
                        const name = document.createElement('div');
                        name.className = 'text-[10px] font-bold text-slate-500 px-1 mb-0.5';
                        name.textContent = isAdmin ? (msg.userName === 'Admin' ? currentAdminName : msg.userName) : msg.userName;

                        const bubble = document.createElement('div');
                        bubble.className = 'px-4 py-2.5 rounded-2xl text-[13px] leading-relaxed markdown-content ' +
                            (isAdmin
                                ? 'bg-violet-600/30 border border-violet-500/30 text-white rounded-tr-sm'
                                : 'bg-slate-800 border border-white/10 text-slate-200 rounded-tl-sm');

                        // Use marked to parse markdown
                        bubble.innerHTML = marked.parse(msg.message);

                        const meta = document.createElement('div');
                        meta.className = 'text-[9px] text-slate-600 font-mono px-1 flex items-center gap-2';
                        meta.textContent = new Date(msg.createdAt).toLocaleString('fr-FR', { dateStyle: 'short', timeStyle: 'short' });

                        col.appendChild(name);
                        col.appendChild(bubble);
                        col.appendChild(meta);
                        row.appendChild(avatar);
                        row.appendChild(col);
                        container.appendChild(row);
                    });
                    requestAnimationFrame(() => { container.scrollTop = container.scrollHeight; });
                }

                /* ── Actions ─────────────────────────────── */
                async function updateTicketOption(key, val) {
                    if (key === 'status') {
                        selectedStatus = val;
                        const ticket = bugReportsData[openTicketIndex];
                        if (!ticket) return;

                        try {
                            const resp = await fetch(`/admin/bug-reports/${ticket.id}/resolve`, {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/x-www-form-urlencoded',
                                    'Accept': 'application/json'
                                },
                                body: `status=${val}`
                            });
                            if (resp.ok) {
                                ticket.status = val;
                                // Mettre à jour la liste à gauche et ré-ouvrir le détail
                                document.querySelector(`[onclick="openDetails(${openTicketIndex})"] .status-dot`)?.classList.replace(
                                    document.querySelector(`[onclick="openDetails(${openTicketIndex})"] .status-dot`).classList[1],
                                    val === 'RESOLVED' ? 'bg-emerald-400' : val === 'IN_PROGRESS' ? 'bg-blue-400' : 'bg-amber-400'
                                );
                                openDetails(openTicketIndex);
                            }
                        } catch (e) {
                            console.error('Failed to update status', e);
                        }
                    }
                }

                async function sendChatResponse() {
                    const input = document.getElementById('chatInput');
                    const message = input.value.trim();
                    if (!message) return;

                    const ticket = bugReportsData[openTicketIndex];
                    if (!ticket) return;

                    const formData = new FormData();
                    formData.append('message', message);
                    formData.append('status', selectedStatus || ticket.status);
                    formData.append('level', 'info');

                    // Send via AJAX
                    try {
                        const resp = await fetch(`/admin/bug-reports/${ticket.id}/respond`, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded',
                                'Accept': 'application/json'
                            },
                            body: new URLSearchParams(formData)
                        });
                        if (resp.ok) {
                            input.value = '';
                            input.style.height = 'auto';
                            // Success - the WebSocket will handle the UI update
                        } else {
                            alert('Erreur lors de l\'envoi');
                        }
                    } catch (e) {
                        alert('Erreur lors de l\'envoi');
                    }
                }

                async function quickResolve() {
                    const ticket = bugReportsData[openTicketIndex];
                    if (!ticket) return;
                    try {
                        const resp = await fetch(`/admin/bug-reports/${ticket.id}/resolve`, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded',
                                'Accept': 'application/json'
                            },
                            body: 'status=RESOLVED'
                        });
                        if (resp.ok) {
                            // Update local data
                            ticket.status = 'RESOLVED';
                            const statusRadio = document.querySelector(`input[name="ticketStatus"][value="RESOLVED"]`);
                            if (statusRadio) statusRadio.checked = true;
                            openDetails(openTicketIndex); // Re-render
                        }
                    } catch (e) { alert('Erreur'); }
                }

                /* ── UI Helpers ─────────────────────────────── */
                function toggleStack() {
                    const body = document.getElementById('stackBody');
                    const chevron = document.getElementById('stackChevron');
                    const hidden = body.classList.toggle('hidden');
                    chevron.style.transform = hidden ? '' : 'rotate(180deg)';
                }

                function toggleEmojiPicker() {
                    const picker = document.getElementById('emojiPicker');
                    const hidden = picker.classList.toggle('hidden');
                    if (!hidden) {
                        document.getElementById('imageGallery').classList.add('hidden');
                        if (!document.getElementById('emojiGrid').children.length) setEmojiCat('faces');
                    }
                }

                function setEmojiCat(cat) {
                    const grid = document.getElementById('emojiGrid');
                    while (grid.firstChild) {
                        grid.removeChild(grid.firstChild)
                    }
                    const emojis = {
                        faces: ['😀', '😃', '😄', '😁', '😆', '😅', '😂', '🤣', '😊', '😇', '🙂', '🙃', '😉', '😌', '😍', '🥰', '😘', '😗', '😙', '😚', '😋', '😛', '😝', '😜', '🤪', '🤨', '🧐', '🤓', '😎', '🤩', '🥳', '😏', '😒', '😞', '😔', '😟', '😕', '🙁', '☹️', '😣', '😖', '😫', '😩', '🥺', '😢', '😭', '😤', '😠', '😡', '🤬', '🤯', '😳', '🥵', '🥶', '😱', '😨', '😰', '😥', '😓', '🤗', '🤔', '🤭', '🤫', '🤥', '😶', '😐', '😑', '😬', '🙄', '😯', '😦', '😧', '😮', '😲', '🥱', '😴', '🤤', '😪', '😵', '🤐', '🥴', '🤢', '🤮', '🤧', '🧐'],
                        objects: ['⌚', '📱', '💻', '⌨️', '🖥️', '🖨️', '🖱️', '🖱', '🖲️', '🕹️', '🗜️', '💽', '💾', '💿', '📀', '📼', '📷', '📸', '📹', '🎥', '📽️', '🎞️', '📞', '☎️', '📟', '📠', '📺', '📻', '🎙️', '🎚️', '🎛️', '🧭', '⏱️', '⏲️', '⏰', '🕰️', '⌛', '⏳'],
                        symbols: ['❤️', '🧡', '💛', '💚', '💙', '💜', '🖤', '🤍', '🤎', '💔', '❣️', '💕', '💞', '💓', '💗', '💖', '💘', '💝', '💟']
                    };
                    emojis[cat].forEach(e => {
                        const btn = document.createElement('button');
                        btn.className = 'text-xl p-1 hover:bg-white/10 rounded-lg transition-all';
                        btn.textContent = e;
                        btn.onclick = () => {
                            document.getElementById('chatInput').value += e;
                            document.getElementById('emojiPicker').classList.add('hidden');
                        };
                        grid.appendChild(btn);
                    });
                }

                async function toggleGallery() {
                    const gallery = document.getElementById('imageGallery');
                    const hidden = gallery.classList.toggle('hidden');
                    if (!hidden) {
                        const grid = document.getElementById('galleryGrid');
                        grid.innerHTML = '<div class="col-span-3 py-10 text-center text-slate-600 text-[10px]">Chargement...</div>';
                        try {
                            const resp = await fetch('/api/me/uploads');
                            const { uploads } = await resp.json();
                            while (grid.firstChild) {
                                grid.removeChild(grid.firstChild)
                            }
                            uploads.forEach(u => {
                                if (u.url.match(/\.(jpg|jpeg|png|webp|gif|svg)$/i)) {
                                    const img = document.createElement('img');
                                    img.src = u.url;
                                    img.className = 'w-full aspect-square object-cover rounded-lg border border-white/5 hover:border-violet-500 cursor-pointer transition-all';
                                    img.onclick = () => {
                                        document.getElementById('chatInput').value += `![image](${u.url})`;
                                        gallery.classList.add('hidden');
                                    };
                                    grid.appendChild(img);
                                }
                            });
                        } catch (e) { grid.innerHTML = '<div class="col-span-3 text-rose-500 text-[10px]">Erreur de chargement.</div>'; }
                    }
                }

                /* ── File Upload ────────────────────────────── */
                document.getElementById('bugAttachmentInput').onchange = async function () {
                    const file = this.files[0];
                    if (!file) return;
                    const btn = document.querySelector('button[onclick*="bugAttachmentInput"]');
                    const originalIcon = btn.innerHTML;
                    btn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';

                    const fd = new FormData();
                    fd.append('file', file);
                    try {
                        const resp = await fetch('/api/me/upload?field=misc', { method: 'POST', body: fd });
                        const data = await resp.json();
                        if (data.url) {
                            const input = document.getElementById('chatInput');
                            input.value += (file.type.startsWith('image/') ? `\n![file](${data.url})` : `\n[Fichier joint](${data.url})`);
                        }
                    } catch (e) { alert('Upload échoué'); }
                    btn.innerHTML = originalIcon;
                };

                /* ── Modal Control ────────────────────────────── */
                function openDetails(index) {
                    openTicketIndex = index;
                    const r = bugReportsData[index];
                    if (!r) return;

                    // Sync Sidebar
                    const statusRadio = document.querySelector(`input[name="ticketStatus"][value="${r.status}"]`);
                    if (statusRadio) statusRadio.checked = true;
                    selectedStatus = r.status;

                    document.getElementById('modalIdDisplay').textContent = '#' + r.id;
                    document.getElementById('modalUserChip').textContent = r.user ? r.user.userName + ' · ' + r.user.email : 'Anonyme';
                    document.getElementById('modalDate').textContent = new Date(r.createdAt).toLocaleString('fr-FR', { dateStyle: 'full', timeStyle: 'short' });

                    const userLink = document.getElementById('modalUserLink');
                    if (r.user) {
                        userLink.href = '/dashboard/admin/users?search=' + encodeURIComponent(r.user.email);
                        document.getElementById('modalUserLinkContainer').classList.remove('hidden');
                    } else {
                        document.getElementById('modalUserLinkContainer').classList.add('hidden');
                    }

                    renderThread(r.thread || []);

                    if (r.stack) {
                        document.getElementById('modalStack').textContent = r.stack;
                        document.getElementById('modalStackContainer').classList.remove('hidden');
                    } else {
                        document.getElementById('modalStackContainer').classList.add('hidden');
                    }

                    const urlEl = document.getElementById('modalUrl');
                    urlEl.textContent = r.url || '—';
                    urlEl.onclick = () => { if (r.url) window.open(r.url, '_blank'); };

                    const browserContainer = document.getElementById('modalBrowserContainer');
                    const browserEl = document.getElementById('modalBrowser');
                    while (browserEl.firstChild) {
                        browserEl.removeChild(browserEl.firstChild)
                    }
                    if (r.browser && typeof r.browser === 'object') {
                        browserContainer.classList.remove('hidden');
                        [['OS', r.browser.platform], ['Écran', r.browser.screen], ['Viewport', r.browser.viewport]].forEach(([l, v]) => {
                            const d = document.createElement('div');
                            d.className = 'flex items-center justify-between text-[10px] py-1 border-b border-white/4 last:border-0';
                            d.innerHTML = `<span class="text-slate-600">${l}</span><span class="text-slate-400 font-mono">${v || '—'}</span>`;
                            browserEl.appendChild(d);
                        });
                    } else { browserContainer.classList.add('hidden'); }

                    const resolveBtn = document.getElementById('modalResolveBtn');
                    if (r.status === 'RESOLVED') {
                        resolveBtn.classList.add('opacity-40', 'pointer-events-none');
                        resolveBtn.textContent = 'Ticket résolu';
                    } else {
                        resolveBtn.classList.remove('opacity-40', 'pointer-events-none');
                        resolveBtn.innerHTML = `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg> Marquer comme résolu`;
                    }

                    document.getElementById('detailsModal').classList.replace('hidden', 'flex');

                    // WebSocket setup
                    if (currentSocket) currentSocket.close();

                    const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
                    currentSocket = new WebSocket(`${protocol}//${window.location.host}/admin/bug-reports/${r.id}/ws`);

                    currentSocket.onmessage = (event) => {
                        const payload = JSON.parse(event.data);
                        if (payload.type === 'message') {
                            const newMsg = payload.data;
                            if (!r.thread) r.thread = [];
                            // Check if already exists (avoid duplicates if optimistic UI is added later)
                            if (!r.thread.find(m => m.id === newMsg.id)) {
                                r.thread.push(newMsg);
                                renderThread(r.thread);
                            }
                        }
                    };

                    currentSocket.onclose = () => { currentSocket = null; };
                }

                function closeModal() {
                    if (currentSocket) {
                        currentSocket.close();
                        currentSocket = null;
                    }
                    document.getElementById('detailsModal').classList.replace('flex', 'hidden');
                    document.getElementById('emojiPicker').classList.add('hidden');
                    document.getElementById('imageGallery').classList.add('hidden');
                }

                // Auto-resize search input
                document.getElementById('chatInput').addEventListener('input', function () {
                    this.style.height = 'auto';
                    this.style.height = (this.scrollHeight) + 'px';
                });

                document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

                // Handle click outside to close popups
                document.addEventListener('mousedown', (e) => {
                    const picker = document.getElementById('emojiPicker');
                    const gallery = document.getElementById('imageGallery');
                    const emojiBtn = document.getElementById('emojiBtn');
                    const galleryBtn = document.querySelector('button[onclick*="toggleGallery"]');

                    if (!picker.classList.contains('hidden')) {
                        if (!picker.contains(e.target) && !emojiBtn.contains(e.target)) {
                            picker.classList.add('hidden');
                        }
                    }
                    if (!gallery.classList.contains('hidden')) {
                        if (!gallery.contains(e.target) && !galleryBtn.contains(e.target)) {
                            gallery.classList.add('hidden');
                        }
                    }
                });
            </script>

            <style>
                .markdown-content p {
                    margin-bottom: 0.5rem;
                }

                .markdown-content p:last-child {
                    margin-bottom: 0;
                }

                .markdown-content img {
                    max-width: 200px;
                    border-radius: 0.5rem;
                    margin: 0.5rem 0;
                    display: block;
                }

                .markdown-content a {
                    color: #8b5cf6;
                    text-decoration: underline;
                }

                .markdown-content code {
                    background: rgba(0, 0, 0, 0.3);
                    padding: 0.1rem 0.3rem;
                    border-radius: 0.25rem;
                    font-family: monospace;
                }
            </style>