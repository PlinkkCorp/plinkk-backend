<%- include('partials/head', {
  title: 'Fonctionnalités',
  description: 'Découvrez toutes les fonctionnalités de Plinkk : pages personnalisables, thèmes illimités, analytics avancés, liens intelligents, domaines personnalisés, SEO optimisé et bien plus.',
  metaKeywords: 'fonctionnalités Plinkk, thèmes personnalisés, analytics, liens intelligents, SEO, domaines personnalisés, QR codes, open source',
  metaAuthor: 'Équipe Plinkk',
  pageThemeColor: 'info',
  canonical: 'https://plinkk.fr/features',
  image: 'https://cdn.plinkk.fr/og-image-features.png',
  robots: 'index,follow',
  extraHead: `
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Fonctionnalités Plinkk",
      "description": "Découvrez toutes les fonctionnalités de Plinkk pour créer votre page de liens parfaite.",
      "url": "https://plinkk.fr/features",
      "mainEntity": {
        "@type": "ItemList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "Thèmes personnalisables"},
          {"@type": "ListItem", "position": 2, "name": "Analytics intégrés"},
          {"@type": "ListItem", "position": 3, "name": "SEO optimisé"},
          {"@type": "ListItem", "position": 4, "name": "Liens intelligents"},
          {"@type": "ListItem", "position": 5, "name": "Domaines personnalisés"}
        ]
      }
    }
    </script>
  `
}) %>
<%- include('partials/header', { user: (typeof user !=='undefined' ? user : null) }) %>

<style>
  .feat-reveal{opacity:0;transform:translateY(32px);transition:opacity .7s cubic-bezier(.16,1,.3,1),transform .7s cubic-bezier(.16,1,.3,1)}
  .feat-reveal.visible{opacity:1;transform:none}
  .feat-card{transition:transform .25s ease,border-color .25s ease,box-shadow .25s ease}
  .feat-card:hover{transform:translateY(-4px);box-shadow:0 8px 32px -8px rgba(139,92,246,.15)}
  .section-badge{display:inline-flex;align-items:center;gap:.375rem;font-size:.75rem;font-weight:600;letter-spacing:.05em;text-transform:uppercase;padding:.25rem .75rem;border-radius:9999px}
  .feat-icon{width:2.5rem;height:2.5rem;display:flex;align-items:center;justify-content:center;border-radius:.75rem;flex-shrink:0;transition:background .2s}
  .premium-tag{font-size:.625rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:.125rem .5rem;border-radius:9999px;background:linear-gradient(135deg,#a78bfa,#f472b6);color:#fff}
</style>

<main class="relative isolate overflow-hidden min-h-screen">
  <!-- Background Effects -->
  <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
    <div class="absolute left-[50%] top-0 -translate-x-1/2 blur-3xl opacity-20" aria-hidden="true">
      <div class="aspect-[1155/678] w-[72.1875rem] bg-gradient-to-tr from-[#7c3aed] to-[#06b6d4]"
        style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)">
      </div>
    </div>
    <div class="absolute right-0 bottom-0 blur-3xl opacity-10" aria-hidden="true">
      <div class="aspect-[1155/678] w-[50rem] bg-gradient-to-bl from-[#f472b6] to-[#7c3aed]"
        style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)">
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8 py-24 sm:py-32">

    <!-- Hero -->
    <div class="mx-auto max-w-3xl text-center feat-reveal">
      <span class="section-badge bg-violet-500/10 text-violet-400 ring-1 ring-inset ring-violet-500/20 mb-6">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456Z"/></svg>
        Toutes les fonctionnalités
      </span>
      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl bg-clip-text text-transparent bg-gradient-to-r from-white via-slate-200 to-slate-400">
        Tout ce dont vous avez besoin,<br>en une seule plateforme.
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-400 max-w-2xl mx-auto">
        De la personnalisation avancée aux analytics en temps réel, Plinkk vous offre un outil complet pour créer des pages de liens uniques et performantes.
      </p>
      <div class="mt-8 flex items-center justify-center gap-4">
        <a href="<%= dashboardUrl %>/login#signup" class="rounded-xl bg-violet-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-violet-500/25 hover:bg-violet-500 transition-all hover:scale-105 hover:shadow-violet-500/40">
          Commencer gratuitement
        </a>
        <a href="/pricing" class="rounded-xl bg-white/5 px-6 py-3 text-sm font-semibold text-slate-300 ring-1 ring-inset ring-white/10 hover:bg-white/10 hover:text-white transition-all">
          Voir les tarifs
        </a>
      </div>
    </div>


    <!-- ===================== SECTION 1 : Profils & Pages ===================== -->
    <section class="mt-32 feat-reveal">
      <div class="flex flex-col items-center text-center mb-12">
        <span class="section-badge bg-indigo-500/10 text-indigo-400 ring-1 ring-inset ring-indigo-500/20 mb-4">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
          Profils & Pages
        </span>
        <h2 class="text-3xl font-bold text-white sm:text-4xl">Votre page, votre identité</h2>
        <p class="mt-3 text-slate-400 max-w-xl">Créez des pages de liens uniques qui reflètent parfaitement votre image.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="feat-card rounded-2xl bg-slate-900/50 backdrop-blur-sm border border-white/5 hover:border-indigo-500/30 p-6">
          <div class="feat-icon bg-indigo-500/10">
            <svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-white">Multi-pages</h3>
          <p class="mt-1.5 text-xs text-slate-400 leading-relaxed">Créez plusieurs pages Plinkk : 1 en gratuit, 2 en Premium, et ajoutez-en plus à la carte.</p>
        </div>
        <div class="feat-card rounded-2xl bg-slate-900/50 backdrop-blur-sm border border-white/5 hover:border-indigo-500/30 p-6">
          <div class="feat-icon bg-indigo-500/10">
            <svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m9.86-2.032a4.5 4.5 0 0 0-1.242-7.244l4.5-4.5a4.5 4.5 0 0 1 6.364 6.364l-1.757 1.757"/></svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-white">Slug personnalisé</h3>
          <p class="mt-1.5 text-xs text-slate-400 leading-relaxed">Votre URL unique <code class="text-violet-400">plinkk.fr/votre-nom</code> avec validation intelligente.</p>
        </div>
        <div class="feat-card rounded-2xl bg-slate-900/50 backdrop-blur-sm border border-white/5 hover:border-indigo-500/30 p-6">
          <div class="feat-icon bg-indigo-500/10">
            <svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z"/></svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-white">Avatar & Bannière</h3>
          <p class="mt-1.5 text-xs text-slate-400 leading-relaxed">Photo de profil, icône, bannière image ou GIF animé. Support Gravatar intégré.</p>
        </div>
        <div class="feat-card rounded-2xl bg-slate-900/50 backdrop-blur-sm border border-white/5 hover:border-indigo-500/30 p-6">
          <div class="feat-icon bg-indigo-500/10">
            <svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88"/></svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-white">Visibilité</h3>
          <p class="mt-1.5 text-xs text-slate-400 leading-relaxed">Passez votre page en public ou privé en un clic. Page par défaut configurable.</p>
        </div>
        <div class="feat-card rounded-2xl bg-slate-900/50 backdrop-blur-sm border border-white/5 hover:border-indigo-500/30 p-6">
          <div class="flex items-center gap-2">
            <div class="feat-icon bg-indigo-500/10">
              <svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>
            </div>
            <span class="premium-tag">Premium</span>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-white">Page protégée par mot de passe</h3>
          <p class="mt-1.5 text-xs text-slate-400 leading-relaxed">Restreignez l'accès à votre page avec un mot de passe sécurisé.</p>
        </div>
        <div class="feat-card rounded-2xl bg-slate-900/50 backdrop-blur-sm border border-white/5 hover:border-indigo-500/30 p-6">
          <div class="feat-icon bg-indigo-500/10">
            <svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Zm6-10.125a1.875 1.875 0 1 1-3.75 0 1.875 1.875 0 0 1 3.75 0Zm-3.375 6.75h4.5a1.5 1.5 0 0 0 1.5-1.5 3 3 0 0 0-3-3h-1.5a3 3 0 0 0-3 3 1.5 1.5 0 0 0 1.5 1.5Z"/></svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-white">Profil complet</h3>
          <p class="mt-1.5 text-xs text-slate-400 leading-relaxed">Bio, email public, téléphone, texte de site, nom d'affichage personnalisable et barre de statut.</p>
        </div>
      </div>
    </section>


    <!-- ===================== SECTION 2 : Liens ===================== -->
    <section class="mt-28 feat-reveal">
      <div class="flex flex-col items-center text-center mb-12">
        <span class="section-badge bg-cyan-500/10 text-cyan-400 ring-1 ring-inset ring-cyan-500/20 mb-4">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m9.86-2.032a4.5 4.5 0 0 0-1.242-7.244l4.5-4.5a4.5 4.5 0 0 1 6.364 6.364l-1.757 1.757"/></svg>
          Gestion des liens
        </span>
        <h2 class="text-3xl font-bold text-white sm:text-4xl">Liens intelligents et puissants</h2>
        <p class="mt-3 text-slate-400 max-w-xl">Bien plus qu'un simple répertoire de liens : Smart Links, programmation, catégories et capture de leads.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="feat-card rounded-2xl bg-slate-900/50 backdrop-blur-sm border border-white/5 hover:border-cyan-500/30 p-6">
          <div class="feat-icon bg-cyan-500/10">
            <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m9.86-2.032a4.5 4.5 0 0 0-1.242-7.244l4.5-4.5a4.5 4.5 0 0 1 6.364 6.364l-1.757 1.757"/></svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-white">Liens personnalisables</h3>
          <p class="mt-1.5 text-xs text-slate-400 leading-relaxed">URL, titre, description, icône, miniature et sous-titre. Organisez avec des catégories visuelles.</p>
        </div>
        <div class="feat-card rounded-2xl bg-slate-900/50 backdrop-blur-sm border border-white/5 hover:border-cyan-500/30 p-6">
          <div class="feat-icon bg-cyan-500/10">
            <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-6.75 18h9"/></svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-white">Smart Links</h3>
          <p class="mt-1.5 text-xs text-slate-400 leading-relaxed">Redirigez automatiquement vers l'App Store ou le Play Store selon l'appareil du visiteur avec <code class="text-cyan-400">iosUrl</code> et <code class="text-cyan-400">androidUrl</code>.</p>
        </div>
        <div class="feat-card rounded-2xl bg-slate-900/50 backdrop-blur-sm border border-white/5 hover:border-cyan-500/30 p-6">
          <div class="flex items-center gap-2">
            <div class="feat-icon bg-cyan-500/10">
              <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
            </div>
            <span class="premium-tag">Premium</span>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-white">Liens programmés</h3>
          <p class="mt-1.5 text-xs text-slate-400 leading-relaxed">Planifiez l'activation et l'expiration automatique de vos liens avec des dates précises.</p>
        </div>
        <div class="feat-card rounded-2xl bg-slate-900/50 backdrop-blur-sm border border-white/5 hover:border-cyan-500/30 p-6">
          <div class="feat-icon bg-cyan-500/10">
            <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z"/></svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-white">Labels & Badges</h3>
          <p class="mt-1.5 text-xs text-slate-400 leading-relaxed">Ajoutez des labels colorés et des badges personnalisés à vos liens pour les mettre en valeur.</p>
        </div>
        <div class="feat-card rounded-2xl bg-slate-900/50 backdrop-blur-sm border border-white/5 hover:border-cyan-500/30 p-6">
          <div class="feat-icon bg-cyan-500/10">
            <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418"/></svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-white">Icônes sociales</h3>
          <p class="mt-1.5 text-xs text-slate-400 leading-relaxed">Affichez vos réseaux sociaux avec des icônes dédiées, ordonnables par glisser-déposer.</p>
        </div>
        <div class="feat-card rounded-2xl bg-slate-900/50 backdrop-blur-sm border border-white/5 hover:border-cyan-500/30 p-6">
          <div class="feat-icon bg-cyan-500/10">
            <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-white">Capture de leads</h3>
          <p class="mt-1.5 text-xs text-slate-400 leading-relaxed">Intégrez des formulaires dans vos liens et collectez les soumissions directement dans votre dashboard.</p>
        </div>
        <div class="feat-card rounded-2xl bg-slate-900/50 backdrop-blur-sm border border-white/5 hover:border-cyan-500/30 p-6">
          <div class="feat-icon bg-cyan-500/10">
            <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Zm6-10.125a1.875 1.875 0 1 1-3.75 0 1.875 1.875 0 0 1 3.75 0Zm-3.375 6.75h4.5a1.5 1.5 0 0 0 1.5-1.5 3 3 0 0 0-3-3h-1.5a3 3 0 0 0-3 3 1.5 1.5 0 0 0 1.5 1.5Z"/></svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-white">vCard</h3>
          <p class="mt-1.5 text-xs text-slate-400 leading-relaxed">Générez une carte de contact téléchargeable pour vos visiteurs en un clic.</p>
        </div>
