<%- include('partials/head', {
  title: 'Patch Notes - Plinkk',
  description: 'Découvrez toutes les mises à jour et améliorations de Plinkk'
}) %>
<%- include('partials/header') %>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      color: #333;
      position: relative;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: 
        radial-gradient(circle at 20% 50%, rgba(102, 126, 234, 0.1) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(118, 75, 162, 0.1) 0%, transparent 50%);
      pointer-events: none;
      z-index: -1;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 40px 20px;
    }

    header {
      text-align: center;
      color: white;
      margin-bottom: 60px;
      animation: fadeInDown 0.8s ease;
    }

    header h1 {
      font-size: 3.5rem;
      margin-bottom: 10px;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
    }

    header p {
      font-size: 1.1rem;
      opacity: 0.9;
    }

    .patchnotes-grid {
      display: grid;
      gap: 30px;
      animation: fadeInUp 0.8s ease;
    }

    .patchnote-card {
      background: white;
      border-radius: 12px;
      padding: 30px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      transition: all 0.3s ease;
      border-left: 5px solid #667eea;
    }

    .patchnote-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
    }

    .patchnote-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 15px;
    }

    .version-badge {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 6px 16px;
      border-radius: 20px;
      font-weight: bold;
      font-size: 0.9rem;
    }

    .patchnote-title {
      font-size: 1.8rem;
      color: #333;
      margin-bottom: 10px;
    }

    .patchnote-date {
      color: #999;
      font-size: 0.9rem;
      display: block;
      margin-bottom: 20px;
    }

    .patchnote-content {
      color: #666;
      line-height: 1.8;
      font-size: 0.95rem;
    }

    /* Markdown styling */
    .patchnote-content h2,
    .patchnote-content h3 {
      color: #333;
      margin-top: 20px;
      margin-bottom: 10px;
    }

    .patchnote-content h2 {
      font-size: 1.4rem;
    }

    .patchnote-content h3 {
      font-size: 1.1rem;
    }

    .patchnote-content ul,
    .patchnote-content ol {
      margin-left: 20px;
      margin-bottom: 10px;
    }

    .patchnote-content li {
      margin-bottom: 8px;
    }

    .patchnote-content code {
      background: #f5f5f5;
      padding: 2px 6px;
      border-radius: 4px;
      font-family: 'Courier New', monospace;
      color: #d63384;
    }

    .patchnote-content pre {
      background: #f5f5f5;
      padding: 15px;
      border-radius: 8px;
      overflow-x: auto;
      margin: 15px 0;
    }

    .patchnote-content pre code {
      background: none;
      padding: 0;
      color: #333;
    }

    .patchnote-content blockquote {
      border-left: 4px solid #667eea;
      padding-left: 15px;
      margin: 15px 0;
      color: #666;
      font-style: italic;
    }

    .empty-state {
      text-align: center;
      color: white;
      padding: 60px 20px;
    }

    .empty-state h2 {
      font-size: 2rem;
      margin-bottom: 10px;
    }

    @keyframes fadeInDown {
      from {
        opacity: 0;
        transform: translateY(-20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 768px) {
      header h1 {
        font-size: 2rem;
      }

      .patchnote-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .version-badge {
        margin-top: 10px;
      }

      .patchnote-card {
        padding: 20px;
      }
    }
  </style>

<main class="min-h-screen">
  <div class="container">
    <header>
      <h1>
        <svg class="inline-block w-8 h-8 mr-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #667eea;">
          <rect x="8" y="2" width="8" height="4" rx="1"/>
          <path d="M16 4h1a3 3 0 0 1 3 3v12a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3V7a3 3 0 0 1 3-3h1"/>
        </svg>
        Patch Notes
      </h1>
      <p>Toutes les mises à jour et améliorations de Plinkk</p>
    </header>

    <div class="patchnotes-grid">
      <% if (patchNotes && patchNotes.length > 0) { %>
        <% patchNotes.forEach((note) => { %>
          <div class="patchnote-card">
            <div class="patchnote-header">
              <h2 class="patchnote-title"><%= note.title %></h2>
              <span class="version-badge">v<%= note.version %></span>
            </div>
            <% if (note.publishedAt) { %>
              <span class="patchnote-date">
                Publié le <%= new Date(note.publishedAt).toLocaleDateString('fr-FR', { 
                  year: 'numeric', 
                  month: 'long', 
                  day: 'numeric' 
                }) %>
              </span>
            <% } %>
            <div class="patchnote-content markdown-content" data-content="<%= note.content.replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;') %>">
              <!-- Contenu rendu par JavaScript -->
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="empty-state">
          <h2>Aucune patch note pour le moment</h2>
          <p>Les mises à jour seront affichées ici dès qu'elles seront disponibles.</p>
        </div>
      <% } %>
    </div>
  </div>
</main>

<script>
  // Rendre le Markdown côté client une fois que marked est chargé
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.markdown-content').forEach(el => {
      const content = el.getAttribute('data-content');
      if (content && window.marked) {
        el.innerHTML = window.marked(content);
      }
    });
  });
</script>

<%- include('partials/footer') %>
