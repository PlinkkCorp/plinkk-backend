{
  "name": "@plinkk/public",
  "version": "3.2.5",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "dev:tsx": "bun --watch src/server.ts",
    "init": "bun install && bun run prisma:init && bun run create-key && bun run dev",
    "create-key": "bunx @fastify/secure-session > src/secret-key",
    "build": "bun build:tsc && bun ../../scripts/copy-static.mjs",
    "build:tsc": "bunx tsc -p tsconfig.json",
    "start": "bun dist/server.js",
    "prisma:migratedev": "bunx prisma migrate dev --config=../../packages/prisma/prisma.config.ts --schema=../../packages/prisma/prisma/schema.prisma",
    "prisma:dev": "bunx prisma dev --config=../../packages/prisma/prisma.config.ts --schema=../../packages/prisma/prisma/schema.prisma",
    "prisma:studio": "bunx prisma studio --config=../../packages/prisma/prisma.config.ts --schema=../../packages/prisma/prisma/schema.prisma",
    "prisma:init": "bunx prisma migrate deploy --config=../../packages/prisma/prisma.config.ts --schema=../../packages/prisma/prisma/schema.prisma && bunx prisma generate --config=../../packages/prisma/prisma.config.ts --schema=../../packages/prisma/prisma/schema.prisma",
    "set-admin": "bun ../../scripts/set-admin.cjs",
    "migrate:plinkks": "bun ../../scripts/migrate-plinkks.cjs",
    "delete_inactive": "bun ../../scripts/delete_inactive_user.js",
    "seed:role": "bun prisma/seed.ts",
    "sri": "bun ../../scripts/compute-sri.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "bun@1.3.10",
  "dependencies": {
    "@fastify/compress": "^8.3.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/http-proxy": "^11.3.0",
    "@fastify/multipart": "^9.2.1",
    "@fastify/oauth2": "^8.1.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/secure-session": "^8.2.0",
    "@fastify/static": "^8.2.0",
    "@fastify/view": "^11.1.1",
    "@plinkk/prisma": "workspace:*",
    "@plinkk/shared": "workspace:*",
    "@prisma/client": "^7.3.0",
    "@types/archiver": "^6.0.3",
    "@types/uglify-js": "^3.17.5",
    "archiver": "^7.0.1",
    "canvas": "^3.2.0",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "fastify": "^5.6.1",
    "fastify-cli": "^7.4.0",
    "fastify-cron": "^1.4.0",
    "ioredis": "^5.10.1",
    "marked": "4.3.0",
    "nanoid": "^3.3.11",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "rimraf": "^5.0.10",
    "ts-node": "^10.9.2",
    "uglify-js": "^3.19.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ejs": "^3.1.5",
    "@types/node": "^24.7.0",
    "prisma": "^7.3.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}