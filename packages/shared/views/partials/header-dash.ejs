                                                                    function setBellUnread(unread) {
                                                                        if (inboxBellBadge) {
                                                                            inboxBellBadge.textContent = String(unread);
                                                                            inboxBellBadge.classList.toggle('hidden', unread <= 0);
                                                                        }

                                                                        if (inboxBellIcon) {
                                                                            if (unread > 0) {
                                                                                inboxBellIcon.setAttribute('fill', 'currentColor');
                                                                                inboxBellIcon.classList.remove('text-slate-300');
                                                                                inboxBellIcon.classList.add('text-violet-300');
                                                                            } else {
                                                                                inboxBellIcon.setAttribute('fill', 'none');
                                                                                inboxBellIcon.classList.remove('text-violet-300');
                                                                                inboxBellIcon.classList.add('text-slate-300');
                                                                            }
                                                                        }
                                                                    }

                                                                    async function refreshUnreadCount() {
                                                                        try {
                                                                            const res = await fetch('/api/me/inbox/unread-count', { credentials: 'same-origin' });
                                                                            if (!res.ok) throw new Error('unread_fetch_failed');
                                                                            const data = await res.json();
                                                                            setBellUnread(Number(data.unreadCount || 0));
                                                                        } catch (_) {
                                                                            const localUnread = inboxItems.filter(function (item) { return !item.isRead; }).length;
                                                                            setBellUnread(localUnread);
                                                                        }
                                                                    }

                                                                    function renderSkeletonRows(container, count) {
                                                                        if (!container) return;
                                                                        const rows = [];
                                                                        for (let i = 0; i < count; i += 1) {
                                                                            rows.push('' +
                                                                                '<div class="px-4 py-3 animate-pulse">' +
                                                                                '<div class="h-3 w-28 bg-slate-800 rounded mb-2"></div>' +
                                                                                '<div class="h-4 w-2/3 bg-slate-800 rounded mb-2"></div>' +
                                                                                '<div class="h-3 w-full bg-slate-800/80 rounded mb-1"></div>' +
                                                                                '<div class="h-3 w-4/5 bg-slate-800/60 rounded"></div>' +
                                                                                '</div>'
                                                                            );
                                                                        }
                                                                        container.innerHTML = rows.join('');
                                                                    }

                                                                    function renderInboxItem(item, compact) {
                                                                        const isRead = !!item.isRead;
                                                                        const isExpanded = !compact && fullExpandedIds.has(item.id);
                                                                        const isLoadingDetail = !compact && fullLoadingDetailIds.has(item.id);
                                                                        const previewText = item.previewText || item.text || '';
                                                                        const fullText = item.fullText || item.text || '';
                                                                        const contentHtml = item.type === 'patch-note'
                                                                            ? (isExpanded ? (item.htmlText || escapeHtml(fullText).replace(/\n/g, '<br>')) : escapeHtml(previewText).replace(/\n/g, '<br>'))
                                                                            : escapeHtml(formatMsgPreview(item.text || '')).replace(/\n/g, '<br>');
                                                                        const contentClass = item.type === 'patch-note' && isExpanded ? ' inbox-expand-open' : '';
                                                                        const when = new Date(item.createdAt).toLocaleString('fr-FR');
                                                                        const bugThreadBtn = item.type === 'bug-response' && item.threadId
                                                                            ? '<a href="/inbox" class="inbox-open-thread shrink-0 inline-flex items-center gap-1 text-[10px] font-semibold text-violet-300 hover:text-violet-200 bg-violet-500/10 hover:bg-violet-500/20 border border-violet-500/25 px-2 py-0.5 rounded-full transition-all" data-thread-id="' + item.threadId + '">Ouvrir le ticket →</a>'
                                                                            : '';
                                                                        let expandBtn = '';
                                                                        if (!compact) {
                                                                            if (item.type === 'patch-note') {
                                                                                const baseUrl = "<%= typeof frontendUrl !== 'undefined' ? frontendUrl : '' %>".replace(/\/$/, '');
                                                                                let href = item.link || '/patch-notes';
                                                                                if (href.startsWith('/')) href = baseUrl + href;
                                                                                expandBtn = '<a href="' + href + '" class="inbox-see-more-link shrink-0 text-[10px] text-sky-300 hover:text-sky-200">Voir plus</a>';
                                                                            } else {
                                                                                expandBtn = '<button class="inbox-see-more shrink-0 text-[10px] ' + (isExpanded ? 'text-slate-400' : 'text-sky-300 hover:text-sky-200') + '" data-inbox-id="' + item.id + '">' + (isExpanded ? 'Réduire' : (isLoadingDetail ? 'Chargement...' : 'Voir plus')) + '</button>';
                                                                            }
                                                                        }
                                                                        const wrapperPad = compact ? 'px-4 py-3' : 'px-5 py-4';

                                                                        return '' +
                                                                            '<div class="' + wrapperPad + ' ' + (isRead ? 'opacity-60' : '') + '" data-inbox-id="' + item.id + '">' +
                                                                            '<div class="flex items-start justify-between gap-2">' +
                                                                            '<div class="min-w-0 flex-1">' +
                                                                            '<div class="flex items-center gap-2 mb-1 flex-wrap">' +
                                                                            '<span class="text-[10px] uppercase tracking-wider font-bold text-slate-400">' + item.type + '</span>' +
                                                                            '<span class="text-[10px] text-slate-500">' + when + '</span>' +
                                                                            '</div>' +
                                                                            '<p class="text-xs font-semibold text-white truncate">' + escapeHtml(String(item.title || '')) + '</p>' +
                                                                            '<div class="text-xs text-slate-300 mt-1 inbox-md' + contentClass + '">' + contentHtml + '</div>' +
                                                                            '</div>' +
                                                                            '<div class="flex flex-col items-end gap-1">' +
                                                                            bugThreadBtn +
                                                                            expandBtn +
                                                                            '<div class="flex items-center gap-2 mt-1">' +
                                                                            (isRead
                                                                                ? '<button class="shrink-0 text-[10px] text-emerald-300 cursor-default" disabled>Marqué comme lu</button>'
                                                                                : '<button class="inbox-mark-read shrink-0 text-[10px] text-violet-300 hover:text-violet-200" data-inbox-id="' + item.id + '">Marquer comme lu</button>') +
                                                                            (inboxShowHiddenOnly
                                                                             ? '<button class="inbox-restore-item shrink-0 text-slate-500 hover:text-emerald-400" data-inbox-id="' + item.id + '" title="Restaurer la notification">' +
                                                                               '<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>' +
                                                                               '</button>'
                                                                             : '<button class="inbox-delete-item shrink-0 text-slate-500 hover:text-rose-400" data-inbox-id="' + item.id + '" title="Cacher la notification">' +
                                                                               '<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M10 11v6M14 11v6"/></svg>' +
                                                                               '</button>') +
                                                                            '</div>' +
                                                                            '</div>' +
                                                                            '</div>' +
                                                                            '</div>';
                                                                    }

                                                                    async function inboxMarkRead(itemId) {
                                                                        if (!itemId) return;
                                                                        try {
                                                                            const target = inboxItems.find(function (item) { return item.id === itemId; })
                                                                                || fullState.items.find(function (item) { return item.id === itemId; });
                                                                            await fetch('/api/me/inbox/' + encodeURIComponent(itemId) + '/read', {
                                                                                method: 'POST',
                                                                                headers: { 'Content-Type': 'application/json' },
                                                                                credentials: 'same-origin',
                                                                                body: JSON.stringify({ itemType: getReadType(target) })
                                                                            });
                                                                        } catch (_) { }
                                                                    }

                                                                    async function inboxMarkAllReadRemote() {
                                                                        try {
                                                                            await fetch('/api/me/inbox/read-all', {
                                                                                method: 'POST',
                                                                                credentials: 'same-origin'
                                                                            });
                                                                        } catch (_) { }
                                                                    }

                                                                    function inboxRender(items) {
                                                                        if (!inboxBellList) return;
                                                                        if (!items.length) {
                                                                            inboxBellList.innerHTML = '<div class="px-4 py-8 text-center text-sm text-slate-400">Aucune notification.</div>';
                                                                            return;
                                                                        }
                                                                        inboxBellList.innerHTML = items.map(function (item) {
                                                                            return renderInboxItem(item, true);
                                                                        }).join('');
                                                                    }

                                                                    function syncReadState(itemId) {
                                                                        inboxItems = inboxItems.map(function (item) {
                                                                            if (item.id === itemId) {
                                                                                item.isRead = true;
                                                                            }
                                                                            return item;
                                                                        });
                                                                        fullState.items = fullState.items.map(function (item) {
                                                                            if (item.id === itemId) {
                                                                                item.isRead = true;
                                                                            }
                                                                            return item;
                                                                        });
                                                                    }

                                                                    function renderFullFilterButtons(type) {
                                                                        if (!inboxFullFilters) return;
                                                                        inboxFullFilters.querySelectorAll('.inbox-full-filter').forEach(function (btn) {
                                                                            const btnType = btn.getAttribute('data-filter');
                                                                            if (btnType === type) {
                                                                                btn.classList.add('bg-violet-500/15', 'text-violet-300', 'border-violet-500/30');
                                                                                btn.classList.remove('bg-slate-800', 'text-slate-300', 'border-slate-700');
                                                                            } else {
                                                                                btn.classList.remove('bg-violet-500/15', 'text-violet-300', 'border-violet-500/30');
                                                                                btn.classList.add('bg-slate-800', 'text-slate-300', 'border-slate-700');
                                                                            }
                                                                        });
                                                                    }

                                                                    function renderFullItems(items, append) {
                                                                        if (!inboxFullList) return;
                                                                        if (!append) {
                                                                            inboxFullList.innerHTML = '';
                                                                        }
                                                                        if (!items.length && !append) {
                                                                            inboxFullList.innerHTML = '<div class="px-4 py-8 text-center text-sm text-slate-400">Aucune notification pour ce filtre.</div>';
                                                                            return;
                                                                        }
                                                                        inboxFullList.insertAdjacentHTML('beforeend', items.map(function (item) {
                                                                            return renderInboxItem(item, false);
                                                                        }).join(''));
                                                                    }

                                                                    function toggleFullLoading(visible) {
                                                                        if (!inboxFullLoading) return;
                                                                        inboxFullLoading.classList.toggle('hidden', !visible);
                                                                    }

                                                                    async function loadItemFullDetail(itemId) {
                                                                        if (!itemId || fullLoadingDetailIds.has(itemId)) return;
                                                                        const item = fullState.items.find(function (it) { return it.id === itemId; });
                                                                        if (!item) return;

                                                                        if (fullExpandedIds.has(itemId)) {
                                                                            fullExpandedIds.delete(itemId);
                                                                            renderFullItems(fullState.items, false);
                                                                            return;
                                                                        }

                                                                        if (item.type !== 'patch-note') {
                                                                            fullExpandedIds.add(itemId);
                                                                            renderFullItems(fullState.items, false);
                                                                            return;
                                                                        }

                                                                        fullLoadingDetailIds.add(itemId);
                                                                        renderFullItems(fullState.items, false);
                                                                        try {
                                                                            const res = await fetch('/api/me/inbox/' + encodeURIComponent(itemId) + '/detail', {
                                                                                credentials: 'same-origin'
                                                                            });
                                                                            if (!res.ok) throw new Error('detail_fetch_failed');
                                                                            const data = await res.json();
                                                                            const detailed = data && data.item ? data.item : null;
                                                                            if (detailed) {
                                                                                fullState.items = fullState.items.map(function (it) {
                                                                                    if (it.id !== itemId) return it;
                                                                                    return {
                                                                                        ...it,
                                                                                        previewText: it.previewText || it.text,
                                                                                        fullText: detailed.text || it.fullText || it.text,
                                                                                        htmlText: detailed.htmlText || it.htmlText
                                                                                    };
                                                                                });
                                                                            }
                                                                            fullExpandedIds.add(itemId);
                                                                        } catch (_) {
                                                                        } finally {
                                                                            fullLoadingDetailIds.delete(itemId);
                                                                            renderFullItems(fullState.items, false);
                                                                        }
                                                                    }

                                                                    async function inboxLoadBell() {
                                                                        if (!inboxBellList) return [];
                                                                        try {
                                                                            renderSkeletonRows(inboxBellList, 4);
                                                                            const res = await fetch('/api/me/inbox?page=1&limit=8&type=all&compact=1', { credentials: 'same-origin' });
                                                                            if (!res.ok) throw new Error('inbox_fetch_failed');
                                                                            const data = await res.json();
                                                                            const items = (Array.isArray(data.items) ? data.items : []).filter(function(item) { return !isInboxHidden(item.id); });
                                                                            inboxRender(items);
                                                                            refreshUnreadCount();
                                                                            return items;
                                                                        } catch (_) {
                                                                            inboxBellList.innerHTML = '<div class="px-4 py-8 text-center text-sm text-rose-300">Impossible de charger l\'inbox.</div>';
                                                                            return [];
                                                                        }
                                                                    }

                                                                    async function inboxLoadFull(reset) {
                                                                        if (!inboxFullList || fullState.loading) return;
                                                                        if (reset) {
                                                                            fullState.page = 1;
                                                                            fullState.hasMore = true;
                                                                            fullState.items = [];
                                                                            fullExpandedIds.clear();
                                                                            renderSkeletonRows(inboxFullList, 6);
                                                                        }
                                                                        if (!fullState.hasMore) return;

                                                                        fullState.loading = true;
                                                                        toggleFullLoading(true);
                                                                        try {
                                                                            const res = await fetch('/api/me/inbox?page=' + fullState.page + '&limit=' + fullState.limit + '&type=' + encodeURIComponent(fullState.type) + '&compact=1', {
                                                                                credentials: 'same-origin'
                                                                            });
                                                                            if (!res.ok) throw new Error('inbox_full_fetch_failed');
                                                                            const data = await res.json();
                                                                            const items = (Array.isArray(data.items) ? data.items : []).filter(function(item) { 
                                                                                return inboxShowHiddenOnly ? isInboxHidden(item.id) : !isInboxHidden(item.id); 
                                                                            });
                                                                            const pagination = data.pagination || {};

                                                                            fullState.items = reset ? items.slice() : fullState.items.concat(items);
                                                                            renderFullItems(items, !reset);

                                                                            fullState.hasMore = !!pagination.hasMore;
                                                                            if (fullState.hasMore) {
                                                                                fullState.page += 1;
                                                                            }
                                                                        } catch (_) {
                                                                            if (reset) {
                                                                                inboxFullList.innerHTML = '<div class="px-4 py-8 text-center text-sm text-rose-300">Impossible de charger l\'inbox.</div>';
                                                                            }
                                                                        } finally {
                                                                            fullState.loading = false;
                                                                            toggleFullLoading(false);
                                                                        }
                                                                    }

                                                                    function openFullModal() {
                                                                        if (!inboxFullModal) return;
                                                                        inboxFullModal.classList.remove('hidden');
                                                                        renderFullFilterButtons(fullState.type);
                                                                        inboxLoadFull(true);
                                                                    }

                                                                    function closeFullModal() {
                                                                        inboxFullModal && inboxFullModal.classList.add('hidden');
                                                                    }

                                                                    async function openBugThread(threadId) {
                                                                        if (!threadId || !inboxThreadModal || !inboxThreadMessages) return;
                                                                        activeThreadId = threadId;
                                                                        inboxThreadTitle && (inboxThreadTitle.textContent = 'Discussion bug #' + threadId);
                                                                        inboxThreadMessages.innerHTML = '<p class="text-sm text-slate-400">Chargement...</p>';
                                                                        inboxThreadModal.classList.remove('hidden');

                                                                        try {
                                                                            const res = await fetch('/api/bug-reports/mine', { credentials: 'same-origin' });
                                                                            if (!res.ok) throw new Error('thread_fetch_failed');
                                                                            const data = await res.json();
                                                                            const threads = Array.isArray(data.threads) ? data.threads : [];
                                                                            const thread = threads.find(function (t) { return String(t.id) === String(threadId); });
                                                                            if (!thread) {
                                                                                inboxThreadMessages.innerHTML = '<p class="text-sm text-rose-300">Thread introuvable.</p>';
                                                                                return;
                                                                            }

                                                                            const msgs = Array.isArray(thread.messages) ? thread.messages : [];
                                                                            inboxThreadMessages.innerHTML = msgs.map(function (m) {
                                                                                const isAdmin = m.from === 'admin';
                                                                                return '<div class="' + (isAdmin ? 'ml-6' : 'mr-6') + '">' +
                                                                                    '<div class="rounded-xl border ' + (isAdmin ? 'border-violet-500/20 bg-violet-500/10' : 'border-slate-700 bg-slate-900') + ' p-3">' +
                                                                                    '<p class="text-[10px] uppercase tracking-wide ' + (isAdmin ? 'text-violet-300' : 'text-slate-400') + '">' + (isAdmin ? 'admin' : 'vous') + '</p>' +
                                                                                    '<p class="text-sm text-slate-200 mt-1 whitespace-pre-wrap">' + escapeHtml(m.message || '') + '</p>' +
                                                                                    '<p class="text-[10px] text-slate-500 mt-2">' + new Date(m.createdAt).toLocaleString('fr-FR') + '</p>' +
                                                                                    '</div>' +
                                                                                    '</div>';
                                                                            }).join('');
                                                                        } catch (_) {
                                                                            inboxThreadMessages.innerHTML = '<p class="text-sm text-rose-300">Impossible de charger la discussion.</p>';
                                                                        }
                                                                    }

                                                                    if (inboxBellBtn && inboxBellPanel && inboxBellWrap) {
                                                                        inboxLoadBell().then(function (items) { inboxItems = items; });
                                                                        refreshUnreadCount();

                                                                        window.openHeaderInbox = function(e) {
                                                                            if (e) { e.preventDefault(); e.stopPropagation(); }
                                                                            if (typeof openFullModal === 'function') {
                                                                                openFullModal();
                                                                                const panel = document.getElementById('ticketWidgetPanel');
                                                                                if (panel) panel.classList.add('hidden');
                                                                            }
                                                                        };

                                                                        inboxBellBtn.addEventListener('click', function (e) {
                                                                            e.stopPropagation();
                                                                            const hidden = inboxBellPanel.classList.contains('hidden');
                                                                            inboxBellPanel.classList.toggle('hidden');
                                                                            inboxBellBtn.setAttribute('aria-expanded', hidden ? 'true' : 'false');
                                                                            if (hidden) {
                                                                                inboxLoadBell().then(function (items) { inboxItems = items; });
                                                                            }
                                                                        });

                                                                        document.addEventListener('click', function (e) {
                                                                            if (!inboxBellWrap.contains(e.target)) {
                                                                                inboxBellPanel.classList.add('hidden');
                                                                                inboxBellBtn.setAttribute('aria-expanded', 'false');
                                                                            }
                                                                        });

                                                                        inboxBellList && inboxBellList.addEventListener('click', function (e) {
                                                                            const btn = e.target.closest('.inbox-mark-read');
                                                                            if (btn) {
                                                                                e.preventDefault();
                                                                                e.stopPropagation();
                                                                                if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
                                                                                const id = btn.getAttribute('data-inbox-id');
                                                                                if (!id) return;
                                                                                const target = inboxItems.find(function (item) { return item.id === id; });
                                                                                if (!target) return;
                                                                                target.isRead = true;
                                                                                inboxMarkRead(id);
                                                                                inboxRender(inboxItems);
                                                                                refreshUnreadCount();
                                                                                return;
                                                                            }
                                                                            
                                                                            const deleteBtn = e.target.closest('.inbox-delete-item');
                                                                            if (deleteBtn) {
                                                                                e.preventDefault();
                                                                                e.stopPropagation();
                                                                                if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
                                                                                const id = deleteBtn.getAttribute('data-inbox-id');
                                                                                if (!id) return;
                                                                                hideInboxItem(id);
                                                                                const target = inboxItems.find(function (item) { return item.id === id; }) || fullState.items.find(function (item) { return item.id === id; });
                                                                                if (target && !target.isRead) {
                                                                                    target.isRead = true;
                                                                                    inboxMarkRead(id);
                                                                                }
                                                                                inboxItems = inboxItems.filter(function(item) { return item.id !== id; });
                                                                                fullState.items = fullState.items.filter(function(item) { return item.id !== id; });
                                                                                inboxRender(inboxItems);
                                                                                renderFullItems(fullState.items, false);
                                                                                refreshUnreadCount();
                                                                                return;
                                                                            }

                                                                            const threadBtn = e.target.closest('.inbox-open-thread');
                                                                            if (!threadBtn) return;
                                                                            const threadId = threadBtn.getAttribute('data-thread-id');
                                                                            if (!threadId) return;
                                                                            openBugThread(threadId);
                                                                        });

                                                                        inboxMarkAllRead && inboxMarkAllRead.addEventListener('click', function (e) {
                                                                            if (e) e.stopPropagation();
                                                                            inboxMarkAllReadRemote();
                                                                            inboxItems = inboxItems.map(function (item) {
                                                                                item.isRead = true;
                                                                                return item;
                                                                            });
                                                                            inboxRender(inboxItems);
                                                                            refreshUnreadCount();
                                                                        });

                                                                        inboxFullMarkAllReadBtn && inboxFullMarkAllReadBtn.addEventListener('click', function (e) {
                                                                            if (e) e.stopPropagation();
                                                                            inboxMarkAllReadRemote();
                                                                            inboxItems = inboxItems.map(function (item) { item.isRead = true; return item; });
                                                                            fullState.items = fullState.items.map(function (item) { item.isRead = true; return item; });
                                                                            inboxRender(inboxItems);
                                                                            renderFullItems(fullState.items, false);
                                                                            refreshUnreadCount();
                                                                        });

                                                                        inboxOpenFull && inboxOpenFull.addEventListener('click', function (e) {
                                                                            e.preventDefault();
                                                                            e.stopPropagation();
                                                                            openFullModal();
                                                                        });
                                                                    }

                                                                    if (inboxFullFilters) {
                                                                        inboxFullFilters.addEventListener('click', function (e) {
                                                                            const btn = e.target.closest('.inbox-full-filter');
                                                                            if (!btn) return;
                                                                            const type = btn.getAttribute('data-filter') || 'all';
                                                                            fullState.type = type;
                                                                            renderFullFilterButtons(type);
                                                                            inboxLoadFull(true);
                                                                        });
                                                                    }

                                                                    if (inboxFullList) {
                                                                        inboxFullList.addEventListener('click', function (e) {
                                                                            const expandBtn = e.target.closest('.inbox-see-more');
                                                                            if (expandBtn) {
                                                                                e.preventDefault();
                                                                                e.stopPropagation();
                                                                                const id = expandBtn.getAttribute('data-inbox-id');
                                                                                if (!id) return;
                                                                                loadItemFullDetail(id);
                                                                                return;
                                                                            }

                                                                            const btn = e.target.closest('.inbox-mark-read');
                                                                            if (btn) {
                                                                                e.preventDefault();
                                                                                e.stopPropagation();
                                                                                if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
                                                                                const id = btn.getAttribute('data-inbox-id');
                                                                                if (!id) return;
                                                                                syncReadState(id);
                                                                                inboxRender(inboxItems);
                                                                                renderFullItems(fullState.items, false);
                                                                                inboxMarkRead(id);
                                                                                refreshUnreadCount();
                                                                                return;
                                                                            }
                                                                            
                                                                            const deleteBtn = e.target.closest('.inbox-delete-item');
                                                                            if (deleteBtn) {
                                                                                e.preventDefault();
                                                                                e.stopPropagation();
                                                                                if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
                                                                                const id = deleteBtn.getAttribute('data-inbox-id');
                                                                                if (!id) return;
                                                                                hideInboxItem(id);
                                                                                const target = inboxItems.find(function (item) { return item.id === id; }) || fullState.items.find(function (item) { return item.id === id; });
                                                                                if (target && !target.isRead) {
                                                                                    target.isRead = true;
                                                                                    inboxMarkRead(id);
                                                                                }
                                                                                inboxItems = inboxItems.filter(function(item) { return item.id !== id; });
                                                                                fullState.items = fullState.items.filter(function(item) { return item.id !== id; });
                                                                                inboxRender(inboxItems);
                                                                                renderFullItems(fullState.items, false);
                                                                                refreshUnreadCount();
                                                                                return;
                                                                            }

                                                                            const restoreBtn = e.target.closest('.inbox-restore-item');
                                                                            if (restoreBtn) {
                                                                                e.preventDefault();
                                                                                e.stopPropagation();
                                                                                if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
                                                                                const id = restoreBtn.getAttribute('data-inbox-id');
                                                                                if (!id) return;
                                                                                
                                                                                const hidden = getHiddenInboxIds();
                                                                                const newHidden = hidden.filter(function(i) { return i !== id; });
                                                                                localStorage.setItem('plinkk_hidden_inbox_items', JSON.stringify(newHidden));
                                                                                
                                                                                inboxItems = inboxItems.filter(function(item) { return item.id !== id; });
                                                                                fullState.items = fullState.items.filter(function(item) { return item.id !== id; });
                                                                                inboxRender(inboxItems);
                                                                                renderFullItems(fullState.items, false);
                                                                                refreshUnreadCount();
                                                                                return;
                                                                            }

                                                                            const threadBtn = e.target.closest('.inbox-open-thread');
                                                                            if (!threadBtn) return;
                                                                            const threadId = threadBtn.getAttribute('data-thread-id');
                                                                            if (!threadId) return;
                                                                            openBugThread(threadId);
                                                                        });
                                                                    }

                                                                    if (inboxFullSentinel && 'IntersectionObserver' in window) {
                                                                        inboxFullObserver = new IntersectionObserver(function (entries) {
                                                                            entries.forEach(function (entry) {
                                                                                if (entry.isIntersecting && !fullState.loading && fullState.hasMore && inboxFullModal && !inboxFullModal.classList.contains('hidden')) {
                                                                                    inboxLoadFull(false);
                                                                                }
                                                                            });
                                                                        }, { root: null, rootMargin: '200px', threshold: 0.01 });
                                                                        inboxFullObserver.observe(inboxFullSentinel);
                                                                    }

                                                                    inboxFullBackdrop && inboxFullBackdrop.addEventListener('click', closeFullModal);
                                                                    inboxFullClose && inboxFullClose.addEventListener('click', closeFullModal);
                                                                    document.addEventListener('keydown', function (e) {
                                                                        if (e.key === 'Escape') {
                                                                            closeFullModal();
                                                                        }
                                                                    });
                                                                    
                                                                    const toggleHiddenBtn = document.getElementById('inboxFullToggleHiddenBtn');
                                                                    if (toggleHiddenBtn) {
                                                                        toggleHiddenBtn.addEventListener('click', function(e) {
                                                                            e.preventDefault();
                                                                            inboxShowHiddenOnly = !inboxShowHiddenOnly;
                                                                            toggleHiddenBtn.textContent = inboxShowHiddenOnly ? 'Masquer éléments supprimés' : 'Voir éléments masqués';
                                                                            if (inboxShowHiddenOnly) {
                                                                                toggleHiddenBtn.classList.add('text-rose-400', 'border-rose-500/50', 'bg-rose-500/10');
                                                                                toggleHiddenBtn.classList.remove('text-slate-400', 'border-slate-700/50', 'bg-slate-800');
                                                                            } else {
                                                                                toggleHiddenBtn.classList.remove('text-rose-400', 'border-rose-500/50', 'bg-rose-500/10');
                                                                                toggleHiddenBtn.classList.add('text-slate-400', 'border-slate-700/50', 'bg-slate-800');
                                                                            }
                                                                            inboxLoadFull(true);
                                                                        });
                                                                    }

                                                                    function closeThreadModal() {
                                                                        inboxThreadModal && inboxThreadModal.classList.add('hidden');
                                                                        activeThreadId = null;
                                                                    }

                                                                    inboxThreadBackdrop && inboxThreadBackdrop.addEventListener('click', closeThreadModal);
                                                                    inboxThreadClose && inboxThreadClose.addEventListener('click', closeThreadModal);

                                                                    inboxThreadReplyForm && inboxThreadReplyForm.addEventListener('submit', async function (e) {
                                                                        e.preventDefault();
                                                                        if (!activeThreadId || !inboxThreadReplyInput) return;
                                                                        const message = String(inboxThreadReplyInput.value || '').trim();
                                                                        if (!message) return;

                                                                        try {
                                                                            const res = await fetch('/api/bug-reports/' + encodeURIComponent(activeThreadId) + '/reply', {
                                                                                method: 'POST',
                                                                                headers: { 'Content-Type': 'application/json' },
                                                                                credentials: 'same-origin',
                                                                                body: JSON.stringify({ message })
                                                                            });
                                                                            if (!res.ok) throw new Error('thread_reply_failed');
                                                                            inboxThreadReplyInput.value = '';
                                                                            openBugThread(activeThreadId);
                                                                        } catch (_) {
                                                                            alert('Impossible d\'envoyer la réponse.');
                                                                        }
                                                                    });
                                                                    try {
                                                                        /* ── Dismiss logic for all message types (banner, notification, popup) ── */
                                                                        document.querySelectorAll('.site-msg-item').forEach(function (wrap) {
                                                                            var raw = wrap.getAttribute('data-msg');
                                                                            if (!raw) return;
                                                                            var safe = raw.replace(/&#39;/g, "'");
                                                                            var msg = null; try { msg = JSON.parse(safe); } catch (e) { }
                                                                            if (!msg || !msg.id) return;
                                                                            var key = 'dismissed_site_message_' + msg.id;
                                                                            var snoozeKey = 'snooze_site_message_' + msg.id;
                                                                            var snoozeUntil = Number(localStorage.getItem(snoozeKey) || 0);
                                                                            if (snoozeUntil && Date.now() < snoozeUntil) { wrap.style.display = 'none'; return; }
                                                                            if (snoozeUntil && Date.now() >= snoozeUntil) { localStorage.removeItem(snoozeKey); }
                                                                            if (localStorage.getItem(key)) { wrap.style.display = 'none'; return; }
                                                                            wrap.querySelectorAll('.site-msg-dismiss').forEach(function (btn) {
                                                                                btn.addEventListener('click', function () {
                                                                                    if (msg.dismissible) localStorage.setItem(key, '1');
                                                                                    wrap.style.display = 'none';
                                                                                });
                                                                            });
                                                                            wrap.querySelectorAll('.site-msg-snooze').forEach(function (btn) {
                                                                                btn.addEventListener('click', function () {
                                                                                    var days = Number(btn.getAttribute('data-snooze-days') || '1');
                                                                                    var until = Date.now() + days * 24 * 60 * 60 * 1000;
                                                                                    localStorage.setItem(snoozeKey, String(until));
                                                                                    wrap.style.display = 'none';
                                                                                });
                                                                            });
                                                                        });
                                                                        /* Popup backdrop dismiss */
                                                                        var popupBg = document.getElementById('sitePopupBackdrop');
                                                                        var popupWrap = document.getElementById('sitePopupWrap');
                                                                        if (popupBg && popupWrap) {
                                                                            var popData = popupWrap.getAttribute('data-msg');
                                                                            if (popData) {
                                                                                var popSafe = popData.replace(/&#39;/g, "'");
                                                                                var popMsg = null; try { popMsg = JSON.parse(popSafe); } catch (e) { }
                                                                                popupBg.addEventListener('click', function () {
                                                                                    if (popMsg && popMsg.dismissible && popMsg.id) {
                                                                                        localStorage.setItem('dismissed_site_message_' + popMsg.id, '1');
                                                                                    }
                                                                                    popupWrap.style.display = 'none';
                                                                                });
                                                                            }
                                                                        }
                                                                        /* Auto-dismiss notifications after 8s */
                                                                        var notifWrap = document.getElementById('siteNotifsWrap');
                                                                        if (notifWrap) {
                                                                            notifWrap.querySelectorAll('.site-msg-item').forEach(function (item, i) {
                                                                                setTimeout(function () {
                                                                                    item.style.transition = 'opacity 0.4s, transform 0.4s';
                                                                                    item.style.opacity = '0';
                                                                                    item.style.transform = 'translateX(100%)';
                                                                                    setTimeout(function () { item.style.display = 'none'; }, 500);
                                                                                }, 6000 + i * 2000);
                                                                            });
                                                                        }
                                                                    } catch (e) { }
                                                                })();
                                                            </script>

