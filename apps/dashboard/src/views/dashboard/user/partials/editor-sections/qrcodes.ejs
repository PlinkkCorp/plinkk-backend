<!-- QR Codes Section -->
<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-xl font-bold text-white mb-1">Mes codes QR</h2>
            <p class="text-sm text-slate-400">Créez et personnalisez vos codes QR pour promouvoir votre page Plinkk</p>
        </div>
        <button id="btnCreateQrCode"
            class="flex items-center gap-2 px-4 py-2.5 text-sm font-medium rounded-xl bg-violet-600 hover:bg-violet-500 text-white shadow-lg shadow-violet-900/20 transition-all">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Nouveau QR Code
        </button>
    </div>

    <!-- QR Codes List -->
    <div id="qrCodesList" class="space-y-4">
        <div class="text-center py-12 text-slate-400">
            <svg class="w-12 h-12 mx-auto mb-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7"></rect>
                <rect x="14" y="3" width="7" height="7"></rect>
                <rect x="14" y="14" width="7" height="7"></rect>
                <rect x="3" y="14" width="2" height="2"></rect>
            </svg>
            <p class="text-sm">Aucun code QR créé. Commencez par en ajouter un !</p>
        </div>
    </div>
</div>

<!-- Create/Edit QR Code Modal -->
<div id="qrCodeModal" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
    <div class="bg-slate-900 border border-slate-800 rounded-3xl max-w-2xl w-full max-h-[90vh] overflow-auto shadow-2xl">
        <div class="flex items-center justify-between p-6 border-b border-slate-800 sticky top-0 bg-slate-900">
            <h3 id="qrCodeModalTitle" class="text-xl font-bold text-white">Créer un code QR</h3>
            <button onclick="closeQrCodeModal()" class="p-2 hover:bg-slate-800 rounded-lg text-slate-400 hover:text-white transition-colors">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>

        <form id="qrCodeForm" class="p-6 space-y-6">
            <input type="hidden" id="qrCodeId" value="">

            <!-- Name -->
            <div>
                <label for="qrCodeName" class="block text-sm font-medium text-white mb-2">Nom du QR Code</label>
                <input type="text" id="qrCodeName" placeholder="Ex: Promotion Été 2024"
                    class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-violet-500 transition-colors">
                <p class="mt-1 text-xs text-slate-400">Donnez un nom descriptif à votre QR Code</p>
            </div>

            <!-- Target Type -->
            <div>
                <label for="qrCodeTargetType" class="block text-sm font-medium text-white mb-2">Cible du QR Code</label>
                <select id="qrCodeTargetType"
                    class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white focus:outline-none focus:border-violet-500 transition-colors">
                    <option value="PLINKK_PAGE">Ma page Plinkk</option>
                    <option value="PROFILE">Mon profil</option>
                    <option value="CUSTOM_URL">URL personnalisée</option>
                </select>
                <p class="mt-1 text-xs text-slate-400">Choisissez ce que le QR Code affichera</p>
            </div>

            <!-- Custom URL (hidden by default) -->
            <div id="customUrlGroup" class="hidden">
                <label for="qrCodeCustomUrl" class="block text-sm font-medium text-white mb-2">URL personnalisée</label>
                <input type="url" id="qrCodeCustomUrl" placeholder="https://example.com"
                    class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-violet-500 transition-colors">
                <p class="mt-1 text-xs text-slate-400">Entrez une URL complète (https://...)</p>
            </div>

            <!-- Customization Section -->
            <div class="border-t border-slate-800 pt-6">
                <h4 class="text-sm font-semibold text-white mb-4">Personnalisation du QR Code</h4>
                
                <div class="grid grid-cols-2 gap-4">
                    <!-- Eye Color -->
                    <div>
                        <label for="qrCodeEyeColor" class="block text-sm font-medium text-white mb-2">Couleur des carrés (coins)</label>
                        <div class="flex items-center gap-3">
                            <input type="color" id="qrCodeEyeColor" value="#000000"
                                class="w-12 h-12 rounded-lg cursor-pointer border border-slate-700">
                            <span id="qrCodeEyeColorValue" class="text-sm text-slate-400">#000000</span>
                        </div>
                    </div>

                    <!-- Light Color -->
                    <div>
                        <label for="qrCodeLightColor" class="block text-sm font-medium text-white mb-2">Couleur du fond</label>
                        <div class="flex items-center gap-3">
                            <input type="color" id="qrCodeLightColor" value="#ffffff"
                                class="w-12 h-12 rounded-lg cursor-pointer border border-slate-700">
                            <span id="qrCodeLightColorValue" class="text-sm text-slate-400">#ffffff</span>
                        </div>
                    </div>
                </div>

                <!-- Border Radius -->
                <div class="mt-4">
                    <label for="qrCodeBorderRadius" class="block text-sm font-medium text-white mb-2">Arrondissement des pixels</label>
                    <div class="flex items-center gap-4">
                        <input type="range" id="qrCodeBorderRadius" min="0" max="100" value="0"
                            class="flex-1 h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-violet-600">
                        <span id="qrCodeBorderRadiusValue" class="text-sm text-slate-400 w-12">0%</span>
                    </div>
                    <p class="mt-1 text-xs text-slate-400">Rendez les pixels plus ou moins arrondis</p>
                </div>

                <!-- Margin -->
                <div class="mt-4">
                    <label for="qrCodeMargin" class="block text-sm font-medium text-white mb-2">Marge</label>
                    <div class="flex items-center gap-4">
                        <input type="range" id="qrCodeMargin" min="0" max="20" value="4"
                            class="flex-1 h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-violet-600">
                        <span id="qrCodeMarginValue" class="text-sm text-slate-400 w-12">4</span>
                    </div>
                    <p class="mt-1 text-xs text-slate-400">Espace blanc autour du QR Code</p>
                </div>

                <!-- Direct Target -->
                <div class="mt-6 p-4 bg-slate-800/50 rounded-xl border border-slate-700">
                    <div class="flex items-start gap-3">
                        <input type="checkbox" id="qrCodeDirectTarget"
                            class="mt-1 w-4 h-4 text-violet-600 bg-slate-800 border-slate-700 rounded focus:ring-violet-500 focus:ring-2">
                        <div class="flex-1">
                            <label for="qrCodeDirectTarget" class="text-sm font-medium text-white cursor-pointer">Lien direct (sans statistiques)</label>
                            <p class="text-xs text-slate-400 mt-1">
                                Si activé, le QR code redirigera directement vers la cible sans passer par le système de tracking. 
                                <span class="text-amber-400">Attention: aucune statistique de scan ne sera collectée.</span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Preview -->
            <div class="border-t border-slate-800 pt-6">
                <p class="text-sm font-medium text-white mb-3">Aperçu</p>
                <div class="bg-slate-800 rounded-xl p-6 flex items-center justify-center min-h-[250px]">
                    <div id="qrCodePreview" class="w-full max-w-xs flex items-center justify-center">
                        <div class="text-center text-slate-400">
                            <svg class="w-12 h-12 mx-auto mb-2 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="3" width="7" height="7"></rect>
                                <rect x="14" y="3" width="7" height="7"></rect>
                                <rect x="14" y="14" width="7" height="7"></rect>
                                <rect x="3" y="14" width="2" height="2"></rect>
                            </svg>
                            <p class="text-xs">Aperçu du QR Code</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="flex gap-3 border-t border-slate-800 pt-6">
                <button type="button" onclick="closeQrCodeModal()"
                    class="flex-1 px-4 py-3 bg-slate-800 border border-slate-700 text-white rounded-xl font-medium hover:bg-slate-700 transition-colors">
                    Annuler
                </button>
                <button type="submit" id="qrCodeSubmitBtn"
                    class="flex-1 px-4 py-3 bg-violet-600 hover:bg-violet-500 text-white rounded-xl font-medium shadow-lg shadow-violet-900/20 transition-all">
                    Créer le QR Code
                </button>
            </div>
        </form>
    </div>
</div>

<script>
(() => {
    const plinkkId = new URLSearchParams(window.location.search).get('plinkkId');
    const qrIdToEdit = new URLSearchParams(window.location.search).get('qrId');
    let currentQrCodeList = [];

    // Color input listeners
    document.getElementById('qrCodeEyeColor').addEventListener('change', (e) => {
        document.getElementById('qrCodeEyeColorValue').textContent = e.target.value;
        generateQrCodePreview();
    });

    document.getElementById('qrCodeLightColor').addEventListener('change', (e) => {
        document.getElementById('qrCodeLightColorValue').textContent = e.target.value;
        generateQrCodePreview();
    });

    // Range input listeners
    document.getElementById('qrCodeBorderRadius').addEventListener('input', (e) => {
        document.getElementById('qrCodeBorderRadiusValue').textContent = e.target.value + '%';
        generateQrCodePreview();
    });

    document.getElementById('qrCodeMargin').addEventListener('input', (e) => {
        document.getElementById('qrCodeMarginValue').textContent = e.target.value;
        generateQrCodePreview();
    });

    // Target type change
    document.getElementById('qrCodeTargetType').addEventListener('change', (e) => {
        const customUrlGroup = document.getElementById('customUrlGroup');
        if (e.target.value === 'CUSTOM_URL') {
            customUrlGroup.classList.remove('hidden');
        } else {
            customUrlGroup.classList.add('hidden');
        }
        generateQrCodePreview();
    });

    // Form submission
    document.getElementById('qrCodeForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const qrCodeId = document.getElementById('qrCodeId').value;
        const method = qrCodeId ? 'PATCH' : 'POST';
        const endpoint = qrCodeId 
            ? `/api/me/plinkks/${plinkkId}/qrcodes/${qrCodeId}`
            : `/api/me/plinkks/${plinkkId}/qrcodes`;

        const targetType = document.getElementById('qrCodeTargetType').value;
        const payload = {
            name: document.getElementById('qrCodeName').value,
            targetType,
            customUrl: targetType === 'CUSTOM_URL' ? document.getElementById('qrCodeCustomUrl').value : undefined,
            foregroundHex: document.getElementById('qrCodeEyeColor').value,
            backgroundHex: document.getElementById('qrCodeLightColor').value,
            eyeHex: document.getElementById('qrCodeEyeColor').value,
            rounded: parseInt(document.getElementById('qrCodeBorderRadius').value) > 0,
            margin: parseInt(document.getElementById('qrCodeMargin').value),
            directTarget: document.getElementById('qrCodeDirectTarget').checked,
        };

        try {
            const response = await fetch(endpoint, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
            });

            if (!response.ok) {
                const error = await response.json();
                throw new Error(error.error || 'Erreur lors de la sauvegarde');
            }

            closeQrCodeModal();
            loadQrCodes();
        } catch (error) {
            alert('Erreur: ' + error.message);
        }
    });

    // Load QR codes
    async function loadQrCodes() {
        if (!plinkkId) return;

        try {
            const response = await fetch(`/api/me/plinkks/${plinkkId}/qrcodes`);
            if (!response.ok) throw new Error('Erreur au chargement');

            const data = await response.json();
            currentQrCodeList = data.items || [];
            renderQrCodes();

            if (qrIdToEdit) {
                const match = currentQrCodeList.find(qr => qr.id === qrIdToEdit);
                if (match) {
                    window.editQrCode(match.id);
                }
            }
        } catch (error) {
            console.error('Erreur:', error);
        }
    }

    // Render QR codes list
    function renderQrCodes() {
        const container = document.getElementById('qrCodesList');
        
        if (currentQrCodeList.length === 0) {
            container.innerHTML = `
                <div class="text-center py-12 text-slate-400">
                    <svg class="w-12 h-12 mx-auto mb-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="7" height="7"></rect>
                        <rect x="14" y="3" width="7" height="7"></rect>
                        <rect x="14" y="14" width="7" height="7"></rect>
                        <rect x="3" y="14" width="2" height="2"></rect>
                    </svg>
                    <p class="text-sm">Aucun code QR créé. Commencez par en ajouter un !</p>
                </div>
            `;
            return;
        }

        container.innerHTML = currentQrCodeList.map(qr => `
            <div class="bg-slate-800 border border-slate-700 rounded-2xl p-4 flex items-start gap-4">
                <div class="flex-shrink-0 bg-slate-700 rounded-lg p-2 flex items-center justify-center w-24 h-24">
                    <img src="${qr.imageUrl}" alt="${qr.name}" class="w-full h-full object-contain">
                </div>
                <div class="flex-1 min-w-0">
                    <h4 class="font-semibold text-white">${qr.name || 'Sans nom'}</h4>
                    <p class="text-sm text-slate-400 mt-1">Cible: ${qr.targetType}</p>
                    <p class="text-xs text-slate-500 mt-2 break-all">Lien: <a href="${qr.shareUrl}" target="_blank" class="text-violet-400 hover:underline">${qr.shareUrl}</a></p>
                    <p class="text-xs text-slate-500 mt-1">Créé: ${new Date(qr.createdAt).toLocaleDateString('fr-FR')}</p>
                </div>
                <div class="flex-shrink-0 flex gap-2">
                    <button onclick="downloadQrCodeFromEditor('${qr.id}', '${qr.name || 'QR Code'}')"
                        class="p-2 hover:bg-slate-700 rounded-lg text-slate-400 hover:text-white transition-colors"
                        title="Télécharger">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                    </button>
                    <button onclick="editQrCode('${qr.id}')"
                        class="p-2 hover:bg-slate-700 rounded-lg text-slate-400 hover:text-white transition-colors"
                        title="Modifier">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                        </svg>
                    </button>
                    <button onclick="deleteQrCode('${qr.id}', '${qr.name || 'ce QR Code'}')"
                        class="p-2 hover:bg-rose-500/10 rounded-lg text-slate-400 hover:text-rose-400 transition-colors"
                        title="Supprimer">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                        </svg>
                    </button>
                </div>
            </div>
        `).join('');
    }

    // Generate QR code preview
    async function generateQrCodePreview() {
        const targetType = document.getElementById('qrCodeTargetType').value;
        const eyeColor = document.getElementById('qrCodeEyeColor').value;
        const lightColor = document.getElementById('qrCodeLightColor').value;
        const borderRadius = parseInt(document.getElementById('qrCodeBorderRadius').value);
        const margin = parseInt(document.getElementById('qrCodeMargin').value);

        // For preview, we would need to generate a QR code on the client side
        // This is a placeholder - the actual preview would be generated server-side
        const preview = document.getElementById('qrCodePreview');
        preview.innerHTML = '<p class="text-sm text-slate-400">Aperçu disponible après la création</p>';
    }

    // Modal functions
    window.openQrCodeModal = () => {
        document.getElementById('qrCodeModal').classList.remove('hidden');
        document.getElementById('qrCodeModalTitle').textContent = 'Créer un code QR';
        document.getElementById('qrCodeId').value = '';
        document.getElementById('qrCodeForm').reset();
        document.getElementById('qrCodeSubmitBtn').textContent = 'Créer le QR Code';
        document.getElementById('customUrlGroup').classList.add('hidden');
    };

    window.closeQrCodeModal = () => {
        document.getElementById('qrCodeModal').classList.add('hidden');
    };

    window.editQrCode = (id) => {
        const qr = currentQrCodeList.find(q => q.id === id);
        if (!qr) return;

        document.getElementById('qrCodeModalTitle').textContent = 'Modifier le code QR';
        document.getElementById('qrCodeId').value = id;
        document.getElementById('qrCodeName').value = qr.name || '';
        document.getElementById('qrCodeTargetType').value = qr.targetType;
        document.getElementById('qrCodeCustomUrl').value = qr.customUrl || '';
        document.getElementById('qrCodeEyeColor').value = qr.foregroundHex || '#000000';
        document.getElementById('qrCodeLightColor').value = qr.backgroundHex || '#ffffff';
        document.getElementById('qrCodeBorderRadius').value = qr.rounded ? 100 : 0;
        document.getElementById('qrCodeMargin').value = qr.margin || 4;
        document.getElementById('qrCodeSubmitBtn').textContent = 'Modifier le QR Code';

        // Update color displays
        document.getElementById('qrCodeEyeColorValue').textContent = qr.foregroundHex || '#000000';
        document.getElementById('qrCodeLightColorValue').textContent = qr.backgroundHex || '#ffffff';
        document.getElementById('qrCodeBorderRadiusValue').textContent = (qr.rounded ? 100 : 0) + '%';
        document.getElementById('qrCodeMarginValue').textContent = qr.margin || 4;

        // Show/hide custom URL
        const customUrlGroup = document.getElementById('customUrlGroup');
        if (qr.targetType === 'CUSTOM_URL') {
            customUrlGroup.classList.remove('hidden');
        } else {
            customUrlGroup.classList.add('hidden');
        }

        document.getElementById('qrCodeModal').classList.remove('hidden');
    };

    window.deleteQrCode = async (id, label) => {
        if (!confirm(`Êtes-vous sûr de vouloir supprimer le QR Code "${label}" ?`)) return;

        try {
            const response = await fetch(`/api/me/plinkks/${plinkkId}/qrcodes/${id}`, { method: 'DELETE' });
            if (!response.ok) throw new Error('Erreur lors de la suppression');
            loadQrCodes();
        } catch (error) {
            alert('Erreur: ' + error.message);
        }
    };
    window.downloadQrCodeFromEditor = (qrId, name) => {
        const fileName = (name || 'QR Code').replace(/[^a-z0-9_-]/gi, '_');
        const url = `/api/me/plinkks/${plinkkId}/qrcodes/${qrId}/image.svg`;
        const link = document.createElement('a');
        link.href = url;
        link.download = `${fileName}.svg`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    };
    // Event listener for create button
    document.getElementById('btnCreateQrCode').addEventListener('click', window.openQrCodeModal);

    // Close modal on background click
    document.getElementById('qrCodeModal').addEventListener('click', (e) => {
        if (e.target === document.getElementById('qrCodeModal')) {
            closeQrCodeModal();
        }
    });

    // Initial load
    loadQrCodes();
})();
</script>
