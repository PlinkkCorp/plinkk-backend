<div id="globalTicketModal"
    class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-slate-950/80 backdrop-blur-sm"
    aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div
        class="relative w-full max-w-lg transform overflow-hidden rounded-3xl bg-[#0B1020] border border-white/10 text-left shadow-2xl transition-all">
        <form id="globalTicketForm" onsubmit="submitGlobalTicket(event)">
            <input type="hidden" id="ticketContextUrl" value="">
            <input type="hidden" id="ticketContextStack" value="">
            <input type="hidden" id="ticketContextBrowser" value="">
            
            <div class="px-6 py-6 sm:p-8">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-xl font-bold text-white tracking-tight" id="modal-title">Ouvrir un ticket</h3>
                    <button type="button" onclick="closeGlobalTicketModal()" class="text-slate-500 hover:text-white transition-colors">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>

                <div class="space-y-5">
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2 px-1">Catégorie</label>
                        <select id="ticketCategory" required
                            class="block w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-white placeholder-slate-500 hover:border-white/20 focus:border-violet-500 focus:outline-none focus:ring-1 focus:ring-violet-500 transition-all sm:text-sm appearance-none">
                            <option value="bug" class="bg-slate-900">Signaler un Bug</option>
                            <option value="question" class="bg-slate-900">Poser une Question</option>
                            <option value="suggestion" class="bg-slate-900">Faire une Suggestion</option>
                            <option value="partnership" class="bg-slate-900">Partenariat</option>
                            <option value="other" class="bg-slate-900">Autre</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2 px-1">Message</label>
                        <textarea id="ticketMessage" required rows="5"
                            class="block w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-white placeholder-slate-500 hover:border-white/20 focus:border-violet-500 focus:outline-none focus:ring-1 focus:ring-violet-500 transition-all sm:text-sm"
                            placeholder="Décrivez votre demande en détail..."></textarea>
                    </div>
                </div>
            </div>

            <div class="bg-white/5 px-6 py-4 sm:flex sm:flex-row-reverse sm:px-8 gap-3">
                <button type="submit" id="submitTicketBtn"
                    class="inline-flex w-full justify-center rounded-2xl bg-gradient-to-r from-violet-600 to-fuchsia-600 px-6 py-3 text-sm font-bold text-white shadow-lg shadow-violet-500/20 hover:opacity-90 sm:w-auto transition-all active:scale-95">
                    Envoyer le ticket
                </button>
                <button type="button" onclick="closeGlobalTicketModal()"
                    class="mt-3 inline-flex w-full justify-center rounded-2xl px-6 py-3 text-sm font-semibold text-slate-300 shadow-sm ring-1 ring-inset ring-white/10 hover:bg-white/5 sm:mt-0 sm:w-auto transition-all">
                    Annuler
                </button>
            </div>
        </form>
    </div>
</div>

<script nonce="<%= cspNonce %>">
    window.openGlobalTicketModal = function (category, defaultMessage, context) {
        const modal = document.getElementById('globalTicketModal');
        if (!modal) return;

        modal.classList.remove('hidden');
        modal.classList.add('flex');

        const catEl = document.getElementById('ticketCategory');
        if (catEl && category) {
            catEl.value = category;
        }

        const msgEl = document.getElementById('ticketMessage');
        if (msgEl) {
            msgEl.value = defaultMessage || '';
            msgEl.focus();
        }

        // Set context
        document.getElementById('ticketContextUrl').value = (context && context.url) || window.location.href;
        document.getElementById('ticketContextStack').value = (context && context.stack) || '';

        // Capture browser info
        const browserInfo = {
            ua: navigator.userAgent,
            screen: `${window.screen.width}x${window.screen.height}`,
            viewport: `${window.innerWidth}x${window.innerHeight}`,
            lang: navigator.language,
            platform: navigator.platform
        };
        document.getElementById('ticketContextBrowser').value = JSON.stringify(browserInfo);
    };

    // Alias for backwards compatibility
    window.openGlobalBugReportModal = function (e, defaultMessage, context) {
        if (e && e.preventDefault) e.preventDefault();
        window.openGlobalTicketModal('bug', defaultMessage, context);
    };

    window.closeGlobalTicketModal = function () {
        const modal = document.getElementById('globalTicketModal');
        if (!modal) return;

        modal.classList.add('hidden');
        modal.classList.remove('flex');

        const msgEl = document.getElementById('ticketMessage');
        if (msgEl) msgEl.value = '';
        document.getElementById('ticketContextUrl').value = '';
        document.getElementById('ticketContextStack').value = '';
        document.getElementById('ticketContextBrowser').value = '';
    };

    window.showTicketToast = function (message, type = 'success') {
        const toast = document.createElement('div');
        const toneClass = type === 'error'
            ? 'bg-rose-600/95 border-rose-400/40 shadow-rose-500/20'
            : 'bg-emerald-600/95 border-emerald-400/40 shadow-emerald-500/20';

        toast.className = `fixed top-6 right-6 z-[120] rounded-2xl border px-6 py-3 text-sm font-bold text-white shadow-2xl backdrop-blur-md transition-all duration-300 opacity-0 translate-y-2 ${toneClass}`;
        toast.textContent = message;
        document.body.appendChild(toast);

        requestAnimationFrame(() => {
            toast.classList.remove('opacity-0', 'translate-y-2');
        });

        setTimeout(() => {
            toast.classList.add('opacity-0', 'translate-y-2');
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    };

    window.submitGlobalTicket = async function (e) {
        e.preventDefault();
        const btn = document.getElementById('submitTicketBtn');
        const msgEl = document.getElementById('ticketMessage');
        const catEl = document.getElementById('ticketCategory');
        if (!btn || !msgEl || !catEl) return;

        const msg = msgEl.value;
        const cat = catEl.value;
        const originalText = btn.textContent;
        const url = document.getElementById('ticketContextUrl').value;
        const stack = document.getElementById('ticketContextStack').value;
        const browser = document.getElementById('ticketContextBrowser').value;

        btn.disabled = true;
        btn.textContent = 'Envoi...';

        try {
            const res = await fetch('/api/bug-reports', { // Keeping existing endpoint for compatibility, or you can rename it if backend is updated
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    message: `[${cat.toUpperCase()}] ${msg}`,
                    url: url || window.location.href,
                    stack: stack || null,
                    browser: browser ? JSON.parse(browser) : null,
                    category: cat
                })
            });

            if (res.ok) {
                window.closeGlobalTicketModal();
                window.showTicketToast('Votre ticket a été envoyé avec succès !', 'success');
            } else {
                window.showTicketToast("Une erreur est survenue lors de l'envoi du ticket.", 'error');
            }
        } catch (err) {
            window.showTicketToast('Erreur réseau lors de l\'envoi du ticket.', 'error');
        } finally {
            btn.disabled = false;
            btn.textContent = originalText;
        }
    };
</script>
