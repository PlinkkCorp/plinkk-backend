<%- include('partials/head.ejs', { title: 'Codes QR', description: 'Créez et personnalisez vos codes QR pour promouvoir votre Plinkk.', robots: 'noindex,nofollow' }) %>
<%- include('partials/header-dash.ejs') %>

<div class="max-w-[1600px] mx-auto grid grid-cols-12 gap-6 px-4 py-8">
  <%- include('partials/asside_dash.ejs', { active: 'qrcodes' }) %>

  <main class="col-span-12 lg:col-span-10 space-y-8">
    <!-- Header -->
    <div class="bg-slate-900 border border-slate-800 p-6 rounded-3xl">
      <h1 class="text-2xl font-bold text-white">Codes QR</h1>
      <p class="text-sm text-slate-400 mt-1">Créez et personnalisez vos codes QR pour promouvoir votre page Plinkk.</p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-slate-900 border border-slate-800 p-6 rounded-2xl hover:border-slate-700 transition-colors">
        <div class="flex items-center justify-between mb-3">
          <div class="p-2 bg-violet-500/10 rounded-lg text-violet-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <rect x="3" y="3" width="7" height="7"></rect>
              <rect x="14" y="3" width="7" height="7"></rect>
              <rect x="14" y="14" width="7" height="7"></rect>
              <rect x="3" y="14" width="2" height="2"></rect>
            </svg>
          </div>
          <span class="text-xs text-slate-400">Total</span>
        </div>
        <p class="text-2xl font-bold text-white"><%= totalQrCodes %></p>
        <p class="text-xs text-slate-400 mt-1">Code<%= totalQrCodes !== 1 ? 's' : '' %> QR créé<%= totalQrCodes !== 1 ? 's' : '' %></p>
        <% if (typeof maxQrCodes !== 'undefined') { %>
          <div class="mt-3 pt-3 border-t border-slate-800">
            <p class="text-xs text-slate-500">Limite: <%= totalQrCodes %>/<%= maxQrCodes %></p>
            <% if (totalQrCodes >= maxQrCodes * 0.8) { %>
              <a href="/premium" class="text-xs text-violet-400 hover:text-violet-300 transition-colors">Augmenter la limite</a>
            <% } %>
          </div>
        <% } %>
      </div>

      <div class="bg-slate-900 border border-slate-800 p-6 rounded-2xl hover:border-slate-700 transition-colors">
        <div class="flex items-center justify-between mb-3">
          <div class="p-2 bg-emerald-500/10 rounded-lg text-emerald-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.658 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
          </div>
          <span class="text-xs text-slate-400">Lectures</span>
        </div>
        <p class="text-2xl font-bold text-white"><%= totalScans.toLocaleString('fr-FR') %></p>
        <p class="text-xs text-slate-400 mt-1">Scan<%= totalScans !== 1 ? 's' : '' %> au total</p>
      </div>
    </div>

    <!-- QR Codes List -->
    <div class="space-y-4">
      <h2 class="text-lg font-bold text-white">Tous les codes QR</h2>
      
      <% if (qrCodes && qrCodes.length > 0) { %>
        <div class="grid gap-4">
          <% qrCodes.forEach(qr => { %>
            <div class="bg-slate-900 border border-slate-800 rounded-2xl p-5 hover:border-violet-500/30 transition-all group">
              <div class="flex flex-col md:flex-row gap-6 items-start md:items-center">
                <!-- QR Code Preview -->
                <div class="flex-shrink-0 bg-slate-800 rounded-xl p-3 flex items-center justify-center w-28 h-28">
                  <img src="/api/me/plinkks/<%= qr.plinkkId %>/qrcodes/<%= qr.id %>/image.svg" alt="<%= qr.name %>" class="w-full h-full object-contain">
                </div>

                <!-- QR Code Info -->
                <div class="flex-1 min-w-0">
                  <h3 class="font-bold text-white text-lg group-hover:text-violet-400 transition-colors"><%= qr.name || 'Sans nom' %></h3>
                  <div class="mt-3 space-y-2 text-sm">
                    <p class="text-slate-400">
                      <span class="font-medium text-slate-300">Cible:</span>
                      <% if (qr.targetType === 'PLINKK_PAGE') { %>
                        Page Plinkk "<%= qr.plinkk.name %>" (<span class="text-violet-400"><%= qr.plinkk.slug %></span>)
                      <% } else if (qr.targetType === 'PROFILE') { %>
                        Profil utilisateur
                      <% } else if (qr.targetType === 'CUSTOM_URL') { %>
                        URL personnalisée
                      <% } else if (qr.targetType === 'REDIRECT') { %>
                        Redirection
                      <% } %>
                    </p>
                    <p class="text-slate-500">
                      <span class="font-medium text-slate-400">Lectures:</span> <%= (qr.scansCount || 0).toLocaleString('fr-FR') %>
                    </p>
                    <p class="text-slate-500">
                      <span class="font-medium text-slate-400">Créé:</span> <%= new Date(qr.createdAt).toLocaleDateString('fr-FR') %>
                    </p>
                  </div>
                </div>

                <!-- Actions -->
                <div class="flex flex-col gap-2 w-full md:w-auto">
                  <button onclick="copyToClipboard('https://plinkk.fr/q/<%= qr.shortCode %>')"
                    class="px-4 py-2.5 bg-slate-800 hover:bg-slate-700 text-white rounded-xl text-sm font-medium transition-colors flex items-center justify-center gap-2 whitespace-nowrap">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
                      <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
                    </svg>
                    Copier
                  </button>
                  <button onclick="downloadQrCode('<%= qr.plinkkId %>', '<%= qr.id %>', '<%= qr.name || 'QR Code' %>')"
                    class="px-4 py-2.5 bg-slate-800 hover:bg-slate-700 text-white rounded-xl text-sm font-medium transition-colors flex items-center justify-center gap-2 whitespace-nowrap">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                      <polyline points="7 10 12 15 17 10"></polyline>
                      <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                    Télécharger
                  </button>
                  <button onclick="editQrCode('<%= qr.plinkkId %>', '<%= qr.id %>')"
                    class="px-4 py-2.5 bg-violet-600 hover:bg-violet-500 text-white rounded-xl text-sm font-medium transition-colors flex items-center justify-center gap-2 whitespace-nowrap">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                      <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                    </svg>
                    Modifier
                  </button>
                  <button onclick="deleteQrCode('<%= qr.plinkkId %>', '<%= qr.id %>', '<%= qr.name || 'ce QR Code' %>')"
                    class="px-4 py-2.5 bg-rose-600/20 hover:bg-rose-600/30 text-rose-400 rounded-xl text-sm font-medium transition-colors flex items-center justify-center gap-2 whitespace-nowrap">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="3 6 5 6 21 6"></polyline>
                      <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    </svg>
                    Supprimer
                  </button>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="text-center py-16 bg-slate-900 border border-slate-800 rounded-2xl">
          <div class="p-4 bg-slate-800/50 rounded-full w-20 h-20 mx-auto mb-4 flex items-center justify-center">
            <svg class="w-10 h-10 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <rect x="3" y="3" width="7" height="7"></rect>
              <rect x="14" y="3" width="7" height="7"></rect>
              <rect x="14" y="14" width="7" height="7"></rect>
              <rect x="3" y="14" width="2" height="2"></rect>
            </svg>
          </div>
          <h3 class="text-white font-semibold mb-1">Aucun code QR créé</h3>
          <p class="text-slate-400 text-sm">Créez vos codes QR depuis l'onglet "QR Codes" dans l'éditeur de votre Plinkk.</p>
        </div>
      <% } %>
    </div>
  </main>
</div>

<script>
(() => {
  window.deleteQrCode = async (plinkkId, qrId, label) => {
    if (!confirm(`Êtes-vous sûr de vouloir supprimer le QR Code "${label}" ?`)) return;

    try {
      const response = await fetch(`/api/me/plinkks/${plinkkId}/qrcodes/${qrId}`, { method: 'DELETE' });
      if (!response.ok) throw new Error('Erreur lors de la suppression');
      location.reload();
    } catch (error) {
      alert('Erreur: ' + error.message);
    }
  };

  window.copyToClipboard = (text) => {
    navigator.clipboard.writeText(text).then(() => {
      alert('Lien copié dans le presse-papiers !');
    });
  };

  window.downloadQrCode = (plinkkId, qrId, name) => {
    const url = `/api/me/plinkks/${plinkkId}/qrcodes/${qrId}/image.svg`;
    const link = document.createElement('a');
    link.href = url;
    link.download = `${name || 'qrcode'}.svg`;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  };

  window.editQrCode = (plinkkId, qrId) => {
    window.location.href = `/qrcode/edit?plinkkId=${encodeURIComponent(plinkkId)}&qrId=${encodeURIComponent(qrId)}`;
  };
})();
</script>
