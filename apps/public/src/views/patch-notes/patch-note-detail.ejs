<%- include('../partials/head', { title: patchNote.title + ' - Patch Notes - Plinkk', description: 'Découvrez les détails de cette mise à jour Plinkk.' }) %>
<%- include('../partials/header', { user: (typeof user !== 'undefined' ? user : null) }) %>

<main class="relative isolate overflow-hidden min-h-screen">
  <!-- Background Effects -->
  <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
    <div class="absolute left-[50%] top-0 -translate-x-1/2 blur-3xl opacity-20" aria-hidden="true">
      <div class="aspect-[1155/678] w-[72.1875rem] bg-gradient-to-tr from-[#ff80b5] to-[#9089fc]" style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"></div>
    </div>
  </div>

  <div class="mx-auto max-w-4xl px-6 py-24 sm:py-32">

    <!-- Navigation -->
    <a href="/patch-notes" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-white/5 transition-colors mb-8 animate-slide-up">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      Retour aux patch notes
    </a>

    <!-- Content Card -->
    <div class="bg-slate-900/40 backdrop-blur-md rounded-3xl border border-white/5 p-8 sm:p-12 shadow-2xl animate-slide-up" style="animation-delay: 50ms;">

      <!-- Header -->
      <div class="mb-8 pb-8 border-b border-white/5">
        <div class="flex items-center gap-3 mb-6">
          <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-gradient-to-r from-violet-500/20 to-fuchsia-500/20 text-violet-300 border border-violet-500/30">v<%= patchNote.version %></span>
        </div>
        
        <h1 class="text-4xl font-bold tracking-tight text-white mb-6"><%= patchNote.title %></h1>

        <!-- Meta Info -->
        <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6 text-sm text-slate-400">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-violet-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/></svg>
            <time datetime="<%= new Date(patchNote.publishedAt).toISOString() %>">
              <%= new Date(patchNote.publishedAt).toLocaleDateString('fr-FR', { 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric'
              }) %>
            </time>
          </div>

          <% if (patchNote.createdBy) { %>
            <div class="flex items-center gap-2">
              <% if (patchNote.createdBy.image) { %>
                <img src="<%= patchNote.createdBy.image %>" alt="<%= patchNote.createdBy.name %>" class="w-6 h-6 rounded-full object-cover">
              <% } else { %>
                <div class="w-6 h-6 rounded-full bg-gradient-to-r from-violet-400 to-fuchsia-400 flex items-center justify-center text-xs font-bold text-white">
                  <%= patchNote.createdBy.name.charAt(0).toUpperCase() %>
                </div>
              <% } %>
              <span><%= patchNote.createdBy.name %></span>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Content -->
      <div class="prose prose-invert max-w-none">
        <div class="patch-note-content text-slate-300 leading-relaxed">
          <%- patchNote.htmlContent %>
        </div>
      </div>

      <!-- Footer -->
      <div class="mt-12 pt-8 border-t border-white/5 text-center">
        <p class="text-slate-400 mb-6">✨ Merci de votre soutien ! ❤️</p>
        <a href="/patch-notes" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-gradient-to-r from-violet-600 to-fuchsia-600 hover:from-violet-500 hover:to-fuchsia-500 text-white font-medium transition-all active:scale-[0.97]">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          Voir tous les patchs
        </a>
      </div>

    </div>

  </div>
</main>

<%- include('../partials/footer') %>

<style>
  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-slide-up {
    animation: slideDown 0.6s ease-out forwards;
    opacity: 0;
  }

  /* Prose styling overrides */
  .prose-invert {
    --prose-body: #e2e8f0;
    --prose-headings: #f1f5f9;
    --prose-lead: #cbd5e1;
    --prose-links: #a78bfa;
    --prose-bold: #f1f5f9;
    --prose-counters: #94a3b8;
    --prose-bullets: #64748b;
    --prose-hr: #334155;
    --prose-quotes: #cbd5e1;
    --prose-quote-borders: #475569;
    --prose-captions: #94a3b8;
    --prose-kbd: #f1f5f9;
    --prose-kbd-shadows: rgba(15, 23, 42, 0.75);
    --prose-code: #f1f5f9;
    --prose-pre-bg: #1e293b;
    --prose-pre-code: #e2e8f0;
  }

  .patch-note-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: rgb(196 181 253);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .patch-note-content h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: rgb(221 214 254);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .patch-note-content h4,
  .patch-note-content h5 {
    font-weight: 700;
    color: rgb(226 232 240);
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }

  .patch-note-content p {
    color: rgb(203 213 225);
    margin-bottom: 1rem;
  }

  .patch-note-content ul,
  .patch-note-content ol {
    margin-top: 1rem;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .patch-note-content li {
    margin-bottom: 0.5rem;
    color: rgb(203 213 225);
  }

  /* Items avec flèches */
  .patch-note-content li.arrow-list-item {
    list-style-type: none;
    margin-left: -1.5rem;
  }

  .patch-note-content .arrow-item {
    color: rgb(167 139 250);
    font-weight: 500;
  }

  .patch-note-content code {
    background-color: rgba(30, 41, 59, 0.5);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    color: rgb(196 181 253);
    font-size: 0.875rem;
    font-family: ui-monospace, monospace;
  }

  .patch-note-content pre {
    background-color: rgba(30, 41, 59, 0.5);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-top: 1rem;
    margin-bottom: 1rem;
    border: 1px solid rgb(51 65 85);
  }

  .patch-note-content pre code {
    background-color: transparent;
    padding: 0;
    color: rgb(226 232 240);
  }

  .patch-note-content blockquote {
    border-left: 4px solid rgb(167 139 250);
    padding-left: 1rem;
    padding-right: 1rem;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    font-style: italic;
    color: rgb(148 163 184);
    margin-top: 1rem;
    margin-bottom: 1rem;
    background-color: rgba(30, 41, 59, 0.3);
    border-radius: 0 0.25rem 0.25rem 0;
  }

  .patch-note-content a {
    color: rgb(167 139 250);
    text-decoration: underline;
    transition: color 0.2s;
  }

  .patch-note-content a:hover {
    color: rgb(196 181 253);
  }

  .patch-note-content strong {
    color: rgb(241 245 249);
    font-weight: 700;
  }

  .patch-note-content em {
    color: rgb(226 232 240);
    font-style: italic;
  }

  .patch-note-content hr {
    border-top: 1px solid rgb(51 65 85);
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  /* Emoji styling */
  .emoji {
    margin-right: 0.5rem;
  }
</style>

<script nonce="<%= cspNonce %>">
  // Ajouter la classe aux <li> qui contiennent des flèches
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.arrow-item').forEach(function(arrow) {
      const li = arrow.closest('li');
      if (li) {
        li.classList.add('arrow-list-item');
      }
    });
  });
</script>
