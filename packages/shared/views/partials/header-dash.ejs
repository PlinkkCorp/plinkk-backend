<header class="sticky top-0 z-50 border-b border-white/5 bg-[#0B1020]/80 backdrop-blur-md transition-all duration-300"
    id="dashboardHeader">
    <style>
        #spaTopLoaderDash {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 2px;
            z-index: 10000;
            pointer-events: none;
            opacity: 0;
            transition: opacity .2s ease;
        }

        #spaTopLoaderDash.active {
            opacity: 1;
        }

        #spaTopLoaderDash .prog {
            width: 0%;
            height: 100%;
            background: linear-gradient(90deg, #6366f1, #a855f7);
            box-shadow: 0 0 10px rgba(99, 102, 241, 0.5);
            transition: width .2s ease;
        }

        @keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(100%);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @keyframes popupIn {
            from {
                opacity: 0;
                transform: scale(0.9);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .animate-slide-in-right {
            animation: slideInRight 0.35s ease-out both;
        }

        .animate-popup-in {
            animation: popupIn 0.25s ease-out both;
        }

        .inbox-md h1,
        .inbox-md h2,
        .inbox-md h3,
        .inbox-md h4 {
            margin: .35rem 0;
            font-weight: 700;
        }

        .inbox-md p {
            margin: .2rem 0;
        }

        .inbox-md ul,
        .inbox-md ol {
            margin: .25rem 0 .25rem 1rem;
            padding-left: .8rem;
        }

        .inbox-md code {
            background: rgba(148, 163, 184, 0.18);
            padding: 0 4px;
            border-radius: 4px;
        }

        @keyframes inboxExpandOpen {
            from {
                opacity: 0;
                transform: translateY(-6px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .inbox-expand-open {
            animation: inboxExpandOpen 0.22s ease-out both;
            transform-origin: top;
        }
    </style>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between gap-4">
            <div class="flex items-center gap-8">
                <a href="/" class="flex items-center gap-2.5 transition-opacity hover:opacity-80">
                    <img src="https://cdn.plinkk.fr/logo.svg" alt="Plinkk" class="h-8 w-8" />
                    <span class="text-lg font-bold tracking-tight text-white">Plinkk</span>
                </a>

                <nav class="hidden md:flex items-center gap-1">
                    <a href="/"
                        class="rounded-full px-4 py-1.5 text-sm font-medium text-slate-400 transition-colors hover:bg-white/5 hover:text-white">Dashboard</a>
                    <a href="/edit"
                        class="rounded-full px-4 py-1.5 text-sm font-medium text-slate-400 transition-colors hover:bg-white/5 hover:text-white">Éditeur</a>
                    <a href="/stats"
                        class="rounded-full px-4 py-1.5 text-sm font-medium text-slate-400 transition-colors hover:bg-white/5 hover:text-white">Stats</a>
                    <a href="<%= (typeof frontendUrl !== 'undefined' ? frontendUrl : '') %>/users"
                        class="rounded-full px-4 py-1.5 text-sm font-medium text-slate-400 transition-colors hover:bg-white/5 hover:text-white">Liste
                        des Utilisateurs</a>
                    <a href="<%= (typeof frontendUrl !== 'undefined' ? frontendUrl : '') %>/partners"
                        class="rounded-full px-4 py-1.5 text-sm font-medium text-slate-400 transition-colors hover:bg-white/5 hover:text-white">Partenariat</a>
                </nav>
            </div>

            <div class="flex items-center gap-3">
                <div class="hidden md:flex items-center gap-3">
                    <% const roleName=user && user.role ? (user.role.id || user.role.name) : null; const
                        isStaff=!!(roleName && ['ADMIN','DEVELOPER','MODERATOR'].includes(roleName)); const
                        premiumUntil=user && user.premiumUntil ? new Date(user.premiumUntil) : null; const
                        hasActivePremium=!!(user && user.isPremium && (!premiumUntil || premiumUntil.getTime()>
                        Date.now()));
                        const isPremiumUser = !!(user && (isStaff || user.isPartner || hasActivePremium));
                        %>
                        <% if (!isPremiumUser) { %>
                            <a href="/premium"
                                class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm font-semibold text-white bg-gradient-to-r from-violet-600 to-fuchsia-600 shadow-lg shadow-violet-900/30 hover:shadow-violet-900/50 hover:-translate-y-0.5 transition-all">
                                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="1.5">
                                    <path d="M12 2L9 9l-7 1 5 4-2 7 7-4 7 4-2-7 5-4-7-1z" />
                                </svg>
                                <span>Passer Premium</span>
                            </a>
                            <% } %>
                                <% if (user && user.role && (user.role.id==='ADMIN' || user.role.id==='DEVELOPER' ||
                                    user.role.id==='MODERATOR' )) { %>
                                    <a href="/admin"
                                        class="inline-flex items-center justify-center rounded-full bg-rose-500/10 px-4 py-1.5 text-sm font-medium text-rose-400 ring-1 ring-inset ring-rose-500/20 transition-colors hover:bg-rose-500/20 hover:text-rose-300">Admin</a>
                                    <% } %>

                                        <div class="relative" id="inboxBellWrap">
                                            <button id="inboxBellBtn"
                                                class="relative inline-flex items-center justify-center rounded-full bg-white/5 p-2.5 ring-1 ring-white/10 transition-all hover:bg-white/10 hover:ring-white/20 focus:outline-none"
                                                aria-label="Ouvrir la boîte de réception" aria-expanded="false">
                                                <svg id="inboxBellIcon" class="h-5 w-5 text-slate-300" viewBox="0 0 24 24"
                                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                    stroke-linejoin="round">
                                                    <path d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14.2V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5"></path>
                                                    <path d="M9 17a3 3 0 0 0 6 0"></path>
                                                </svg>
                                                <span id="inboxBellBadge"
                                                    class="hidden absolute -top-1 -right-1 min-w-[18px] h-[18px] px-1 rounded-full bg-rose-500 text-white text-[10px] font-bold leading-[18px] text-center">0</span>
                                            </button>

                                            <div id="inboxBellPanel"
                                                class="hidden absolute right-0 top-full mt-2 w-[380px] max-w-[90vw] rounded-2xl border border-white/10 bg-[#161b2e] shadow-2xl overflow-hidden">
                                                <div class="px-4 py-3 border-b border-white/5 flex items-center justify-between">
                                                    <p class="text-sm font-semibold text-white">Inbox</p>
                                                    <div class="flex items-center gap-3">
                                                        <button id="inboxMarkAllRead"
                                                            class="text-[11px] text-violet-300 hover:text-violet-200">Tout marquer comme lu</button>
                                                        <button id="inboxOpenFull"
                                                            class="text-[11px] text-slate-300 hover:text-white">Voir tout</button>
                                                    </div>
                                                </div>
                                                <div id="inboxBellList" class="max-h-[420px] overflow-y-auto divide-y divide-white/5"></div>
                                            </div>

                                        </div>

                                        <div class="relative" id="profileMenu">
                                            <button id="profileMenuBtn"
                                                class="group flex items-center gap-2 rounded-full bg-white/5 pl-1.5 pr-3 py-1 ring-1 ring-white/10 transition-all hover:bg-white/10 hover:ring-white/20 focus:outline-none">
                                                <div class="relative h-8 w-8 shrink-0">
                                                    <%- include('avatar.ejs', { user }) %>
                                                </div>
                                                <span
                                                    class="max-w-[100px] truncate text-sm font-medium text-slate-200 group-hover:text-white">
                                                    <%= user && user.userName %>
                                                </span>
                                                <svg class="h-4 w-4 text-slate-500 transition-transform group-hover:text-slate-300"
                                                    fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                                    stroke-width="2">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        d="M19 9l-7 7-7-7" />
                                                </svg>
                                            </button>

                                            <div id="profileMenuPanel"
                                                class="absolute right-0 top-full mt-2 w-64 origin-top-right rounded-xl border border-white/10 bg-[#161b2e] p-1 shadow-2xl hidden">
                                                <div class="px-3 py-3 flex items-center gap-3">
                                                    <div class="relative h-9 w-9 shrink-0">
                                                        <%- include('avatar.ejs', { user }) %>
                                                    </div>
                                                    <div class="min-w-0">
                                                        <div class="flex items-center gap-1.5">
                                                            <p class="truncate text-sm font-medium text-white">
                                                                <%= user && user.userName %>
                                                            </p>
                                                            <% if (isPremiumUser) { %>
                                                                <span
                                                                    class="inline-flex items-center gap-0.5 rounded-full bg-amber-500/10 text-amber-300 border border-amber-500/25 px-1.5 py-px text-[9px] font-bold uppercase tracking-wider leading-none">PRO</span>
                                                                <% } %>
                                                        </div>
                                                        <p class="truncate text-xs text-slate-500">
                                                            <%= user && user.email %>
                                                        </p>
                                                    </div>
                                                </div>

                                                <!-- Gems Display -->
                                                <div
                                                    class="px-3 py-2 bg-violet-500/10 rounded-lg mx-2 my-1 flex items-center justify-between border border-violet-500/20">
                                                    <div class="flex items-center gap-2 text-violet-300">
                                                        <img src="<% cdnUrl %>/icons/gems.svg" alt="Gems"
                                                            class="w-4 h-4 shrink-0" />
                                                        <span class="text-xs font-medium">Plinkk Gems</span>
                                                    </div>
                                                    <span class="text-sm font-bold text-violet-200">
                                                        <%= (user && user.plinkkGems) ? user.plinkkGems : 0 %>
                                                    </span>
                                                </div>

                                                <div class="h-px bg-white/5 my-1"></div>

                                                <a href="/"
                                                    class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-slate-300 transition-colors hover:bg-white/5 hover:text-white">
                                                    <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24"
                                                        stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="2"
                                                            d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                                                    </svg>
                                                    Dashboard
                                                </a>
                                                <a href="/edit"
                                                    class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-slate-300 transition-colors hover:bg-white/5 hover:text-white">
                                                    <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24"
                                                        stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="2"
                                                            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                                    </svg>
                                                    Éditer ma page
                                                </a>
                                                <a href="/stats"
                                                    class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-slate-300 transition-colors hover:bg-white/5 hover:text-white">
                                                    <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24"
                                                        stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="2"
                                                            d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                                                    </svg>
                                                    Statistiques
                                                </a>
                                                <a href="/cosmetics"
                                                    class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-slate-300 transition-colors hover:bg-white/5 hover:text-white">
                                                    <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24"
                                                        stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="2"
                                                            d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
                                                    </svg>
                                                    Cosmétiques
                                                </a>

                                                <div class="h-px bg-white/5 my-1"></div>

                                                <a href="#" onclick="openGlobalBugReportModal(event)"
                                                    class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-slate-300 transition-colors hover:bg-white/5 hover:text-amber-400">
                                                    <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24"
                                                        stroke="currentColor">
                                                        <rect x="8" y="6" width="8" height="14" rx="4" stroke-width="2">
                                                        </rect>
                                                        <path d="M12 2v4" stroke-width="2"></path>
                                                        <path d="M8 10H4" stroke-width="2"></path>
                                                        <path d="M20 10h-4" stroke-width="2"></path>
                                                        <path d="M8 14H4" stroke-width="2"></path>
                                                        <path d="M20 14h-4" stroke-width="2"></path>
                                                    </svg>
                                                    Signaler un bug
                                                </a>

                                                <a href="/account"
                                                    class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-slate-300 transition-colors hover:bg-white/5 hover:text-white">
                                                    <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24"
                                                        stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="2"
                                                            d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                                    </svg>
                                                    Paramètres
                                                </a>
                                                <a href="/logout"
                                                    class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-rose-400 transition-colors hover:bg-rose-500/10">
                                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24"
                                                        stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="2"
                                                            d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                                    </svg>
                                                    Se déconnecter
                                                </a>
                                            </div>
                                        </div>
                </div>

                <button id="menuBtn"
                    class="md:hidden inline-flex items-center justify-center rounded-lg p-2 text-slate-400 hover:bg-white/5 hover:text-white focus:outline-none">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <div id="mobileMenu" class="hidden border-t border-white/5 bg-[#0B1020]/95 backdrop-blur-xl md:hidden">
        <div class="space-y-1 px-4 py-4">
            <div class="text-slate-500 text-sm font-medium">Général</div>
            <a href="/"
                class="block rounded-lg px-3 py-2 text-base font-medium text-slate-300 hover:bg-white/5 hover:text-white">Dashboard</a>
            <a href="/stats"
                class="block rounded-lg px-3 py-2 text-base font-medium text-slate-300 hover:bg-white/5 hover:text-white">Stats</a>
            <a href="/partners"
                class="block rounded-lg px-3 py-2 text-base font-medium text-slate-300 hover:bg-white/5 hover:text-white">Partenaires</a>
            
            <div class="text-slate-500 text-sm font-medium">Personnalisation</div>
            <a href="/edit"
                class="block rounded-lg px-3 py-2 text-base font-medium text-slate-300 hover:bg-white/5 hover:text-white">Éditeur</a>
            <a href="/cosmetics"
                class="block rounded-lg px-3 py-2 text-base font-medium text-slate-300 hover:bg-white/5 hover:text-white">Cosmétiques</a>
            <a href="/plinkks"
                class="block rounded-lg px-3 py-2 text-base font-medium text-slate-300 hover:bg-white/5 hover:text-white">Mes Plinkks</a>
            <a href="/redirects"
                class="block rounded-lg px-3 py-2 text-base font-medium text-slate-300 hover:bg-white/5 hover:text-white">Mes Redirections</a>
            <a href="/submissions"
                class="block rounded-lg px-3 py-2 text-base font-medium text-slate-300 hover:bg-white/5 hover:text-white">Soumissions</a>
        </div>

        <div class="border-t border-white/5 px-4 py-4">
            <div class="flex items-center gap-3 mb-4">
                <div class="relative h-11 w-11 shrink-0">
                    <%- include('avatar.ejs', { user }) %>
                </div>
                <div>
                    <div class="text-base font-medium text-white">
                        <%= user && user.userName %>
                    </div>
                    <div class="text-sm text-slate-500">
                        <%= user && user.email %>
                    </div>
                </div>
            </div>
            <div class="space-y-1">
                <a href="/account"
                    class="block rounded-lg px-3 py-2 text-base font-medium text-slate-300 hover:bg-white/5 hover:text-white">Paramètres</a>
                <a href="/logout"
                    class="block rounded-lg px-3 py-2 text-base font-medium text-rose-400 hover:bg-rose-500/10">Se
                    déconnecter</a>
            </div>
        </div>
    </div>

    <div id="spaTopLoaderDash" aria-hidden="true">
        <div class="prog" id="spaTopLoaderDashProg"></div>
    </div>
</header>

<% if (user && typeof user.emailVerified !== 'undefined' && user.emailVerified === false) { %>
<!-- Banner for Unverified Email -->
<div class="bg-rose-500/10 border-b border-rose-500/20 py-3 relative z-40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3">
            <div class="p-2 bg-rose-500/20 rounded-lg text-rose-400">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                    <line x1="12" y1="9" x2="12" y2="13"></line>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
            </div>
            <p class="text-sm font-medium text-rose-300">
                Votre adresse email (<strong class="text-rose-200"><%= user.email %></strong>) n'a pas encore été vérifiée. Certaines fonctionnalités peuvent être limitées.
            </p>
        </div>
        <button id="verifyEmailBtn" class="px-4 py-2 rounded-xl bg-rose-500 text-white text-sm font-bold shadow-lg shadow-rose-900/20 hover:bg-rose-400 transition-colors whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed">
            Vérifier mon compte
        </button>
    </div>
</div>
<% } %>

<div id="inboxFullModal" class="hidden fixed inset-0 z-[95] p-4">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="inboxFullBackdrop"></div>
    <div class="relative mx-auto mt-8 w-full max-w-5xl rounded-2xl border border-white/10 bg-[#12172a] shadow-2xl overflow-hidden">
        <div class="px-5 py-4 border-b border-white/5 flex items-center justify-between gap-4">
            <div>
                <p class="text-base font-semibold text-white">Inbox complete</p>
                <p class="text-xs text-slate-400 mt-0.5">Filtres et chargement progressif</p>
            </div>
            <div class="flex items-center gap-4">
                <button id="inboxFullToggleHiddenBtn" class="text-[11px] font-semibold text-slate-400 hover:text-slate-200 border border-slate-700/50 bg-slate-800 hover:bg-slate-700 px-3 py-1.5 rounded-lg transition-colors">Voir éléments masqués</button>
                <button id="inboxFullMarkAllReadBtn" class="text-[11px] font-semibold text-violet-300 hover:text-violet-200 bg-violet-500/10 hover:bg-violet-500/20 px-3 py-1.5 rounded-lg border border-violet-500/30 transition-colors">Tout marquer comme lu</button>
                <button id="inboxFullClose" class="text-slate-400 hover:text-white text-sm">Fermer</button>
            </div>
        </div>
        <div class="px-5 py-3 border-b border-white/5" id="inboxFullFilters">
            <div class="flex flex-wrap gap-2">
                <button data-filter="all" class="inbox-full-filter px-3 py-1.5 rounded-lg text-xs font-semibold bg-violet-500/15 text-violet-300 border border-violet-500/30">Tous</button>
                <button data-filter="admin" class="inbox-full-filter px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-800 text-slate-300 border border-slate-700">Admin</button>
                <button data-filter="patch-note" class="inbox-full-filter px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-800 text-slate-300 border border-slate-700">Patch notes</button>
                <button data-filter="bug-response" class="inbox-full-filter px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-800 text-slate-300 border border-slate-700">Retours bugs</button>
            </div>
        </div>
        <div id="inboxFullList" class="max-h-[68vh] overflow-y-auto divide-y divide-white/5"></div>
        <div id="inboxFullLoading" class="hidden px-5 py-3 text-center text-xs text-slate-400 border-t border-white/5">
