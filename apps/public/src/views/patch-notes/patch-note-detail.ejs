<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= patchNote.title %> - Patch Notes - Plinkk</title>
    <link rel="stylesheet" href="/css/index.css">
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <style>
        :root {
            --color-primary: #6366f1;
            --color-bg: #fff;
            --color-text: #1f2937;
            --color-border: #e5e7eb;
            --color-hover: #f3f4f6;
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --color-bg: #0f172a;
                --color-text: #f1f5f9;
                --color-border: #334155;
                --color-hover: #1e293b;
            }
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto", "Oxygen", "Ubuntu", "Cantarell", sans-serif;
            background-color: var(--color-bg);
            color: var(--color-text);
            line-height: 1.6;
        }

        .patch-note-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        .nav-link {
            display: inline-block;
            margin-bottom: 2rem;
            padding: 0.5rem 1rem;
            border: 1px solid var(--color-border);
            border-radius: 8px;
            color: var(--color-text);
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .nav-link:hover {
            background-color: var(--color-hover);
            border-color: var(--color-primary);
        }

        .patch-note-header {
            margin-bottom: 2rem;
            padding-bottom: 2rem;
            border-bottom: 2px solid var(--color-border);
        }

        .patch-note-version {
            display: inline-block;
            background-color: var(--color-primary);
            color: white;
            padding: 0.35rem 0.85rem;
            border-radius: 9999px;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 1rem;
        }

        .patch-note-header h1 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .patch-note-meta {
            display: flex;
            align-items: center;
            gap: 2rem;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
            color: var(--color-text);
            opacity: 0.7;
        }

        .patch-note-date {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .patch-note-author {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .patch-note-author-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            background-color: var(--color-border);
        }

        .patch-note-author-info {
            display: flex;
            flex-direction: column;
            gap: 0.125rem;
        }

        .patch-note-author-name {
            font-weight: 600;
            color: var(--color-text);
            opacity: 1;
        }

        .patch-note-author-label {
            font-size: 0.75rem;
            opacity: 0.6;
        }

        .patch-note-content {
            margin: 2rem 0;
        }

        /* Markdown styling */
        .patch-note-content h2 {
            font-size: 1.5rem;
            font-weight: 700;
            margin-top: 1.5rem;
            margin-bottom: 1rem;
            color: var(--color-primary);
        }

        .patch-note-content h3 {
            font-size: 1.1rem;
            font-weight: 600;
            margin-top: 1.25rem;
            margin-bottom: 0.75rem;
        }

        .patch-note-content ul,
        .patch-note-content ol {
            margin-left: 2rem;
            margin-bottom: 1rem;
        }

        .patch-note-content li {
            margin-bottom: 0.5rem;
        }

        .patch-note-content code {
            background-color: var(--color-hover);
            padding: 0.2rem 0.5rem;
            border-radius: 4px;
            font-family: "Monaco", "Courier New", monospace;
            font-size: 0.9rem;
        }

        .patch-note-content pre {
            background-color: var(--color-hover);
            padding: 1rem;
            border-radius: 8px;
            overflow-x: auto;
            margin-bottom: 1rem;
        }

        .patch-note-content pre code {
            background-color: transparent;
            padding: 0;
        }

        .patch-note-content blockquote {
            border-left: 4px solid var(--color-primary);
            padding-left: 1rem;
            margin: 1rem 0;
            opacity: 0.8;
            font-style: italic;
        }

        .patch-note-content a {
            color: var(--color-primary);
            text-decoration: none;
            border-bottom: 1px solid transparent;
            transition: all 0.3s ease;
        }

        .patch-note-content a:hover {
            border-bottom-color: var(--color-primary);
        }

        .patch-note-content hr {
            border: none;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--color-border), transparent);
            margin: 2rem 0;
        }

        .patch-note-footer {
            margin-top: 3rem;
            padding-top: 2rem;
            border-top: 2px solid var(--color-border);
            text-align: center;
        }

        .back-button {
            display: inline-block;
            margin-top: 1rem;
            padding: 0.75rem 1.5rem;
            background-color: var(--color-primary);
            color: white;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
        }

        .back-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(99, 102, 241, 0.3);
        }

        .emoji {
            margin-right: 0.5rem;
            font-size: 1.1em;
        }
    </style>
</head>
<body>
    <div class="patch-note-container">
        <a href="/patch-notes" class="nav-link">← Retour aux patch notes</a>

        <div class="patch-note-header">
            <div class="patch-note-version"><%= patchNote.version %></div>
            <h1><%= patchNote.title %></h1>

            <div class="patch-note-meta">
                <div class="patch-note-date">
                    <span>📅</span>
                    <span><%= new Date(patchNote.publishedAt).toLocaleDateString('fr-FR', { 
                        year: 'numeric', 
                        month: 'long', 
                        day: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit'
                    }) %></span>
                </div>

                <% if (patchNote.createdBy) { %>
                    <div class="patch-note-author">
                        <% if (patchNote.createdBy.image) { %>
                            <img src="<%= patchNote.createdBy.image %>" alt="<%= patchNote.createdBy.name %>" class="patch-note-author-avatar">
                        <% } else { %>
                            <div class="patch-note-author-avatar" style="background: var(--color-primary); display: flex; align-items: center; justify-content: center;">
                                <span style="color: white; font-weight: bold;"><%= patchNote.createdBy.name.charAt(0).toUpperCase() %></span>
                            </div>
                        <% } %>
                        <div class="patch-note-author-info">
                            <span class="patch-note-author-name"><%= patchNote.createdBy.name %></span>
                            <span class="patch-note-author-label">Par</span>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="patch-note-content">
            <%- marked(patchNote.content) %>
        </div>

        <div class="patch-note-footer">
            <p style="opacity: 0.7; margin-bottom: 1rem;">Merci de votre soutien ! ❤️</p>
            <a href="/patch-notes" class="back-button">← Voir tous les patchs</a>
        </div>
    </div>
</body>
</html>
