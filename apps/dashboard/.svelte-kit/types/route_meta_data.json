{
	"/(dashboard)": [
		"src/routes/(dashboard)/+page.server.ts",
		"src/routes/+layout.server.ts"
	],
	"/": [
		"src/routes/+layout.server.ts"
	],
	"/(dashboard)/edit": [
		"src/routes/(dashboard)/edit/+page.server.ts",
		"src/routes/+layout.server.ts"
	],
	"/(auth)/login": [
		"src/routes/(auth)/login/+page.server.ts",
		"src/routes/+layout.server.ts"
	]
}