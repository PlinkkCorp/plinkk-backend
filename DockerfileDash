FROM oven/bun:1.3.10-slim

RUN apt-get update && apt-get install -y \
    openssl \
    python3 \
    build-essential \
    libcairo2-dev \
    libpango1.0-dev \
    libjpeg-dev \
    libgif-dev \
    librsvg2-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY . .

ENV CI=true

RUN bun install

RUN DATABASE_URL="postgresql://dummy:dummy@localhost:5432/dummy" bun --filter @plinkk/prisma run generate

RUN bun run --filter @plinkk/prisma build

RUN bun run --filter @plinkk/shared build

RUN bunx @fastify/secure-session > apps/dashboard/src/secret-key

RUN bun run --filter @plinkk/dashboard build

CMD ["bun", "run", "--filter", "@plinkk/dashboard", "start"]

EXPOSE 3001