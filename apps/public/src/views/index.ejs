<%- include('partials/head', { 
  title: 'Plinkk — Votre univers en un seul lien',
  description: "L'alternative open-source à Linktree. Créez une page de liens magnifique, rapide et entièrement personnalisable en quelques minutes. Thèmes illimités, statistiques intégrées, SEO optimisé.",
  metaKeywords: 'Plinkk, linktree, alternative linktree, page de liens, bio link, profil social, portfolio, réseaux sociaux, open source, gratuit, personnalisable, thèmes, statistiques, SEO',
  metaAuthor: 'Équipe Plinkk',
  pageThemeColor: 'primary',
  canonical: 'https://plinkk.fr/',
  image: 'https://cdn.plinkk.fr/og-image-home.png',
  robots: 'index,follow',
  extraHead: `
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href="https://plinkk.fr/" />
    <link rel="stylesheet" href="/public/css/landing.css" />
    
    <!-- Open Graph enrichi -->
    <meta property="og:site_name" content="Plinkk" />
    <meta property="og:title" content="Plinkk — Votre univers en un seul lien 🚀" />
    <meta property="og:description" content="L'alternative open-source à Linktree. Créez une page de liens magnifique, rapide et entièrement personnalisable." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://plinkk.fr/" />
    <meta property="og:image" content="https://cdn.plinkk.fr/landing/og-image-home.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Plinkk - Créez votre page de liens personnalisée" />
    <meta property="og:locale" content="fr_FR" />
    
    <!-- Twitter Card enrichi -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@Plinkk" />
    <meta name="twitter:title" content="Plinkk — Votre univers en un seul lien 🚀" />
    <meta name="twitter:description" content="L'alternative open-source à Linktree. Créez une page de liens magnifique, rapide et entièrement personnalisable." />
    <meta name="twitter:image" content="https://cdn.plinkk.fr/og-image-home.png" />
    <meta name="twitter:image:alt" content="Plinkk - L'alternative open-source à Linktree" />
    
    <!-- JSON-LD amélioré pour la page d'accueil -->
    <script type="application/ld+json" nonce="${cspNonce}">
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Plinkk",
      "alternateName": "Plinkk - Link in Bio",
      "url": "https://plinkk.fr",
      "description": "L'alternative open-source à Linktree. Créez une page de liens magnifique, rapide et entièrement personnalisable.",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "EUR"
      },
      "featureList": [
        "Pages de liens personnalisables",
        "Thèmes illimités",
        "Statistiques intégrées",
        "SEO optimisé",
        "Open source",
        "Gratuit"
      ],
      "screenshot": "https://cdn.plinkk.fr/og-image-home.png",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "ratingCount": "320",
        "bestRating": "5",
        "worstRating": "1"
      }
    }
    </script>
  `
}) %>
<%- include('partials/header', { user: (typeof user !=='undefined' ? user : null) }) %>

  <!-- Scroll progress bar -->
  <div class="scroll-progress">
    <div class="scroll-progress-bar" id="scrollProgress"></div>
  </div>

  <!-- Cursor glow effect -->
  <div class="cursor-glow hidden lg:block" id="cursorGlow"></div>

  <style>
    .hero-shell {
      --hero-accent-a: #00c2a8;
      --hero-accent-b: #ff7a59;
      --hero-accent-c: #0ea5e9;
      background:
        radial-gradient(1200px 520px at 10% 0%, rgba(0, 194, 168, 0.14), transparent 60%),
        radial-gradient(980px 480px at 92% 12%, rgba(255, 122, 89, 0.16), transparent 60%),
        linear-gradient(180deg, #07080d 0%, #0b1020 55%, #0a0f1a 100%);
    }

    .hero-grid {
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
      background-size: 52px 52px;
      -webkit-mask-image: radial-gradient(ellipse 82% 70% at 50% 40%, black 28%, transparent 100%);
      mask-image: radial-gradient(ellipse 82% 70% at 50% 40%, black 28%, transparent 100%);
    }
    .hero-title {
      font-family: "Sora", "Space Grotesk", "Segoe UI", sans-serif;
      font-size: clamp(2.3rem, 5.2vw, 4.5rem);
      line-height: 1.03;
      letter-spacing: -0.035em;
      font-weight: 700;
      color: #f8fafc;
      margin-top: 22px;
      margin-bottom: 16px;
    }

    .hero-title-accent {
      background: linear-gradient(92deg, #8af9ef 0%, #63d8ff 42%, #ffd3a7 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-subtitle {
      color: rgba(226, 232, 240, 0.78);
      max-width: 640px;
      margin: 0 auto 30px;
      font-size: clamp(0.98rem, 1.7vw, 1.16rem);
      line-height: 1.65;
    }

    .hero-input-wrap {
      background: rgba(8, 12, 20, 0.66);
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 18px;
      padding: 6px;
      box-shadow: 0 12px 46px rgba(5, 8, 16, 0.46);
      backdrop-filter: blur(10px);
    }

    .hero-input {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid transparent;
      transition: border-color .2s, box-shadow .2s, background .2s;
    }

    .hero-input:focus {
      outline: none;
      border-color: rgba(99, 216, 255, 0.75);
      background: rgba(255, 255, 255, 0.08);
      box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.2);
    }

    .hero-strip {
      margin-top: 16px;
      display: flex;
      justify-content: center;
      gap: 14px;
      flex-wrap: wrap;
      color: rgba(226, 232, 240, 0.66);
      font-size: 12px;
    }

    .hero-strip span {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.02);
    }

    .hero-visual {
      position: relative;
      width: min(440px, 92vw);
      margin: 26px auto 0;
      padding: 18px;
      border-radius: 28px;
      background: linear-gradient(160deg, rgba(14, 23, 37, 0.88), rgba(11, 17, 29, 0.78));
      border: 1px solid rgba(255, 255, 255, 0.14);
      box-shadow:
        0 30px 68px rgba(0, 0, 0, 0.48),
        inset 0 1px 0 rgba(255, 255, 255, 0.18);
      text-align: left;
      overflow: hidden;
    }

    .hero-visual::before {
      content: "";
      position: absolute;
      inset: -45% 45% auto -10%;
      height: 240px;
      background: radial-gradient(circle, rgba(0, 194, 168, 0.24), transparent 70%);
      pointer-events: none;
    }

    .hero-profile-chip {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px;
      color: rgba(248, 250, 252, 0.9);
      font-size: 13px;
      letter-spacing: 0.01em;
    }

    .hero-avatar {
      width: 38px;
      height: 38px;
      border-radius: 12px;
      background: linear-gradient(140deg, var(--hero-accent-a), var(--hero-accent-c));
      display: grid;
      place-items: center;
      font-weight: 700;
      color: #051018;
    }

    .hero-link-list {
      display: grid;
      gap: 10px;
    }

    .hero-link-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-radius: 14px;
      padding: 10px 12px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: rgba(241, 245, 249, 0.92);
      font-size: 13px;
      transform: translateY(12px);
      opacity: 0;
      animation: heroCardUp 0.7s ease forwards;
    }

    .hero-link-item:nth-child(2) { animation-delay: .1s; }
    .hero-link-item:nth-child(3) { animation-delay: .2s; }
    .hero-link-item:nth-child(4) { animation-delay: .3s; }

    .hero-link-item strong {
      font-weight: 600;
      letter-spacing: 0.01em;
    }

    .hero-link-item em {
      font-style: normal;
      color: rgba(203, 213, 225, 0.68);
      font-size: 11px;
    }

    .hero-link-badge {
      padding: 3px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .hero-link-badge.live {
      background: rgba(0, 194, 168, 0.18);
      color: #95fff4;
    }

    .hero-link-badge.hot {
      background: rgba(255, 122, 89, 0.22);
      color: #ffd0c4;
    }

    @keyframes heroCardUp {
      from {
        transform: translateY(12px);
        opacity: 0;
      }
      to {
        transform: translateY(0);
        opacity: 1;
      }
    }

    @media (min-width: 1024px) {
      .hero-layout {
        max-width: 720px;
        margin: 0 auto;
        text-align: center;
      }
    }
  </style>

  <main class="relative overflow-hidden">

    <section class="hero-shell relative min-h-screen flex items-center px-6 py-24 lg:py-14 overflow-hidden">

      <div class="hero-grid absolute inset-0 pointer-events-none" aria-hidden="true"></div>

      <div class="hero-layout relative z-10 w-full text-center">
        <div>
          <h1 class="reveal reveal-delay-1 hero-title">
            Votre univers en un lien.
            <span class="hero-title-accent">Clair, vivant, memorisable.</span>
          </h1>

          <p class="reveal reveal-delay-2 hero-subtitle">
            Plinkk rassemble vos contenus, offres et reseaux dans une page qui convertit vraiment. Une experience fluide inspiree des meilleurs standards creator, avec une vraie identite de marque.
          </p>

          <div class="reveal hero-input-stack mx-auto">
            <form id="heroEmailForm" data-action="prevent-submit">
              <div class="hero-input-wrap flex flex-col sm:flex-row items-stretch gap-2">
                <div class="relative flex-1">
                  <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                    <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <input type="email" id="heroEmail" required
                    class="hero-input w-full pl-10 pr-4 py-3.5 rounded-xl text-sm text-white placeholder-slate-500"
                    placeholder="vous@exemple.com" autocomplete="email" />
                </div>
                <button type="submit" id="heroEmailBtn"
                  class="magnetic-btn btn-primary px-6 py-3.5 rounded-xl text-sm font-semibold whitespace-nowrap">
                  <span class="magnetic-btn-inner">Creer mon Plinkk</span>
                </button>
              </div>
            </form>

            <div class="hero-strip">
              <span>
                <svg class="w-3.5 h-3.5 text-emerald-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Gratuit pour commencer
              </span>
              <span>
                <svg class="w-3.5 h-3.5 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Setup en 2 minutes
              </span>
              <span>
                <svg class="w-3.5 h-3.5 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Open source
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Marquee Section -->
    <section class="py-12 border-y border-white/5 overflow-hidden marquee">
      <div class="marquee-track flex items-center gap-16 whitespace-nowrap">
        <% const items=['Open Source', 'Personnalisable' , 'Rapide' , 'Gratuit' , 'Statistiques' , 'Thèmes'
          , 'Mobile First' , 'SEO Optimisé' ]; %>
          <% for(let i=0; i < 3; i++) { %>
            <% items.forEach(item=> { %>
              <span class="text-2xl lg:text-3xl font-medium text-white/20 flex items-center gap-4">
                <%= item %>
                  <span class="w-2 h-2 rounded-full bg-violet-500/50"></span>
              </span>
              <% }); %>
                <% } %>
      </div>
    </section>

    <!-- Phone Preview Section -->
    <section class="relative py-32 lg:py-48 px-6 lg:px-12">
      <div class="absolute inset-0 glow-blue pointer-events-none"></div>

      <div class="relative max-w-[1400px] mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">

          <!-- Text content -->
          <div>
            <span class="reveal text-violet-400 text-sm font-medium tracking-wider uppercase mb-4 block">Aperçu en
              direct</span>
            <h2 class="reveal reveal-delay-1 section-title text-white mb-6">
              Votre page,<br>votre identité
            </h2>
            <p class="reveal reveal-delay-2 text-lg text-slate-400 leading-relaxed mb-8 max-w-lg">
              Chaque détail compte. Personnalisez les couleurs, les polices, les animations et créez une page qui vous
              ressemble vraiment.
            </p>
            <a class="reveal reveal-delay-3 smooth-link text-white inline-flex items-center gap-2 text-lg"
              href="<%= dashboardUrl %>/join">
              Créer ma page
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3">
                </path>
              </svg>
            </a>
          </div>

          <!-- Phone mockup -->
          <div class="reveal-scale relative">
            <div class="absolute inset-0 phone-glow -z-10 scale-150"></div>
            <div class="parallax relative mx-auto w-[280px] lg:w-[320px]" data-speed="0.05">
              <!-- Phone frame -->
              <div class="relative bg-zinc-900 rounded-[3rem] p-3 ring-1 ring-white/10">
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-28 h-6 bg-zinc-900 rounded-b-2xl z-10"></div>
                <div class="relative rounded-[2.3rem] overflow-hidden bg-black aspect-[9/19]">
                  <iframe src="<%= typeof frontendUrl !== 'undefined' ? frontendUrl : '' %>/demo?preview=1"
                    class="absolute inset-0 w-full h-full border-0" title="Preview" loading="lazy"></iframe>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-32 px-6 lg:px-12 border-y border-white/5">
      <div class="max-w-[1400px] mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-24">

          <div class="reveal text-center md:text-left">
            <p class="big-number gradient-text counter"
              data-target="<%= typeof userCount !== 'undefined' ? userCount : 0 %>">0</p>
            <p class="text-slate-400 text-lg mt-2">Créateurs actifs</p>
          </div>

          <div class="reveal reveal-delay-1 text-center md:text-left">
            <p class="big-number gradient-text counter"
              data-target="<%= typeof linkCount !== 'undefined' ? linkCount : 0 %>">0</p>
            <p class="text-slate-400 text-lg mt-2">Liens partagés</p>
          </div>

          <div class="reveal reveal-delay-2 text-center md:text-left">
            <p class="big-number gradient-text counter"
              data-target="<%= typeof totalViews !== 'undefined' ? totalViews : 0 %>">0</p>
            <p class="text-slate-400 text-lg mt-2">Vues totales</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Grid -->
    <section class="py-20 lg:py-28 px-6 lg:px-12">
      <div class="max-w-[1400px] mx-auto">

        <!-- Section header -->
        <div class="text-center max-w-xl mx-auto mb-12">
          <span class="reveal text-violet-400 text-xs font-semibold tracking-widest uppercase mb-3 block">Fonctionnalités</span>
          <h2 class="reveal reveal-delay-1 section-title text-white mb-4">Tout pour votre page</h2>
          <p class="reveal reveal-delay-2 text-base text-slate-400 leading-relaxed">
            Des outils puissants, une expérience simple.
          </p>
        </div>

        <!-- Feature grid — 4 cards égales -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">

          <div class="reveal feature-item rounded-2xl p-6">
            <div class="w-10 h-10 rounded-xl bg-violet-500/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008z"/></svg>
            </div>
            <h3 class="text-base font-semibold text-white mb-2">Personnalisation</h3>
            <p class="text-sm text-slate-400 leading-relaxed">Couleurs, thèmes et animations pour refléter votre identité.</p>
          </div>

          <div class="reveal reveal-delay-1 feature-item rounded-2xl p-6">
            <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
            </div>
            <h3 class="text-base font-semibold text-white mb-2">Statistiques</h3>
            <p class="text-sm text-slate-400 leading-relaxed">Clics, sources et performances en temps réel.</p>
          </div>

          <div class="reveal reveal-delay-2 feature-item rounded-2xl p-6">
            <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
            </div>
            <h3 class="text-base font-semibold text-white mb-2">Ultra rapide</h3>
            <p class="text-sm text-slate-400 leading-relaxed">Pages chargées en moins de 100 ms, partout.</p>
          </div>

          <div class="reveal reveal-delay-3 feature-item rounded-2xl p-6">
            <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
            </div>
            <h3 class="text-base font-semibold text-white mb-2">Open Source</h3>
            <p class="text-sm text-slate-400 leading-relaxed">Code transparent. Vos données restent vôtres.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- Feature Showcase - Horizontal Scroll -->
    <div class="horizontal-section-spacer" id="horizontalSpacer"></div>
    <section class="horizontal-section" id="howItWorks">
      <div class="horizontal-scroll-container">
        <div class="horizontal-scroll-track" id="horizontalTrack">

          <!-- Panel 0: Intro -->
          <div class="horizontal-panel">
            <div class="step-card active" data-step="0">
              <div class="showcase-intro">
                <span class="showcase-badge">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                  Explorez Plinkk
                </span>
                <h2 class="section-title text-white mb-6">
                  Tout ce dont vous avez<br><span class="gradient-text-color">besoin. Rien de plus.</span>
                </h2>
                <p class="text-lg text-slate-400 leading-relaxed max-w-lg mx-auto">
                  Un outil complet, pensé pour les créateurs qui veulent une page rapide, belle, et sous leur contrôle total.
                </p>
                <div class="showcase-intro-features">
