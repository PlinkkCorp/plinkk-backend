<%- include('partials/head.ejs', {
  title: 'Inbox',
  description: 'Retrouvez vos messages admin, mises à jour et réponses aux bugs.',
  metaKeywords: 'notifications, inbox, patch notes, messages admin',
  robots: 'noindex,nofollow'
}) %>

<%- include('partials/header-dash.ejs', { user: user }) %>

<div class="max-w-[1600px] mx-auto grid grid-cols-12 gap-6 px-4 py-8">
  <%- include('partials/asside_dash.ejs', { user: user, active: 'inbox' }) %>

  <main class="col-span-12 lg:col-span-10 space-y-6">
    <section class="bg-slate-900 border border-slate-800 rounded-3xl p-6 md:p-8">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h1 class="text-3xl font-bold text-white">Inbox</h1>
          <p class="text-sm text-slate-400 mt-1">Messages de l'équipe, patch notes et retours sur vos signalements.</p>
        </div>
        <div class="flex items-center gap-2">
          <button type="button" id="markAllReadBtn" class="px-4 py-2 rounded-xl text-xs font-semibold bg-slate-800 text-slate-300 hover:bg-slate-700 border border-slate-700 transition-colors">
            Tout marquer lu
          </button>
        </div>
      </div>

      <div class="mt-6 flex flex-wrap gap-2" id="inboxFilters">
        <button data-filter="all" class="inbox-filter px-3 py-1.5 rounded-lg text-xs font-semibold bg-violet-500/15 text-violet-300 border border-violet-500/30">Tous</button>
        <button data-filter="admin" class="inbox-filter px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-800 text-slate-300 border border-slate-700">Admin</button>
        <button data-filter="patch-note" class="inbox-filter px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-800 text-slate-300 border border-slate-700">Patch notes</button>
        <button data-filter="bug-response" class="inbox-filter px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-800 text-slate-300 border border-slate-700">Retours bugs</button>
      </div>
    </section>

    <section class="space-y-3" id="inboxList">
      <% if (!inboxItems || inboxItems.length === 0) { %>
        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-10 text-center text-slate-400">
          Votre inbox est vide pour le moment.
        </div>
      <% } else { %>
        <% inboxItems.forEach(function(item) { %>
          <article
            class="inbox-item bg-slate-900 border border-slate-800 rounded-2xl p-5 transition-all cursor-pointer hover:border-slate-700 <%= !item.isRead ? 'border-violet-500/50 bg-violet-950/20' : '' %>"
            data-item-id="<%= item.id %>"
            data-item-type="<%= item.type %>">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 mb-2 flex-wrap">
                  <% if (!item.isRead) { %>
                    <span class="inline-block w-2 h-2 rounded-full bg-violet-500"></span>
                  <% } %>
                  <span class="text-[10px] uppercase tracking-wider font-bold px-2 py-0.5 rounded-full border border-slate-700 bg-slate-800 text-slate-300"><%= item.type %></span>
                  <% 
                    let priorityClass = 'bg-slate-700 text-slate-300';
                    let priorityLabel = item.priority || 'NORMAL';
                    if (item.priority === 'URGENT') {
                      priorityClass = 'bg-red-500/20 text-red-300 border-red-500/50';
                    } else if (item.priority === 'NORMAL') {
                      priorityClass = 'bg-blue-500/20 text-blue-300 border-blue-500/50';
                    }
                  %>
                  <span class="text-[10px] uppercase tracking-wider font-bold px-2 py-0.5 rounded-full border <%= priorityClass %>"><%= priorityLabel %></span>
                  <span class="text-xs text-slate-500"><%= new Date(item.createdAt).toLocaleString('fr-FR') %></span>
                </div>
                <h2 class="text-white font-semibold text-base"><%= item.title %></h2>
                <p class="text-sm text-slate-300 mt-1 whitespace-pre-wrap line-clamp-2"><%= item.text %></p>
                <div class="flex gap-2 mt-3">
                  <% if (item.type === 'bug-response') { %>
                    <button type="button" class="bug-ticket-btn inline-flex text-xs text-violet-300 hover:text-violet-200 font-semibold" data-item-id="<%= item.id %>">
                      Ouvrir le ticket
                    </button>
                  <% } %>
                  <% if (item.link) { %>
                    <a class="inline-flex text-xs text-violet-300 hover:text-violet-200" href="<%= item.link %>">Voir le détail</a>
                  <% } %>
                </div>
              </div>
              <div class="flex flex-col items-end gap-2 shrink-0">
                <button type="button" class="mark-read-btn shrink-0 px-3 py-1.5 rounded-lg text-[11px] font-semibold bg-slate-800 text-slate-300 border border-slate-700 hover:bg-slate-700 transition-colors">
                  <%= item.isRead ? 'Marquer non lu' : 'Marquer lu' %>
                </button>
                <button type="button" class="delete-inbox-btn shrink-0 p-1.5 rounded-md text-slate-500 hover:text-rose-400 hover:bg-rose-500/10 transition-colors" title="Cacher cette notification">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M10 11v6M14 11v6"/></svg>
                </button>
              </div>
            </div>
          </article>
        <% }) %>
      <% } %>
    </section>
  </main>
</div>


<script>
(function () {
  const filtersWrap = document.getElementById('inboxFilters');
  const list = document.getElementById('inboxList');
  const markAllReadBtn = document.getElementById('markAllReadBtn');

  function getHiddenInboxIds() {
    try {
      return JSON.parse(localStorage.getItem('plinkk_hidden_inbox_items') || '[]');
    } catch(e) { return []; }
  }
  function hideInboxItem(id) {
    const hidden = getHiddenInboxIds();
    if (!hidden.includes(id)) {
        hidden.push(id);
        localStorage.setItem('plinkk_hidden_inbox_items', JSON.stringify(hidden));
    }
  }

  const hiddenIds = getHiddenInboxIds();
  document.querySelectorAll('.inbox-item').forEach(function(item) {
    const id = item.getAttribute('data-item-id');
    if (hiddenIds.includes(id)) {
      item.remove();
    }
  });

  function setActiveFilterButton(type) {
    document.querySelectorAll('.inbox-filter').forEach(function (btn) {
      const t = btn.getAttribute('data-filter');
      if (t === type) {
        btn.classList.add('bg-violet-500/15', 'text-violet-300', 'border-violet-500/30');
        btn.classList.remove('bg-slate-800', 'text-slate-300', 'border-slate-700');
      } else {
        btn.classList.remove('bg-violet-500/15', 'text-violet-300', 'border-violet-500/30');
        btn.classList.add('bg-slate-800', 'text-slate-300', 'border-slate-700');
      }
    });
  }

  function applyFilter(type) {
    document.querySelectorAll('.inbox-item').forEach(function (item) {
      const itemType = item.getAttribute('data-item-type');
      const visible = type === 'all' || itemType === type;
      item.style.display = visible ? '' : 'none';
    });
    setActiveFilterButton(type);
  }

  if (filtersWrap) {
    filtersWrap.addEventListener('click', function (event) {
      const btn = event.target.closest('.inbox-filter');
      if (!btn) return;
      applyFilter(btn.getAttribute('data-filter') || 'all');
    });
  }

  if (list) {
    list.addEventListener('click', async function (event) {
      const markBtn = event.target.closest('.mark-read-btn');
      if (markBtn) {
        const card = markBtn.closest('.inbox-item');
        const id = card ? card.getAttribute('data-item-id') : null;
        const type = card ? card.getAttribute('data-item-type') : null;
        if (!id) return;
        try {
          await fetch('/api/me/inbox/' + encodeURIComponent(id) + '/read', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ itemType: type === 'bug-response' ? 'announcement' : type })
          });
          location.reload();
        } catch (err) {
          console.error('Error:', err);
        }
        return;
      }

      const delBtn = event.target.closest('.delete-inbox-btn');
      if (delBtn) {
        const card = delBtn.closest('.inbox-item');
        const id = card ? card.getAttribute('data-item-id') : null;
        const type = card ? card.getAttribute('data-item-type') : null;
        if (!id) return;
        hideInboxItem(id);
        
        // Also mark as read in background if needed
        const isNotRead = card.classList.contains('border-violet-500/50');
        if (isNotRead) {
          try {
            fetch('/api/me/inbox/' + encodeURIComponent(id) + '/read', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ itemType: type === 'bug-response' ? 'announcement' : type })
            });
          } catch(e) {}
        }
        card.remove();
        return;
      }

      const bugBtn = event.target.closest('.bug-ticket-btn');
      if (bugBtn) {
        const card = bugBtn.closest('.inbox-item');
        const id = bugBtn.getAttribute('data-item-id');
        const titleElem = card ? card.querySelector('h2') : null;
        const textElem = card ? card.querySelector('p') : null;
        const title = titleElem ? titleElem.textContent : 'Ticket';
        const text = textElem ? textElem.textContent : '';
        window.showBugTicket(id, title, text);
        return;
      }
    });
  }

  if (markAllReadBtn) {
    markAllReadBtn.addEventListener('click', async function () {
      try {
        await fetch('/api/me/inbox/read-all', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        location.reload();
      } catch (err) {
        console.error('Error:', err);
      }
    });
  }

  applyFilter('all');
})();
</script>

<%- include('partials/bug-ticket-modal.ejs') %>

</body>
</html>
