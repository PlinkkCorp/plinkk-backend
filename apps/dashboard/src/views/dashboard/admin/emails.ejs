<%- include('partials/head.ejs', { title: 'Emails - Administration' , description: 'Gestion et envoi d\'emails personnalisés.' , robots: 'noindex,nofollow' }) %>
    <%- include('partials/header-dash.ejs', { user: user }) %>

        <div class="max-w-[1600px] mx-auto grid grid-cols-12 gap-6 px-4 py-8">
            <%- include('partials/admin-nav.ejs', { user: user, active: 'emails' }) %>

                <main class="col-span-12 lg:col-span-10 space-y-6">
                    <!-- Header compact -->
                    <div class="flex items-center justify-between bg-gradient-to-r from-slate-900 to-slate-800 p-6 rounded-2xl border border-slate-800">
                        <div>
                            <h1 class="text-2xl font-bold text-white flex items-center gap-2">
                                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                                Gestion d'Emails
                            </h1>
                            <p class="text-slate-400 text-sm mt-1">Campagnes, quotas & file d'attente</p>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="emailToggle" class="sr-only peer" <%= emailsEnabled ? 'checked' : '' %>>
                            <div class="w-11 h-6 bg-slate-700 peer-focus:ring-2 peer-focus:ring-blue-600 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                            <span class="ml-2 text-sm font-medium text-slate-300">Envoi actif</span>
                        </label>
                    </div>

                    <!-- Stats compactes -->
                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
                        <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl">
                            <div class="text-slate-500 text-xs mb-1">Campagnes</div>
                            <div class="text-2xl font-bold text-blue-400" id="statCampaigns">0</div>
                        </div>
                        <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl">
                            <div class="text-slate-500 text-xs mb-1">Envoyés</div>
                            <div class="text-2xl font-bold text-blue-400" id="statEmailsSent">0</div>
                        </div>
                        <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl">
                            <div class="text-slate-500 text-xs mb-1">Ouvertures</div>
                            <div class="text-2xl font-bold text-emerald-400" id="statOpenRate">0%</div>
                        </div>
                        <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl">
                            <div class="text-slate-500 text-xs mb-1">Clics</div>
                            <div class="text-2xl font-bold text-amber-400" id="statClickRate">0%</div>
                        </div>
                    </div>

                    <!-- Quota & File d'attente (sections accordéon) -->
                    <div class="space-y-3">
                        <!-- Section Quota -->
                        <details class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden group" open>
                            <summary class="cursor-pointer p-4 hover:bg-slate-800/50 transition-colors flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                                    <span class="font-semibold text-white">Quota Mensuel</span>
                                    <span class="text-xs px-2 py-1 rounded-full <%= quota.alert === 'critical' ? 'bg-red-500/20 text-red-300' : quota.alert === 'warning' ? 'bg-amber-500/20 text-amber-300' : 'bg-emerald-500/20 text-emerald-300' %>">
                                        <%= quota.total %> / <%= quota.limit %>
                                    </span>
                                </div>
                                <svg class="w-4 h-4 text-slate-400 transition-transform group-open:rotate-180" fill="currentColor" viewBox="0 0 20 20"><path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg>
                            </summary>
                            <div class="p-4 pt-0 space-y-4">
                                <!-- Compteurs compacts -->
                                <div class="grid grid-cols-4 gap-2">
                                    <div class="bg-slate-950/50 p-2 rounded-lg text-center">
                                        <div class="text-xs text-slate-500">OTP</div>
                                        <div class="text-lg font-bold text-blue-400"><%= quota.otp %></div>
                                    </div>
                                    <div class="bg-slate-950/50 p-2 rounded-lg text-center">
                                        <div class="text-xs text-slate-500">Campagnes</div>
                                        <div class="text-lg font-bold text-purple-400"><%= quota.campaign %></div>
                                    </div>
                                    <div class="bg-slate-950/50 p-2 rounded-lg text-center">
                                        <div class="text-xs text-slate-500">Bienvenue</div>
                                        <div class="text-lg font-bold text-emerald-400"><%= quota.welcome %></div>
                                    </div>
                                    <div class="bg-slate-950/50 p-2 rounded-lg text-center">
                                        <div class="text-xs text-slate-500">Autres</div>
                                        <div class="text-lg font-bold text-amber-400"><%= quota.other %></div>
                                    </div>
                                </div>

                                <!-- Barre de progression -->
                                <div class="space-y-2">
                                    <div class="flex items-center justify-between text-xs">
                                        <span class="text-slate-400">Utilisation</span>
                                        <span class="font-bold <%= quota.alert === 'critical' ? 'text-red-400' : quota.alert === 'warning' ? 'text-amber-400' : 'text-emerald-400' %>">
                                            <%= Number(quota.percentUsed || 0).toLocaleString('fr-FR', { minimumFractionDigits: 3, maximumFractionDigits: 6 }) %>%
                                        </span>
                                    </div>
                                    <div class="relative h-4 bg-slate-800 rounded-full overflow-hidden">
                                        <div class="absolute inset-y-0 left-0 <%= quota.alert === 'critical' ? 'bg-red-500' : quota.alert === 'warning' ? 'bg-amber-500' : 'bg-emerald-500' %> transition-all rounded-full" style="width: <%= quota.percentUsed %>%"></div>
                                    </div>
                                </div>

                                <!-- Alerte -->
                                <% if (quota.alert === 'critical') { %>
                                <div class="bg-red-500/10 border border-red-500/30 rounded-lg p-3 text-xs text-red-200 flex items-start gap-2">
                                    <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
                                    <span>Quota critique atteint. Envois limités.</span>
                                </div>
                                <% } else if (quota.alert === 'warning') { %>
                                <div class="bg-amber-500/10 border border-amber-500/30 rounded-lg p-3 text-xs text-amber-200 flex items-start gap-2">
                                    <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
                                    <span>Attention au quota (<%= quota.percentUsed %>%).</span>
                                </div>
                                <% } %>
                            </div>
                        </details>

                        <!-- Section File d'attente -->
                        <details class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden group">
                            <summary class="cursor-pointer p-4 hover:bg-slate-800/50 transition-colors flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <svg class="w-5 h-5 text-purple-400" fill="currentColor" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/></svg>
                                    <span class="font-semibold text-white">File d'attente</span>
                                    <span class="text-xs px-2 py-1 rounded-full bg-orange-500/20 text-orange-300">
                                        <%= queueStats.pending %> en attente
                                    </span>
                                </div>
                                <svg class="w-4 h-4 text-slate-400 transition-transform group-open:rotate-180" fill="currentColor" viewBox="0 0 20 20"><path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg>
                            </summary>
                            <div class="p-4 pt-0 space-y-4">
                                <!-- Stats queue -->
                                <div class="grid grid-cols-4 gap-2">
                                    <div class="bg-orange-500/10 p-2 rounded-lg text-center border border-orange-500/20">
                                        <div class="text-xs text-orange-300">En attente</div>
                                        <div class="text-lg font-bold text-orange-400"><%= queueStats.pending %></div>
                                    </div>
                                    <div class="bg-blue-500/10 p-2 rounded-lg text-center border border-blue-500/20">
                                        <div class="text-xs text-blue-300">En cours</div>
                                        <div class="text-lg font-bold text-blue-400"><%= queueStats.processing %></div>
                                    </div>
                                    <div class="bg-emerald-500/10 p-2 rounded-lg text-center border border-emerald-500/20">
                                        <div class="text-xs text-emerald-300">Envoyés</div>
                                        <div class="text-lg font-bold text-emerald-400"><%= queueStats.sent %></div>
                                    </div>
                                    <div class="bg-red-500/10 p-2 rounded-lg text-center border border-red-500/20">
                                        <div class="text-xs text-red-300">Échoués</div>
                                        <div class="text-lg font-bold text-red-400"><%= queueStats.failed %></div>
                                    </div>
                                </div>

                                <!-- Bouton traiter -->
                                <button onclick="processQueue()" id="processBtn" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-medium py-2 px-4 rounded-lg transition-colors text-sm">
                                    🚀 Traiter la queue maintenant
                                </button>

                                <!-- Table queue -->
                                <% if (queue.length > 0) { %>
                                <div class="overflow-x-auto -mx-4 px-4">
                                    <table class="w-full text-xs">
                                        <thead class="text-slate-400 border-b border-slate-700">
                                            <tr>
                                                <th class="text-left py-2 px-2">Date</th>          
                                                <th class="text-left py-2 px-2">Destinataire</th>
                                                <th class="text-left py-2 px-2">Type</th>
                                                <th class="text-center py-2 px-2">Priorité</th>
                                                <th class="text-center py-2 px-2">Statut</th>
                                                <th class="text-center py-2 px-2">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody class="text-slate-300">
                                            <% queue.slice(0, 10).forEach(email => { %>
                                            <tr class="border-b border-slate-800/50 hover:bg-slate-800/30">
                                                <td class="py-2 px-2"><%= new Date(email.createdAt).toLocaleDateString('fr-FR') %></td>
                                                <td class="py-2 px-2 truncate max-w-[150px]" title="<%= email.to.join(', ') %>"><%= email.to[0] %></td>
                                                <td class="py-2 px-2"><%= email.emailType %></td>
                                                <td class="py-2 px-2 text-center">
                                                    <span class="px-1.5 py-0.5 rounded <%= email.priority >= 7 ? 'bg-red-500/20 text-red-300' : 'bg-slate-700 text-slate-300' %>">
                                                        <%= email.priority %>
                                                    </span>
                                                </td>
                                                <td class="py-2 px-2 text-center">
                                                    <span class="px-2 py-0.5 rounded text-[10px] font-semibold uppercase <%= email.status === 'PENDING' ? 'bg-orange-500/20 text-orange-300' : email.status === 'PROCESSING' ? 'bg-blue-500/20 text-blue-300' : email.status === 'SENT' ? 'bg-emerald-500/20 text-emerald-300' : 'bg-red-500/20 text-red-300' %>">
                                                        <%= email.status %>
                                                    </span>
                                                </td>
                                                <td class="py-2 px-2 text-center">
                                                    <% if (email.status === 'PENDING') { %>
                                                    <button onclick="cancelEmail('<%= email.id %>')" class="text-red-400 hover:text-red-300 text-xs">
                                                        ❌
                                                    </button>
                                                    <% } else { %>
                                                    -
                                                    <% } %>
                                                </td>
                                            </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                    <% if (queue.length > 10) { %>
                                    <p class="text-center text-xs text-slate-500 mt-2">+ <%= queue.length - 10 %> autres emails en queue</p>
                                    <% } %>
                                </div>
                                <% } else { %>
                                <p class="text-center text-slate-500 text-sm py-4">✅ Aucun email en attente</p>
                                <% } %>
                            </div>
                        </details>

                        <!-- Section Formulaire d'envoi -->
                        <details class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden group">
                            <summary class="cursor-pointer p-4 hover:bg-slate-800/50 transition-colors flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                                    <span class="font-semibold text-white">Nouvelle Campagne</span>
                                </div>
                                <svg class="w-4 h-4 text-slate-400 transition-transform group-open:rotate-180" fill="currentColor" viewBox="0 0 20 20"><path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg>
                            </summary>
                            <div class="p-4 pt-0">
                                <form id="emailForm" class="space-y-4">
                            <!-- Type de destinataires -->
                            <div>
                                <label class="block text-xs font-semibold text-slate-400 mb-2">Destinataires</label>
                                <div class="grid grid-cols-2 gap-2">
                                    <label class="flex items-center p-2 border border-slate-700 rounded-lg cursor-pointer hover:border-blue-500 transition-colors has-[:checked]:border-blue-500 has-[:checked]:bg-blue-500/10">
                                        <input type="radio" name="recipientType" value="all" checked class="mr-2 w-4 h-4">
                                        <span class="text-white text-sm">Tous</span>
                                    </label>
                                    <label class="flex items-center p-2 border border-slate-700 rounded-lg cursor-pointer hover:border-blue-500 transition-colors has-[:checked]:border-blue-500 has-[:checked]:bg-blue-500/10">
                                        <input type="radio" name="recipientType" value="staff" class="mr-2 w-4 h-4">
                                        <span class="text-white text-sm">Staff</span>
                                    </label>
                                    <label class="flex items-center p-2 border border-slate-700 rounded-lg cursor-pointer hover:border-blue-500 transition-colors has-[:checked]:border-blue-500 has-[:checked]:bg-blue-500/10">
                                        <input type="radio" name="recipientType" value="admin" class="mr-2 w-4 h-4">
                                        <span class="text-white text-sm">Admin</span>
                                    </label>
                                    <label class="flex items-center p-2 border border-slate-700 rounded-lg cursor-pointer hover:border-blue-500 transition-colors has-[:checked]:border-blue-500 has-[:checked]:bg-blue-500/10">
                                        <input type="radio" name="recipientType" value="role" class="mr-2 w-4 h-4">
                                        <span class="text-white text-sm">Par rôle</span>
                                    </label>
                                    <label class="flex items-center p-2 border border-slate-700 rounded-lg cursor-pointer hover:border-blue-500 transition-colors has-[:checked]:border-blue-500 has-[:checked]:bg-blue-500/10">
                                        <input type="radio" name="recipientType" value="custom" class="mr-2 w-4 h-4">
                                        <span class="text-white text-sm">Personnalisé</span>
                                    </label>
                                </div>
                            </div>

                            <div id="roleRecipientsField" class="hidden">
                                <label class="block text-sm font-semibold text-white mb-2">Rôle ciblé</label>
                                <select name="roleId" id="roleSelect" class="w-full bg-slate-800 border border-slate-700 rounded-2xl p-3 text-white focus:border-blue-500 focus:outline-none transition-colors">
                                    <option value="">Sélectionner un rôle</option>
                                    <% (roles || []).forEach(role => { %>
                                        <option value="<%= role.id %>"><%= role.name %><%= role.isStaff ? ' (staff)' : '' %></option>
                                    <% }) %>
                                </select>
                            </div>

                            <!-- Destinataires customisés -->
                            <div id="customRecipientsField" class="hidden">
                                <label class="block text-sm font-semibold text-white mb-2">Adresses emails (une par ligne)</label>
                                <textarea name="recipients" rows="4" placeholder="email1@example.com&#10;email2@example.com&#10;email3@example.com" class="w-full bg-slate-800 border border-slate-700 rounded-2xl p-4 text-white font-mono text-sm placeholder-slate-500 focus:border-blue-500 focus:outline-none transition-colors"></textarea>
                            </div>

                            <!-- Catégorie -->
                            <div>
                                <label class="block text-sm font-semibold text-white mb-3">Catégorie</label>
                                <select name="category" class="w-full bg-slate-800 border border-slate-700 rounded-2xl p-3 text-white focus:border-blue-500 focus:outline-none transition-colors">
                                    <option value="announcement">Annonce</option>
                                    <option value="feature">Nouvelle fonctionnalité</option>
                                    <option value="update">Mise à jour</option>
                                    <option value="security">Sécurité</option>
                                    <option value="other">Autre</option>
                                </select>
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-white mb-2">Template (optionnel)</label>
                                <div class="flex gap-3">
                                    <select name="templateId" id="templateSelect" class="flex-1 bg-slate-800 border border-slate-700 rounded-2xl p-3 text-white focus:border-blue-500 focus:outline-none transition-colors">
                                        <option value="">Aucun template (saisie manuelle)</option>
                                    </select>
                                    <button type="button" id="saveAsTemplateBtn" class="px-4 py-3 bg-slate-800 hover:bg-slate-700 text-white font-medium rounded-2xl transition-colors">
                                        Sauver template
                                    </button>
                                </div>
                            </div>

                            <!-- Sujet -->
                            <div>
                                <label class="block text-sm font-semibold text-white mb-2">Sujet de l'email</label>
                                <input type="text" name="subject" placeholder="ex: Nouvelle fonctionnalité disponible" required class="w-full bg-slate-800 border border-slate-700 rounded-2xl p-3 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none transition-colors">
                            </div>

                            <!-- Titre -->
                            <div>
                                <label class="block text-sm font-semibold text-white mb-2">Titre de l'email</label>
                                <input type="text" name="title" placeholder="ex: Découvrez notre nouvelle fonctionnalité" required class="w-full bg-slate-800 border border-slate-700 rounded-2xl p-3 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none transition-colors">
                            </div>

                            <!-- Message -->
                            <div>
                                <label class="block text-sm font-semibold text-white mb-2">Message</label>
                                <textarea name="message" rows="6" placeholder="Entrez votre message ici..." required class="w-full bg-slate-800 border border-slate-700 rounded-2xl p-4 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none transition-colors resize-none"></textarea>
                            </div>

                            <!-- Lien d'action (optionnel) -->
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-semibold text-white mb-2">URL d'action (optionnel)</label>
                                    <input type="url" name="actionUrl" placeholder="ex: https://plinkk.fr/features" class="w-full bg-slate-800 border border-slate-700 rounded-2xl p-3 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none transition-colors">
                                </div>
                                <div>
                                    <label class="block text-sm font-semibold text-white mb-2">Texte du bouton (optionnel)</label>
                                    <input type="text" name="actionText" placeholder="ex: Découvrir" class="w-full bg-slate-800 border border-slate-700 rounded-2xl p-3 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none transition-colors">
                                </div>
                            </div>

                            <!-- Aperçu -->
                            <div class="bg-slate-800 border border-slate-700 rounded-2xl p-4">
                                <details class="cursor-pointer">
                                    <summary class="text-sm font-semibold text-white select-none hover:text-blue-400 transition-colors flex items-center gap-2">
                                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
                                        Aperçu de l'email
                                    </summary>
                                    <div class="mt-4 pt-4 border-t border-slate-700 space-y-2 text-sm text-slate-300">
                                        <p><strong>Catégorie:</strong> <span id="previewCategory">Annonce</span></p>
                                        <p><strong>Sujet:</strong> <span id="previewSubject">-</span></p>
                                        <p><strong>Titre:</strong> <span id="previewTitle">-</span></p>
                                        <p><strong>Message:</strong> <span id="previewMessage">-</span></p>
                                        <p id="previewAction" class="hidden"><strong>Bouton:</strong> <span id="previewActionText">-</span> → <span id="previewActionUrl">-</span></p>
                                    </div>
                                </details>
                            </div>

                            <!-- Confirmation -->
                            <div class="bg-blue-500/10 border border-blue-500/50 rounded-2xl p-4">
                                <p class="text-sm text-blue-200 flex items-start gap-2">
                                    <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
                                    <span>Cet email sera envoyé à <strong id="recipientCountDisplay">tous les utilisateurs</strong>. Cette action ne peut pas être annulée.</span>
                                </p>
                            </div>

                            <!-- Boutons -->
                            <div class="flex gap-3 pt-4">
                                <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-2xl transition-colors">
                                    Envoyer la campagne
                                </button>
                                <button type="reset" class="px-6 py-3 bg-slate-800 hover:bg-slate-700 text-white font-medium rounded-2xl transition-colors">
                                    Réinitialiser
                                </button>
                            </div>
                        </form>
                    </div>
                    </details>

                    <!-- Historique des campagnes -->
                    <div class="bg-slate-900 border border-slate-800 rounded-3xl p-8">
                        <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.1 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v16z"/></svg>
                            Historique des campagnes
                        </h2>
                        <div id="campaignsHistory" class="space-y-3 text-slate-400">
                            <p class="text-center py-8">Chargement...</p>
                        </div>
                    </div>
                </main>
        </div>

        <script>
            // Gérer l'affichage des destinataires personnalisés
            document.querySelectorAll('input[name="recipientType"]').forEach(radio => {
                radio.addEventListener('change', () => {
                    const customField = document.getElementById('customRecipientsField');
                    const displayTexts = {
                        all: 'tous les utilisateurs',
                        staff: 'tous les membres du staff',
                        admin: 'tous les administrateurs',
                        role: 'les utilisateurs du rôle sélectionné',
                        custom: 'les destinataires spécifiés'
                    };
                    
                    document.getElementById('recipientCountDisplay').textContent = 
                        displayTexts[radio.value] || 'tous les utilisateurs';
                    
                    customField.classList.toggle('hidden', radio.value !== 'custom');
                    document.getElementById('roleRecipientsField')?.classList.toggle('hidden', radio.value !== 'role');
                });
            });

            const roleSelect = document.getElementById('roleSelect');
            roleSelect?.addEventListener('change', () => {
                const roleLabel = roleSelect.options[roleSelect.selectedIndex]?.text || 'rôle sélectionné';
                const recipientText = roleSelect.value ? `les utilisateurs avec le rôle ${roleLabel}` : 'les utilisateurs du rôle sélectionné';
                const selected = document.querySelector('input[name="recipientType"]:checked');
                if (selected?.value === 'role') {
                    document.getElementById('recipientCountDisplay').textContent = recipientText;
                }
            });

            // Mise à jour de l'aperçu
            const form = document.getElementById('emailForm');
            const templateSelect = document.getElementById('templateSelect');
            const saveAsTemplateBtn = document.getElementById('saveAsTemplateBtn');
            let loadedTemplates = [];

            async function parseJsonSafe(response) {
                const raw = await response.text();
                if (!raw) return {};
                try {
                    return JSON.parse(raw);
                } catch {
                    throw new Error(`Réponse non JSON (${response.status})`);
                }
            }

            ['subject', 'title', 'message', 'category', 'actionText', 'actionUrl'].forEach(field => {
                const input = form.querySelector(`[name="${field}"]`);
                input?.addEventListener('input', () => {
                    document.getElementById(`preview${field.charAt(0).toUpperCase() + field.slice(1)}`).textContent = 
                        input.value || '-';
                    
                    const actionDetails = document.getElementById('previewAction');
                    const actionUrl = form.querySelector('[name="actionUrl"]').value;
                    const actionText = form.querySelector('[name="actionText"]').value;
                    if (actionUrl && actionText) {
                        actionDetails.classList.remove('hidden');
                    } else {
                        actionDetails.classList.add('hidden');
                    }
                });
            });

            async function loadStats() {
                try {
                    const response = await fetch('/api/admin/emails/stats');
                    const stats = await parseJsonSafe(response);
                    if (!response.ok) return;

                    document.getElementById('statCampaigns').textContent = String(stats.totalCampaigns || 0);
                    document.getElementById('statEmailsSent').textContent = String(stats.totalEmailsSent || 0);
                    document.getElementById('statOpenRate').textContent = `${stats.openRate || 0}%`;
                    document.getElementById('statClickRate').textContent = `${stats.clickRate || 0}%`;
                } catch (error) {
                    console.error('Erreur chargement stats emails:', error);
                }
            }

            async function loadTemplates() {
                try {
                    const response = await fetch('/api/admin/emails/templates');
                    const templates = await parseJsonSafe(response);
                    if (!response.ok) return;

                    loadedTemplates = templates;
                    templateSelect.innerHTML = '<option value="">Aucun template (saisie manuelle)</option>' +
                        templates.map(t => `<option value="${t.id}">${t.name}</option>`).join('');
                } catch (error) {
                    console.error('Erreur chargement templates:', error);
                }
            }

            templateSelect.addEventListener('change', () => {
                const selected = loadedTemplates.find(t => t.id === templateSelect.value);
                if (!selected) return;

                form.querySelector('[name="subject"]').value = selected.subject || '';
                form.querySelector('[name="title"]').value = selected.title || '';
                form.querySelector('[name="message"]').value = selected.message || '';
                form.querySelector('[name="category"]').value = selected.category || 'announcement';
                form.querySelector('[name="actionText"]').value = selected.actionText || '';
                form.querySelector('[name="actionUrl"]').value = selected.actionUrl || '';

                ['subject', 'title', 'message', 'category', 'actionText', 'actionUrl'].forEach(field => {
                    const input = form.querySelector(`[name="${field}"]`);
                    input?.dispatchEvent(new Event('input'));
                });
            });

            saveAsTemplateBtn.addEventListener('click', async () => {
                const name = prompt('Nom du template :');
                if (!name) return;

                const payload = {
                    name,
                    subject: form.querySelector('[name="subject"]').value,
                    title: form.querySelector('[name="title"]').value,
                    message: form.querySelector('[name="message"]').value,
                    actionUrl: form.querySelector('[name="actionUrl"]').value || undefined,
                    actionText: form.querySelector('[name="actionText"]').value || undefined,
                    category: form.querySelector('[name="category"]').value,
                };

                try {
                    const response = await fetch('/api/admin/emails/templates', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload),
                    });
                    const data = await parseJsonSafe(response);
                    if (!response.ok) {
                        alert('Erreur: ' + (data.error || 'Impossible de créer le template'));
                        return;
                    }
                    showNotification('Template enregistré', 'success');
                    await loadTemplates();
                    templateSelect.value = data.id;
                } catch (error) {
                    alert('Erreur réseau: ' + error.message);
                }
            });

            // Envoi du formulaire
            form.addEventListener('submit', async (e) => {
                e.preventDefault();

                const formData = new FormData(form);
                const recipientType = formData.get('recipientType');
                const recipients = recipientType === 'custom' 
                    ? formData.get('recipients')?.split('\n').map(e => e.trim()).filter(e => e)
                    : undefined;
                const roleId = recipientType === 'role' ? formData.get('roleId') : undefined;

                if (recipientType === 'role' && !roleId) {
                    alert('Veuillez sélectionner un rôle.');
                    return;
                }

                const payload = {
                    recipientType,
                    roleId,
                    recipients,
                    subject: formData.get('subject'),
                    title: formData.get('title'),
                    message: formData.get('message'),
                    actionUrl: formData.get('actionUrl') || undefined,
                    actionText: formData.get('actionText') || undefined,
                    templateId: formData.get('templateId') || undefined,
                    category: formData.get('category'),
                };

                try {
                    const response = await fetch('/api/admin/emails/send', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    const data = await parseJsonSafe(response);

                    if (!response.ok) {
                        alert('Erreur: ' + (data.error || 'Impossible d\'envoyer l\'email'));
                        return;
                    }

                    alert(data.message);
                    form.reset();
                    loadCampaigns();
                    loadStats();
                } catch (error) {
                    alert('Erreur: ' + error.message);
                }
            });

            // Charger l'historique
            async function loadCampaigns() {
                try {
                    const response = await fetch('/api/admin/emails/campaigns');
                    const campaigns = await parseJsonSafe(response);

                    const historyDiv = document.getElementById('campaignsHistory');
                    if (!campaigns.length) {
                        historyDiv.innerHTML = '<p class="text-center py-8">Aucune campagne envoyée</p>';
                        return;
                    }

                    historyDiv.innerHTML = campaigns.map(campaign => `
                        <div class="border border-slate-700 rounded-2xl p-4 hover:border-slate-600 transition-colors">
                            <div class="flex items-start justify-between">
                                <div class="flex-1">
                                    <h3 class="font-semibold text-white">${campaign.subject}</h3>
                                    <p class="text-sm text-slate-400 mt-1">
                                        Catégorie: 
                                        <span class="inline-block px-2 py-1 bg-slate-800 rounded text-xs font-medium">
                                            ${campaign.category}
                                        </span>
                                    </p>
                                    <p class="text-xs text-slate-500 mt-2">
                                        Par: <strong>${campaign.createdBy?.userName || 'System'}</strong>
                                    </p>
                                </div>
                                <div class="text-right">
                                    <div class="text-blue-400 font-bold">${campaign.sentCount}</div>
                                    <div class="text-xs text-slate-400">emails envoyés</div>
                                    <div class="text-xs text-emerald-400 mt-2">Ouvertures: ${campaign.openRate}%</div>
                                    <div class="text-xs text-amber-400">Clics: ${campaign.clickRate}%</div>
                                    <div class="text-xs text-slate-500 mt-2">
                                        ${new Date(campaign.createdAt).toLocaleDateString('fr-FR')}
                                    </div>
                                </div>
                            </div>
                        </div>
                    `).join('');
                } catch (error) {
                    console.error('Erreur lors du chargement:', error);
                }
            }

            // Charger les campagnes au chargement
            loadCampaigns();
            loadStats();
            loadTemplates();

            // Gestion du toggle d'envoi d'emails
            const emailToggle = document.getElementById('emailToggle');
            emailToggle.addEventListener('change', async (e) => {
                const enabled = e.target.checked;
                
                try {
                    const response = await fetch('/admin/emails/toggle', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ enabled })
                    });

                    const data = await parseJsonSafe(response);

                    if (!response.ok) {
                        alert('Erreur lors de la mise à jour : ' + (data.error || 'Erreur inconnue'));
                        e.target.checked = !enabled;
                        return;
                    }

                    // Notification visuelle
                    const statusText = enabled ? 'activées' : 'désactivées';
                    showNotification(`Campagnes d'emails ${statusText} avec succès`, 'success');
                } catch (error) {
                    alert('Erreur réseau : ' + error.message);
                    e.target.checked = !enabled;
                }
            });

            // Notification visual helper
            function showNotification(message, type = 'info') {
                const notification = document.createElement('div');
                notification.className = `fixed top-4 right-4 px-6 py-3 rounded-2xl shadow-lg text-white font-medium z-50 transition-all ${
                    type === 'success' ? 'bg-emerald-600' : 
                    type === 'error' ? 'bg-red-600' : 'bg-blue-600'
                }`;
                notification.textContent = message;
                document.body.appendChild(notification);
                
                setTimeout(() => {
                    notification.style.opacity = '0';
                    setTimeout(() => notification.remove(), 300);
                }, 3000);
            }

            // Fonctions pour la file d'attente
            async function processQueue() {
                const btn = document.getElementById('processBtn');
                if (!btn) return;
                
                btn.disabled = true;
                btn.textContent = '⏳ Traitement...';

                try {
                    const res = await fetch('/admin/emails/queue/process', { method: 'POST' });
                    const data = await parseJsonSafe(res);

                    if (data.success) {
                        showNotification(`✅ ${data.sent} envoyés, ${data.failed} échoués, ${data.remaining} restants`, 'success');
                        setTimeout(() => location.reload(), 2000);
                    } else {
                        showNotification('❌ Erreur lors du traitement', 'error');
                    }
                } catch (err) {
                    showNotification('❌ Erreur réseau', 'error');
                } finally {
                    btn.disabled = false;
                    btn.textContent = '🚀 Traiter la queue maintenant';
                }
            }

            async function cancelEmail(id) {
                if (!confirm('Êtes-vous sûr de vouloir annuler cet email ?')) return;

                try {
                    const res = await fetch(`/admin/emails/queue/cancel/${id}`, { method: 'POST' });
                    const data = await parseJsonSafe(res);

                    if (data.success) {
                        showNotification('✅ Email annulé', 'success');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showNotification('❌ ' + (data.error || 'Erreur'), 'error');
                    }
                } catch (err) {
                    showNotification('❌ Erreur réseau', 'error');
                }
            }
        </script>
